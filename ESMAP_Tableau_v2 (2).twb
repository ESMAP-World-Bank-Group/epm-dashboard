          <datasource-dependencies datasource='federated.1658zy81lz2h3u1gu0hna1hkm2gh'>
            <column caption='Indicator Attribute' datatype='boolean' name='[Calculation_1601592635822628865]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[Parameters].[Parameter 3]=[Calculation_3206000004388323328]' />
            </column>
            <column caption='Aggregation Unit' datatype='string' name='[Calculation_1601592635824541699]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='case [Parameters].[Parameter 4]&#13;&#10;WHEN &apos;Country&apos; THEN [c]&#13;&#10;WHEN &apos;Zone&apos; THEN [z]&#13;&#10;END' />
            </column>
            <column caption='Total Value Compare' datatype='real' name='[Calculation_1601592635830226948]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Parameters].[Parameter 2]&#13;&#10;WHEN &apos;Absolute&apos; THEN WINDOW_SUM([Calculation_804455501756768259])&#13;&#10;WHEN &apos;Difference&apos; THEN WINDOW_SUM([Calculation_804455501756768259])&#13;&#10;WHEN &apos;Percentage&apos; THEN 1&#13;&#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Total Value Displayed' datatype='string' name='[Calculation_1601592635831001093]' role='measure' type='nominal'>
              <calculation class='tableau' formula='case [Parameters].[Parameter 2]&#13;&#10;WHEN &apos;Percentage&apos; THEN &apos;&apos;&#13;&#10;ELSE &#13;&#10;CASE [Parameters].[Parameter 5]&#13;&#10;WHEN &apos;Yes&apos; THEN&#13;&#10;    CASE [Parameters].[Parameter 3]&#13;&#10;        WHEN &apos;CapexInvestmentComponentCumulated&apos; THEN &apos;M$ &apos; + STR(ROUND([Calculation_1601592635830226948]/10^6, 0))&#13;&#10;        WHEN &apos;CapexInvestmentComponent&apos; THEN &apos;M$ &apos; + STR(ROUND([Calculation_1601592635830226948]/10^6, 0))&#13;&#10;        ELSE STR(ROUND([Calculation_1601592635830226948], 0))&#13;&#10;    END&#13;&#10;ELSE &apos;&apos;&#13;&#10;END&#13;&#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Total Value Displayed New' datatype='string' name='[Calculation_1954562265120755712]' role='measure' type='nominal'>
              <calculation class='tableau' formula='CASE [Parameters].[Parameter 2]&#13;&#10;WHEN &apos;Difference&apos; THEN&#13;&#10;    IF ATTR([Path - Split 1]) = ATTR([Parameters].[Parameter 1]) THEN&#13;&#10;        &apos;&apos;&#13;&#10;    ELSE&#13;&#10;        [Calculation_1601592635831001093]&#13;&#10;    END&#13;&#10;ELSE&#13;&#10;    [Calculation_1601592635831001093]&#13;&#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Attribute Full' datatype='string' name='[Calculation_3206000004388323328]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [Path - Split 3]&#13;&#10;WHEN &apos;pCapexInvestmentComponent.csv&apos; THEN &apos;CapexInvestmentComponent&apos;&#13;&#10;WHEN &apos;pCapexInvestmentComponentCumulated.csv&apos; THEN &apos;CapexInvestmentComponentCumulated&apos;&#13;&#10;ELSE [attribute]&#13;&#10;END' />
            </column>
            <column caption='Legend' datatype='string' name='[Calculation_804455501749575680]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [Path - Split 2]&#13;&#10;WHEN &quot;pTechFuelMerged.csv&quot; THEN [techfuel]&#13;&#10;WHEN &quot;pCostsMerged.csv&quot; THEN [uni]&#13;&#10;WHEN &apos;pCapexInvestmentMerged.csv&apos; THEN [uni]&#13;&#10;END' />
            </column>
            <column caption='Value baseline' datatype='real' name='[Calculation_804455501755736066]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [y], [Calculation_1601592635824541699],[Calculation_804455501749575680],[Calculation_3206000004388323328]: &#13;&#10;  SUM(IF [Path - Split 1] = [Parameters].[Parameter 1] THEN [value] END) &#13;&#10;}' />
            </column>
            <column caption='Value Compare' datatype='real' name='[Calculation_804455501756768259]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='case [Parameters].[Parameter 2]&#13;&#10;WHEN &quot;Absolute&quot; THEN SUM([value])&#13;&#10;WHEN &quot;Difference&quot; THEN SUM([value])-sum([Calculation_804455501755736066])&#13;&#10;WHEN &quot;Percentage&quot; THEN sum([value])/TOTAL(sum(([value])))&#13;&#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Positive values' datatype='boolean' name='[Calculation_804455501761146885]' role='measure' type='nominal'>
              <calculation class='tableau' formula='ABS([Calculation_804455501756768259])&gt;0'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Scenario' datatype='string' name='[Path - Split 1]' role='dimension' type='nominal' user:SplitFieldIndex='1' user:SplitFieldOrigin='[federated.1658zy81lz2h3u1gu0hna1hkm2gh].[Path]'>
