2345   
2346  Sets
2347     H2status  'H2 generation plant status' / Existing, Candidate, Committed /
2348     eh(hh)           'existing hydrogen generation plants'
2349     nh(hh)           'new hydrogen generation plants'
2350     RampRateH2(hh)   'ramp rate constrained H2 generator blocks' // Ramprate takes out inflexible generators for a stronger formulation so that it runs faster
2351     dcH2(hh)         'candidate generators with capex trajectory'
2352     ndcH2(hh)        'candidate generators without capex trajectory'
2353     nRE(g)           'non RE generators'
2354     nVRE(g)          'non VRE generators'
2355     REH2(g)          'set of RE generators which are NOT VRE'
2356     nREH2(g)         'set of generators that are dont belong to subset REH2(g)'
2357     h2zmap(hh,z)
2358     sH2PwrIn(hh,q,d,t,y)
2359  ;
2360   
2361  Sets
2362     H2statusmap(hh,H2status) 'Hydrogen unit status'
2363  ;
2364   
2365  Parameters
2366      fEnableH2Production
2367     pCRFH2(hh)                       'Capital recovery factor'
2368     pCapexTrajectoriesH2(hh,y)       'CAPEX trajectories for hydrogen generation units'
2369     pVarCostH2(hh,y)                 'Variable cost - H2 production'
2370     pH2UnservedCost                  'Cost of external H2 unserved'
2371     pH2Data(hh,pH2Header)                    'Hydrogen production specifications'
2372  ;
2373   
2374  Positive Variables
2375     vCapH2(hh,y)                'total capacity in place accounting for legacy, new and retired plants (MW)'
2376     vBuildH2(hh,y)              'Build (MW)'
2377     vRetireH2(hh,y)             'Retire (MW)'
2378     vH2PwrIn(hh,q,d,t,y)        'Power drawn by H2 plants for H2 production in MW'
2379     vFuelH2(z,y)                'Annual H2 production in MMBTU'
2380     vAnnCapexH2(hh,y)           'Annualized CAPEX of H2 producing technologies'
2381     vPwrREH2(z,q,d,t,y)          'Generation from RE generators that goes to H2 production'
2382     vPwrREGrid(z,q,d,t,y)       'Generation from RE generators that goes to the grid'
2383     vREPwr2H2(g,f,q,d,t,y)       'Generation from RE generators that goes to H2 production'
2384     vREPwr2Grid(g,f,q,d,t,y)    'Generation from VRE generators that goes to the grid'
2385     vFuelH2Quarter(z,q,y)        'H2 fuel saved for H2 electricity generationon a quarterly basis'
2386     vUnmetExternalH2(z,q,y)        'mmBTU of external H2 demand that cant be met'
2387     vYearlyH2UnservedCost(z,y)   'Annual Cost of external H2 unserved in USD'
2388  ;
2389   
2390  Integer variable
2391     vBuiltCapVarH2(hh,y)
2392     vRetireCapVarH2(hh,y)
2393  ;
2394   
2395  Equations
2396      eH2UnservedCost(z,y)
2397      eCapBalanceH2(hh,y)
2398      eCapBalance1H2(hh,y)
2399      eCapBalance2H2
2400      eBuildNewH2(hh)
2401      eBuiltCapH2(hh,y)
2402      eRetireCapH2(hh,y)
2403      eMaxCF_H2(hh,q,y)
2404      eFuel_H2(c,q,y)
2405      eFuel_H2_2(c,z,y)
2406      eRampDnLimitH2(hh,q,d,t,y)
2407      eRampUpLimitH2(hh,q,d,t,y)
2408      eFuelLimitH2(c,f,y)
2409      eFuelLimitH2_2(c,f,y)
2410      eAnnCapexH2_1(hh,y)
2411      eAnnCapexH2(hh,y)
2412      eRE2H2(g,f,q,d,t,y)
2413      eRE2H2_2(z,q,d,t,y)
2414      eRE2H2_3(z,q,d,t,y)
2415      eRE2H2_4(z,q,d,t,y)
2416      eMaxH2PwrInjection(hh,q,d,t,y)
2417  ;
2418   
2419   
2420  * =============================
2421  * Hydrogen Contributions to Main Equations
2422  * =============================
2423   
2424  * --- Hydrogen Contribution to Yearly Cost ---
2425  Equation eYearlyTotalCost_H2Contribution;
2426   
2427  eYearlyTotalCost_H2Contribution(c,y)..
2428  *   vYearlyTotalCost(c,y) =e= vYearlyTotalCost(c,y)
2429      0 =e=
2430                            + sum(zcmap(z,c), vYearlyH2UnservedCost(z,y))$fEnableH2Production;
2431   
2432  * --- Hydrogen Contribution to Total Annualized CAPEX ---
2433  Equation eTotalAnnualizedCapex_H2Contribution;
2434   
2435  eTotalAnnualizedCapex_H2Contribution(z,y)..
2436  *   vAnnCapex(z,y) =e= vAnnCapex(z,y)
2437      0 =e=
2438                     + sum(h2zmap(ndcH2,z), pCRFH2(ndcH2)*vCapH2(ndcH2,y)*pH2Data(ndcH2,"Capex")*1e6)$fEnableH2Production
2439                     + sum(h2zmap(dcH2,z), vAnnCapexH2(dcH2,y))$fEnableH2Production;
2440   
2441  * --- Hydrogen Contribution to Yearly Variable O&M Cost ---
2442  Equation eYearlyVOMCost_H2Contribution;
2443   
2444  eYearlyVOMCost_H2Contribution(z,y)..
2445  *   vYearlyVOMCost(z,y) =e= vYearlyVOMCost(z,y)
2446      0 =e=
2447                           + sum((h2zmap(hh,z),q,d,t), pVarCostH2(hh,y)*pH2Data(hh,"Heatrate")*vH2PwrIn(hh,q,d,t,y)*pHours(q,d,t))$fEnableH2Production;
2448   
2449  * --- Hydrogen Unserved Demand Cost (can stay modular as-is) ---
2450  Equation eH2UnservedCost;
2451   
2452  eH2UnservedCost(z,y)..
2453     vYearlyH2UnservedCost(z,y) =e= sum(q, vUnmetExternalH2(z,q,y)) * pH2UnservedCost $fEnableH2Production;
2454   
2455  * --- Hydrogen Supply Contribution to Demand Balance ---
2456  Equation eSupply_H2Contribution;
2457   
2458  * TODO: Change that
2459  eSupply_H2Contribution(z,q,d,t,y)..
2460  *   vSupply(z,q,d,t,y) =e=vSupply(z,q,d,t,y)
2461  *        -sum((gzmap(g,z),gfmap(g,f)),vPwrOut(g,f,q,d,t,y))
2462      0 =e=
2463       + sum((gzmap(nRE,z),gfmap(nRE,f)),vPwrOut(nRE,f,q,d,t,y))$(fEnableH2Production)
2464       + vPwrREGrid(z,q,d,t,y)$fEnableH2Production;
2465   
2466  * =============================
2467  * Hydrogen Specific Equations
2468  * =============================
2469   
2470   
2471  * Total capacity of H2 plants at 1st year of optimization is equal to pre-existing capacity plus capacity being bulit minus retired capacity
2472  eCapBalanceH2(hh,sStartYear(y))$(fEnableH2Production)..
2473     vCapH2(hh,y) =e= pH2Data(hh,"Capacity")$(eh(hh) and (pH2Data(hh,"StYr") <= sStartYear.val))
2474                 + vBuildH2(hh,y) - vRetireH2(hh,y);
2475   
2476  * Total capacity of existing H2 palnts is equal to capacity over previous year plus capacity being built in current year minus retired capacity in current year
2477  *Checked
2478  eCapBalance1H2(eh,y)$(not sStartYear(y) and fEnableH2Production)..
2479     vCapH2(eh,y) =e= vCapH2(eh,y-1) + vBuildH2(eh,y) - vRetireH2(eh,y);
2480   
2481  * Total capacity of candidate H2 plants is equal to total capacity at previous year plus capacity being built in current year minus retired capacity in current year
2482  *Checked
2483  eCapBalance2H2(nh,y)$(not sStartYear(y) and fEnableH2Production)..
2484     vCapH2(nh,y) =e= vCapH2(nh,y-1) + vBuildH2(nh,y);
2485   
2486  * New H2 plants can be buuilt only after the StYr; the newly built capacity need to be less than declared capacity
2487  *Checked
2488  eBuildNewH2(eh)$(pH2Data(eh,"StYr") > sStartYear.val and fEnableH2Production)..
2489      sum(y, vBuildH2(eh,y)) =l= pH2Data(eh,"Capacity");
2490   
2491   
2492  * (Integer units ) Built capacity each year is equal to unit size
2493  *Checked
2494  eBuiltCapH2(nh,y)$(pH2Data(nh,"DescreteCap") and fEnableH2Production)..
2495     vBuildH2(nh,y) =e= pH2Data(nh,"UnitSize")*vBuiltCapVarH2(nh,y);
2496   
2497  * (Integer units ) Retired capacity each year is equal to unit size
2498  *Checked
2499  eRetireCapH2(eh,y)$(pH2Data(eh,"DescreteCap") and (y.val <= pH2Data(eh,"RetrYr")) and fEnableH2Production)..
2500     vRetireH2(eh,y) =e= pH2Data(eh,"UnitSize")*vRetireCapVarH2(eh,y);
2501   
2502  *  Maximum capacity factor of H2 production based on availability
2503  *Checked
2504  eMaxCF_H2(hh,q,y)$(fEnableH2Production)..
2505     sum((d,t), vH2PwrIn(hh,q,d,t,y)*pHours(q,d,t)) =l= pAvailabilityH2(hh,q)*vCapH2(hh,y)*sum((d,t), pHours(q,d,t));
2506   
2507  *       mmBTU of H2 produced
2508  eFuel_H2(c,q,y)$(fEnableH2Production)..
2509  *                   mmBTU            mmBTU                    mmBTU                                                                     -MWe-                Hr                mmBTU/MWhe
2510      sum(zcmap(z,c), pExternalH2(z,q,y)-vUnmetExternalH2(z,q,y)$pExternalH2(z,q,y)+vFuelH2Quarter(z,q,y)) =e= sum( (zcmap(z,c),h2zmap(hh,z), d,t), vH2PwrIn(hh,q,d,t,y)*pHours(q,d,t)*pH2Data(hh,"HeatRate"));
2511   
2512  eFuel_H2_2(c,z,y)$(fEnableH2Production)..
2513      sum((zcmap(z,c),q),vFuelH2Quarter(z,q,y)) =e=  sum(zcmap(z,c),vFuelH2(z,y));
2514   
2515  eMaxH2PwrInjection(hh,q,d,t,y)$fEnableH2Production..
2516      vH2PwrIn(hh,q,d,t,y)  =l= vCapH2(hh,y);
2517   
2518  * The amount of hydrogen fuel that can be used for electricity generation can not be more than the amount of H2 that was produced from VRE curtailment
2519  eFuelLimitH2(c,f,y)$(pFuelDataH2(f) and fEnableH2Production)..
2520     sum((zcmap(z,c)),  vFuel(z,f,y)) =e=  sum((zcmap(z,c)), vFuelH2(z,y));
2521   
2522   
2523  *When the H2 production flag is off don't account for H2 fuel
2524  eFuelLimitH2_2(c,f,y)$(pFuelDataH2(f) and fEnableH2Production=0)..
2525     sum((zcmap(z,c)),  vFuel(z,f,y)) =e=  0;
2526   
2527   
2528  eRampDnLimitH2(hh,q,d,t,y)$(RamprateH2(hh) and not sFirstHour(t) and fApplyRampConstraint and fEnableH2Production)..
2529      vH2PwrIn(hh,q,d,t-1,y) -  vH2PwrIn(hh,q,d,t,y) =l= vCapH2(hh,y)*pH2Data(hh,"RampDnRate");
2530   
2531  eRampUpLimitH2(hh,q,d,t,y)$(RamprateH2(hh) and not sFirstHour(t) and fApplyRampConstraint and fEnableH2Production)..
2532     vH2PwrIn(hh,q,d,t,y) -  vH2PwrIn(hh,q,d,t-1,y) =l= vCapH2(hh,y)*pH2Data(hh,"RampUpRate");
2533   
2534  *Calculation of Annualized CAPEX for electrolyzers
2535  eAnnCapexH2_1(dcH2,y)$(not sStartYear(y) and fEnableH2Production)..
2536     vAnnCapexH2(dcH2,y) =e= vAnnCapexH2(dcH2,y-1)
2537                       + vBuildH2(dcH2,y)*pH2Data(dcH2,"Capex")*pCapexTrajectoriesH2(dcH2,y)*pCRFH2(dcH2)*1e6;
2538   
2539  eAnnCapexH2(dcH2,sStartYear(y))$fEnableH2Production..
2540     vAnnCapexH2(dcH2,y) =e= vBuildH2(dcH2,y)*pH2Data(dcH2,"Capex")*pCapexTrajectoriesH2(dcH2,y)*pCRFH2(dcH2)*1e6;                                                                          ;
2541   
2542  eRE2H2_4(z,q,d,t,y)$fEnableH2Production..
2543    sum(h2zmap(hh,z),vH2PwrIn(hh,q,d,t,y))=e=vPwrREH2(z,q,d,t,y);
2544   
2545   
2546  eRE2H2_3(z,q,d,t,y)$fEnableH2Production..
2547   vPwrREH2(z,q,d,t,y) =e= sum((gfmap(RE,f),gzmap(RE,z)),vREPwr2H2(RE,f,q,d,t,y));
2548   
2549  eRE2H2_2(z,q,d,t,y)$fEnableH2Production..
2550  vPwrREGrid(z,q,d,t,y)=e=sum((gfmap(RE,f),gzmap(RE,z)),vREPwr2Grid(RE,f,q,d,t,y));
2551   
2552  eRE2H2(RE,f,q,d,t,y)$fEnableH2Production..
2553   vPwrOut(RE,f,q,d,t,y)=e=vREPwr2Grid(RE,f,q,d,t,y)+vREPwr2H2(RE,f,q,d,t,y);
2554   
2555  *For example equation below is deactivated when H2 is on and is replaced by eVREProfile2
2556   
2557  * =============================
2558  * Updating Hydrogen Model
2559  * =============================
2560   
2561   
2563  Model PA /
2564   
2565      eYearlyTotalCost_H2Contribution,
2566      eTotalAnnualizedCapex_H2Contribution,
2567      eYearlyVOMCost_H2Contribution,
2568      eH2UnservedCost,
2569      eSupply_H2Contribution
2570   
2571     vH2PwrIn(sH2PwrIn)
2572     eBuildNewH2
2573     eCapBalance1H2
2574     eCapBalance2H2
2575     eCapBalanceH2
2576     eBuiltCapH2
2577     eRetireCapH2
2578  *eDemSupplyH2
2579     eMaxCF_H2
2580     eFuel_H2
2581     eFuel_H2_2
2582     eRampDnLimitH2
2583     eRampUpLimitH2
2584     eFuelLimitH2
2585     eFuelLimitH2_2
2586  *eYearlyCurtailmentCost2
2587   
2588     eRE2H2
2589     eRE2H2_2
2590     eRE2H2_3
2591     eRE2H2_4
2592     eMaxH2PwrInjection
2593   
2594     eAnnCapexH2_1
2595     eAnnCapexH2
2596     /
2597  ;
2599   
2600  *-------------------------------------------------------------------------------------
2601  * Generate gfmap and others from pGenDataInput
2602  parameter gstatIndex(gstatus) / Existing 1, Candidate 3, Committed 2 /;
2603  parameter tstatIndex(tstatus) / Candidate 3, Committed 2 /;
2604   
2605  *H2 model parameter
2606  parameter H2statIndex(H2status) / Existing 1, Candidate 3, Committed 2 /;
2607   
2608   
2609  * Aggregate `gmap(g,z,tech,f)` over `tech` and `f` to get `gzmap(g,z)`,
2610  * which represents the mapping of generator `g` to zone `z`.
2611  gzmap(g,z) = sum((tech,f), gmap(g,z,tech,f));
2612   
2613  * Aggregate `gmap(g,z,tech,f)` over `tech` and `z` to get `gfmap(g,f)`,
2614  * which represents the mapping of generator `g` to fuel `f`.
2615  gfmap(g,f) = sum((tech,z), gmap(g,z,tech,f));
2616   
2617  * Compute `gprimf(g,f)`, which is similar to `gfmap(g,f)`,
2618  * aggregating over `tech` and `z` to represent the primary fuel mapping.
2619  gprimf(g,f) = sum((tech,z), gmap(g,z,tech,f));
2620   
2621  * Aggregate `gmap(g,z,tech,f)` over `z` and `f` to get `gtechmap(g,tech)`,
2622  * which represents the mapping of generator `g` to technology `tech`.
2623  gtechmap(g,tech) = sum((z,f), gmap(g,z,tech,f));
2624   
2625  * TODO: Update `gfmap(g,f)`, ensuring it includes additional mappings
2626  * based on `pGenDataInput(g,z,tech,f2,'fuel2')` when a condition is met.
2627  * gfmap(g,f) = gfmap(g,f) or sum((z,tech,f2), (pGenDataInput(g,z,tech,f2,'fuel2') = pTechFuel(tech,f,'FuelIndex')));
2628   
2629   
2630  * Map generator status from input data
2631  gstatusmap(g,gstatus) = sum((z,tech,f),pGenDataInput(g,z,tech,f,'status')=gstatIndex(gstatus));
2632   
2633   
2634  pHeatrate(gprimf(g,f)) = sum((z,tech), pGenDataInput(g,z,tech,f,"Heatrate"));
2635  pHeatrate(g,f2)$(gfmap(g,f2) and not gprimf(g,f2)) =
2636      sum((z,tech,f), pGenDataInput(g,z,tech,f,"Heatrate2")
2637  *  $(pGenDataInput(g,z,tech,f,"fuel2") = pTechFuel(tech,f2,'FuelIndex'))
2638      );
2639   
2640   
2641  pGenData(g,pGenDataInputHeader) = sum((z,tech,f),pGenDataInput(g,z,tech,f,pGenDataInputHeader));
2642   
2643  ***********************H2 model parameters***************************************************
2644   
2645  pH2Data(hh,pH2Header)=pH2DataExcel(hh,pH2Header);
2646  H2statusmap(hh,H2status) = pH2DataExcel(hh,'status')=H2statIndex(H2status);
2647  * TODO: Check is that works for H2
2648  * h2zmap(hh,z) = pH2DataExcel(hh,'Zone')=pZoneIndex(z);
2649  h2zmap(hh,z) = pH2DataExcel(hh,'Zone');
2650   
2651  *-------------------------------------------------------------------------------------
2652   
2653  *--- Parameter initialisation for same demand profile for all years
2654   
INCLUDE    /Data/EAPP/EPM/epm/generate_demand.gms
2656  **********************************************************************
2657  * ELECTRICITY PLANNING MODEL (EPM)
2658  * Developed at the World Bank
2659  **********************************************************************
2660  * Description:
2661  * This GAMS-based model is designed for electricity system planning,
2662  * incorporating capacity expansion, generation dispatch, and policy
2663  * constraints such as renewable energy targets, emissions reductions,
2664  * and market mechanisms.
2665  *
2666  * Author(s): ESMAP Modelling Team
2667  * Organization: World Bank
2668  * Version:
2669  * License: Creative Commons Zero v1.0 Universal
2670  *
2671  * Key Features:
2672  * - Optimization of electricity generation and capacity planning
2673  * - Inclusion of renewable energy integration and storage technologies
2674  * - Multi-period, multi-region modeling framework
2675  * - CO2 emissions constraints and policy instruments
2676  *
2677  * Notes:
2678  * - Ensure GAMS is installed before running this model.
2679  * - The model requires input data in .GDX or Excel format.
2680  *
2681  * Contact:
2682  * Claire Nicolas, cnicolas@worldbank.org
2683  **********************************************************************
2684   
2685  *--- Adjust peak and energy in case user selected same demand profile for all years
2686   
2687  Parameters
2688     pmax(z,y)
2689     pmin(z,y)
2690     pdiff(z,y)
2691     ptotalenergy(z,y)
2692     ptemp2(y)
2693     ptemp(y)
2694     pTempDemand(z,q,d,y,t)
2695  ;
2696   
2697  Variable
2698     pyval(z,q,d,y,t)
2699     divisor(z,y)
2700     obj
2701  ;
2702   
2703  divisor.lo(z,y) = card(q)*card(d)*card(t);
2704   
2705  Equation
2706     getDivisor(z,q,d,y,t)
2707     getArea(z,y)
2708     objFn
2709  ;
2710   
2711  getDivisor(z,q,d,y,t)..  pyval(z,q,d,y,t) =e=  [2*pdiff(z,y)/divisor(z,y) * (pmax(z,y) - pDemandProfile(z,q,d,t))]/sqr(pmax(z,y) - pmin(z,y));
2712  getArea(z,y)..           sum((q,d,t), pyval(z,q,d,y,t) * pHours(q,d,t)) =e=  pdiff(z,y);
2713  objFn..                  obj =e= sum((z,q,d,y,t), pyval(z,q,d,y,t));
2714   
2715  model demand / getDivisor, getArea, objFn /;
2716   
2717  * If using alt demand:
2718  if (pSettings("fUseSimplifiedDemand") = 1,
2719     pTempDemand(z,q,d,y,t) = pDemandProfile(z,q,d,t) * pDemandForecast(z,"Peak",y);
2720   
2721     pdiff(z,y) = ((pDemandForecast(z,"Energy",y)*1e3) - sum((q,d,t), pTempDemand(z,q,d,y,t)*pHours(q,d,t) )) ;
2722   
2723     pmax(z,y) = smax((q,d,t), pDemandProfile(z,q,d,t));
2724     pmin(z,y) = smin((q,d,t)$pDemandProfile(z,q,d,t), pDemandProfile(z,q,d,t));
2725  *   option limrow=1000; debugging
2726     Solve demand using nlp min obj;
2727   
2728     abort$(demand.modelstat<>1 and demand.modelstat<>2) 'Demand model not solved successfully';
2730     pDemandData(z,q,d,y,t) =  pTempDemand(z,q,d,y,t) + pyval.l(z,q,d,y,t);
2732     ptemp(y) = sum((z,q,d,t), pdemanddata(z,q,d,y,t)*pHours(q,d,t))/1000;
2733     ptemp2(y) = smax((q,d,t),sum(z, pdemanddata(z,q,d,y,t)));
2734  );
2735   
2736  ptotalenergy(z,y) =  sum((q,d,t), pdemanddata(z,q,d,y,t)*pHours(q,d,t))/1e3;
2737   
2738  *--- Part2: Start of initialisation of other parameters
2739   
2740  * Read main parameters from pSettings
2741   
2742  fEnableStorage                     = pSettings("fEnableStorage");
2743  fDispatchMode                      = pSettings("fDispatchMode");
2744   
2745  * --- Settings: Dispatch constraint switches
2746  fApplyMinGenCommitment      = pSettings("fApplyMinGenCommitment");
2747  fApplyStartupCost                  = pSettings("fApplyStartupCost");
2748  fApplyRampConstraint               = pSettings("fApplyRampConstraint");
2749  fApplyMUDT                       = pSettings("fApplyMUDT");
2750   
2751  * --- Settings: Economic parameters and penalties
2752  pDR                          = pSettings("DR");
2753  pWACC                        = pSettings("WACC");
2754  pVoLL                        = pSettings("VoLL");
2755  pPlanningReserveVoLL         = pSettings("ReserveVoLL");
2756  pSpinningReserveVoLL         = pSettings("SpinReserveVoLL");
2757  pSurplusPenalty              = pSettings("CostSurplus");
2758  pCostOfCurtailment           = pSettings("CostCurtail");
2759  pCostOfCO2backstop           = pSettings("CO2backstop");
2760  pH2UnservedCost              = pSettings("H2UnservedCost");
2761  ssMaxCapitalInvestmentInvestment = pSettings("sMaxCapitalInvestment") * 1e6;
2762   
2763  * --- Settings: Reserve requirements
2764  fApplyPlanningReserveConstraint    = pSettings("fApplyPlanningReserveConstraint");
2765  sReserveMarginPct                  = pSettings("sReserveMarginPct");
2766  fApplyCountrySpinReserveConstraint = pSettings("fApplyCountrySpinReserveConstraint");
2767  fApplySystemSpinReserveConstraint = pSettings("fApplySystemSpinReserveConstraint");
2768  psVREForecastErrorPct              = pSettings("sVREForecastErrorPct");
2769  sIntercoReserveContributionPct     = pSettings("sIntercoReserveContributionPct");
2770  fCountIntercoForReserves           = pSettings("fCountIntercoForReserves");
2771   
2772  * --- Settings: Policy and operational switches
2773  fApplyMinGenShareAllHours      = pSettings("fApplyMinGenShareAllHours");
2774  fApplyFuelConstraint               = pSettings("fApplyFuelConstraint");
2775  fApplyGenerationPhaseout           = pSettings("fApplyGenerationPhaseout");
2776  fApplyCapitalConstraint            = pSettings("fApplyCapitalConstraint");
2777  fEnableCSP                         = pSettings("fEnableCSP");
2778  fEnableCapacityExpansion           = pSettings("fEnableCapacityExpansion");
2779  pMinRE                             = pSettings("sMinRenewableSharePct");
2780  pMinsRenewableTargetYear           = pSettings("sRenewableTargetYear");
2781  fApplyCountryCo2Constraint         = pSettings("fApplyCountryCo2Constraint");
2782  fApplySystemCo2Constraint         = pSettings("fApplySystemCo2Constraint");
2783  fEnableCarbonPrice                     = pSettings("fEnableCarbonPrice");
2784  fEnableEnergyEfficiency           = pSettings("fEnableEnergyEfficiency");
2785   
2786   
2787  * --- Settings: Transmission and trade
2788  fEnableInternalExchange            = pSettings("fEnableInternalExchange");
2789  fRemoveInternalTransferLimit       = pSettings("fRemoveInternalTransferLimit");
2790  fAllowTransferExpansion            = pSettings("fAllowTransferExpansion");
2791  fAllowTransferExpansion            = fAllowTransferExpansion * fEnableCapacityExpansion;
2792   
2793  fEnableExternalExchange            = pSettings("fEnableExternalExchange");
2794  sMaxHourlyImportExternalShare                 = pSettings("sMaxHourlyImportExternalShare");
2795  sMaxHourlyExportExternalShare                 = pSettings("sMaxHourlyExportExternalShare");
2796   
2797  * --- Settings: Hydrogen options
2798  fEnableCapexTrajectoryH2           = pSettings("fEnableCapexTrajectoryH2");
2799  fEnableH2Production               = pSettings("fEnableH2Production");
2800   
2801  * ----------------------------
2802  singleton set sFinalYear(y);
2803  scalar TimeHorizon;
2804   
2805  sStartYear(y) = y.first;
2806  sFinalYear(y) = y.last;
2807  TimeHorizon = sFinalYear.val - sStartYear.val + 1;
2808  sFirstHour(t) = t.first;
2809  sLastHour(t) = t.last;
2810  sFirstDay(d) = d.first;
2811   
2812  sFirstHourAT(AT) = AT.first;
2813   
2814  sLastDay(d) = yes$(ord(d) = card(d));
2815   
2816  * ------------------------------
2817  * Commitment initialization defaults
2818  * Consolidates initial ON/OFF values so a single section shows which units start online.
2819  * ------------------------------
2820  pInitialOnStart(g) = 0;
2821  pInitialOnStart(g)$pGenData(g,"InitialOn") = pGenData(g,"InitialOn");
2822   
2823   
2824  pStorageInitShare = pSettings("InitialSOCforBattery");
2825  if (pStorageInitShare < 0,
2826     pStorageInitShare = 0.5;
2827  );
2828   
2829  FD(q,d,t) = yes;
2830  if (fDispatchMode,
2831     FD(q,d,t)$(ord(q) eq 2 and ord(d) > 28) = no;
2832     FD(q,d,t)$((ord(q) eq 4 or ord(q) eq 6 or ord(q) eq 9 or ord(q) eq 11) and ord(d) > 30) = no;
2833  );
2834   
2835  * Identify which generators carry minimum-generation commitments so that startup cost logic can focus on them.
2836  MinGenPoint(g) = yes$(pGenData(g,"MinGenCommitment") > 0);
2837   
2838  * ------------------------------
2839   
2840   
2841  * Set external transfer limits to zero if exports are not allowed
2842  pExtTransferLimit(z,zext,q,"Import",y)$(not fEnableExternalExchange)  = 0 ;
2843  pExtTransferLimit(z,zext,q,"Export",y)$(not fEnableExternalExchange)  = 0 ;
2844   
2845  * Assign import and export transfer limits only if exports are allowed
2846  pExtTransferLimitIn(z,zext,q,y)$fEnableExternalExchange   = pExtTransferLimit(z,zext,q,"Import",y) ;
2847  pExtTransferLimitOut(z,zext,q,y)$fEnableExternalExchange  = pExtTransferLimit(z,zext,q,"Export",y) ;
2848   
2849  * Define `Zt(z)` to check if total demand in a zone `z` is zero
2850  Zt(z) = sum((q,d,y,t),pDemandData(z,q,d,y,t)) = 0;
2851  * Define `Zd(z)` as the complement of `Zt(z)`, indicating zones with demand
2852  Zd(z) = not Zt(z);
2853   
2854   
2855  * Aggregate storage data from the 4-index pStorageDataInput to pStorageData(g,header)
2856  pStorageData(g,pStorageDataHeader) = sum((z,tech,f), pStorageDataInput(g,z,tech,f,pStorageDataHeader));
2857   
2858  * gsmap is used for linked storage (PV+storage pairs)
2859  * gsmap(g2,g) means storage g is linked to generator g2
2860  * For standalone storage (empty "Linked plant"), gsmap remains empty
2861  * Note: If linked storage is needed, the "Linked plant" column should contain the generator name
2862  gsmap(g2,g) = no;
2863   
2864  * Identify candidate generators (`ng(g)`) based on their status in `gstatusmap`
2865  ng(g)  = gstatusmap(g,'candidate') or gstatusmap(g,'committed');
2866   
2867  * Define existing generators (`eg(g)`) as those that are not candidates, include comitted
2868  eg(g)  = not ng(g);
2869   
2870  * Identify variable renewable energy (VRE) generators (`vre(g)`) based on hourly variation data
2871  vre(g) = sum((gtechmap(g,tech),f)$pTechFuel(tech,f,'HourlyVariation'),1);
2872   
2873  * Identify renewable energy (RE) generators (`re(g)`) based on RE technology classification
2874  re(g)  = sum((gtechmap(g,tech),f)$pTechFuel(tech,f,'RETechnology'),1);
2875   
2876  * Identify concentrated solar power (CSP) technologies
2877  cs(g)  = gtechmap(g,"CSPPlant");
2878   
2879  * Identify PV with storage technologies
2880  so(g)  = gtechmap(g,"PVwSTO");
2881   
2882  * Identify solar thermal with PV (`STOPV`)
2883  stp(g) = gtechmap(g,"STOPV");
2884   
2885  * Identify storage technologies
2886  stg(g) = gtechmap(g,"Storage");
2887   
2888  * Define a general storage category (`st(g)`) as either `STOPV` or `STORAGE`
2889  st(g)  = gtechmap(g,"STOPV") or gtechmap(g,"Storage");
2890   
2891  * Define generators with capex trajectory data
2892  dc(g)  = sum(y, pCapexTrajectories(g,y));
2893   
2894  * Define generators without capex trajectory data
2895  ndc(g) = not dc(g);
2896   
2897  * Identify run-of-river hydro generators (`ror(g)`)
2898  ror(g) = gtechmap(g,"ROR");
2899   
2900  * Identify VRE generators excluding run-of-river hydro (`VRE_noROR(g)`)
2901  VRE_noROR(g) = vre(g) and not ror(g);
2902   
2903  * Define ramp-down rate for generators
2904  RampRate(g) = pGenData(g,"RampDnRate");
2905   
2906  * Map zones (`z`) to fuels (`f`) based on generator-fuel assignments (`gzmap` and `gfmap`)
2907  zfmap(z,f) = sum((gzmap(g,z),gfmap(g,f)), 1);
2908   
2909  * H2 model specific sets
2910  nh(hh)  = H2statusmap(hh,'candidate');
2911  eh(hh)  = not nh(hh);
2912  RampRateH2(hh)= pH2Data(hh,"RampDnRate");
2913  dcH2(hh)  = sum(y, pCapexTrajectoryH2(hh,y));
2914  ndcH2(hh) = not dcH2(hh);
2915  nRE(g) = not re(g);
2916  nVRE(g)=not VRE(g);
2917  REH2(g)= sum((gtechmap(g,tech),f)$pTechFuel(tech,f,'RETechnology'),1) - sum((gtechmap(g,tech),f)$pTechFuel(tech,f,'HourlyVariation'),1);
2918  nREH2(g)= not REH2(g);
2919   
2920  *-------------------------------------------------------------------
2921  * TOPOLOGY DEFINITION
2922  *-------------------------------------------------------------------
2923   
2924  * Defining sTopology based on existing, committed and candidate transmission lines
2925  sTopology(z,z2) = sum((q,y),pTransferLimit(z,z2,q,y)) + sum(pTransmissionHeader,pNewTransmission(z,z2,pTransmissionHeader)) + sum(pTransmissionHeader,pNewTransmission(z2,z,pTransmissionHeader));
2926   
2927  * If not running in interconnected mode, set network to 0
2928  sTopology(z,z2)$(not fEnableInternalExchange) = no;
2929   
2930  * if ignore transfer limit, set limits to high value
2931  pTransferLimit(sTopology,q,y)$fRemoveInternalTransferLimit = inf;
2932   
2933  * Default life for transmission lines
2934  pNewTransmission(sTopology,"Life")$(pNewTransmission(sTopology,"Life")=0 and fAllowTransferExpansion) = 30;
2935   
2936  * Map transmission status from input data
2937  tstatusmap(sTopology(z,z2),tstatus) = (pNewTransmission(z,z2, 'status')=tstatIndex(tstatus)) + (pNewTransmission(z2,z, 'status')=tstatIndex(tstatus));
2938   
2939  * Identify candidate generators (`ng(g)`) based on their status in `gstatusmap`
2940  commtransmission(sTopology(z,z2))  = tstatusmap(z,z2,'committed');
2941   
2942  *-------------------------------------------------------------------
2943  * CAPACITY CREDIT
2944  *-------------------------------------------------------------------
2945   
2946  * Identify the system peak demand for each year based on the highest total demand across all zones, times, and demand segments
2947  pFindSysPeak(y)     = smax((t,d,q), sum(z, pDemandData(z,q,d,y,t)));
2948   
2949  * Identify hours that are close to the peak demand for capacity credit calculations
2950  pAllHours(q,d,y,t)  = 1$(abs(sum(z,pDemandData(z,q,d,y,t))/pFindSysPeak(y) - 1)<pSettings("sPeakLoadProximityThreshold"));
2951   
2952  * Default capacity credit for all generators is set to 1
2953  pCapacityCredit(g,y)= 1;
2954   
2955  * Protect against unintended changes while modifying `pVREgenProfile` with `pVREProfile` data
2956  pVREgenProfile(VRE,q,d,t)$(not(pVREgenProfile(VRE,q,d,t))) = sum((z,tech)$(gzmap(VRE,z) and gtechmap(VRE,tech)),pVREProfile(z,tech,q,d,t));
2957   
2958  * Set capacity credit for VRE based on predefined values or calculated generation-weighted availability
2959  pCapacityCredit(VRE,y) =  Sum((z,q,d,t)$gzmap(VRE,z),Sum(f$gfmap(VRE,f),pVREgenProfile(VRE,q,d,t)) * pAllHours(q,d,y,t)) * (Sum((z,f,q,d,t)$(gfmap(VRE,f) and gzmap(VRE,z) ),pVREgenProfile(VRE,q,d,t))/sum((q,d,t),1));
2960   
2961  * Compute capacity credit for run-of-river hydro as an availability-weighted average
2962  pCapacityCredit(ROR,y) =  sum(q,pAvailability(ROR,y,q)*sum((d,t),pHours(q,d,t)))/sum((q,d,t),pHours(q,d,t));
2963   
2964  * Compute CSP and PV with storage generation profiles
2965  pCSPProfile(cs,q,d,t)    = sum((z,tech)$(gtechmap(cs,tech) and gzmap(cs,z)), pVREProfile(z,tech,q,d,t));
2966  pStoPVProfile(so,q,d,t)  =  sum((z,tech)$(gtechmap(so,tech) and gzmap(so,z)), pVREProfile(z,tech,q,d,t));
2967   
2968  * H2 model parameters
2969  pCapexTrajectoriesH2(hh,y) =1;
2970  pCapexTrajectoriesH2(dch2,y)$fEnableCapexTrajectoryH2 = pCapexTrajectoryH2(dcH2,y);
2971   
2972  *-------------------------------------------------------------------
2973  * Cost of capital
2974  *-------------------------------------------------------------------
2975   
2976  * Set the weight of the start year to 1.0
2977  pWeightYear(sStartYear) = 1.0;
2978  * Compute weight for each year as the difference from the previous year's cumulative weight
2979  pWeightYear(y)$(not sStartYear(y)) = y.val - sum(sameas(y2+1,y), y2.val) ;
2980   
2981  * Compute the present value discounting factor considering mid-period adjustments
2982  pRR(y) = 1.0;
2983  pRR(y)$(ord(y)>1) = 1/((1+pDR)**(sum(y2$(ord(y2)<ord(y)),pWeightYear(y2))-1 + sum(sameas(y2,y), pWeightYear(y2)/2))) ;
2984   
2985  *-------------------------------------------------------------------
2986  * Parameter Processing
2987  *-------------------------------------------------------------------
2988  pLossFactorInternal(z2,z,y)$(pLossFactorInternal(z,z2,y) and not pLossFactorInternal(z2,z,y)) = pLossFactorInternal(z,z2,y);
2989   
2990  pEnergyEfficiencyFactor(z,y)$(not fEnableEnergyEfficiency) = 1;
2991  pEnergyEfficiencyFactor(z,y)$(pEnergyEfficiencyFactor(z,y)=0) = 1;
2992   
2993  pVOMCost(gfmap(g,f),y) = pGenData(g,"VOM")
2994                         + pStorageData(g, "VOMMWh")
2995                         + pCSPData(g, "Storage", "VOMMWh")
2996                         + pCSPData(g, "Thermal Field", "VOMMWh");
2997   
2998  pFuelCost(g,f,y)$(gfmap(g,f)) = sum((gzmap(g,z),zcmap(z,c)),pFuelPrice(c,f,y)*pHeatRate(g,f));
2999  pVarCost(g,f,y)$(gfmap(g,f)) = pFuelCost(g,f,y) + pVOMCost(g,f,y);
3000  pVarCostH2(hh,y) = pH2Data(hh,"VOM");
3001   
3002  * pCRF refers to the Capital Recovery Factor, which is used to calculate the annualized cost of capital for a project.
3003  pCRF(g)$pGenData(g,'Life') = pWACC / (1 - (1 / ( (1 + pWACC)**pGenData(g,'Life'))));
3004  pCRFH2(hh)$pH2Data(hh,'Life') = pWACC / (1 - (1 / ( (1 + pWACC)**pH2Data(hh,'Life'))));
3005  pCRFsst(st)$pGenData(st,'Life') = pWACC / (1 - (1 / ( (1 + pWACC)**pGenData(st,'Life'))));
3006  pCRFcst(cs)$pGenData(cs,'Life') = pWACC / (1 - (1 / ( (1 + pWACC)**pGenData(cs,'Life'))));
3007  pCRFcth(cs)$pGenData(cs,'Life') = pWACC / (1 - (1 / ( (1 + pWACC)**pGenData(cs,'Life'))));
3008   
3009  * Defines which connected zones belong to different countries.
3010  sMapConnectedZonesDiffCountries(sTopology(z,z2)) = sum(c$(zcmap(z,c) and zcmap(z2,c)), 1) = 0;
3011   
3012  *** Simple bounds
3013   
3014  * Set upper limit for generation capacity based on predefined data
3015  vCap.up(g,y) = pGenData(g,"Capacity");
3016   
3017  * Fix the build decision variable to zero for existing generation projects (started before or at the model start year)
3018  vBuild.fx(eg,y)$(pGenData(eg,"StYr") <= sStartYear.val) = 0;
3019   
3020  * Set the upper limit for new generation builds per year, accounting for the annual build limit and year weighting
3021  * Exclude committed generators - they use Capacity directly, not BuildLimitperYear
3022  vBuild.up(ng,y)$(not gstatusmap(ng,'committed')) = pGenData(ng,"BuildLimitperYear")*pWeightYear(y);
3023   
3024  * Force committed generators (status=2) to be built at their start year.
3025  * Unlike candidates, committed generators are not optional - they must be built.
3026  * They remain in ng(g) so their CAPEX is included in total cost (unlike existing generators).
3027  * Note: BuildLimitperYear is ignored for committed generators - full capacity is built at StYr.
3028  vBuild.lo(ng,y)$(gstatusmap(ng,'committed') and (pGenData(ng,"StYr") = y.val)) = pGenData(ng,"Capacity");
3029  vBuild.up(ng,y)$(gstatusmap(ng,'committed') and (pGenData(ng,"StYr") = y.val)) = pGenData(ng,"Capacity");
3030   
3031  * Define the upper limit for additional transmission capacity, subject to high transfer allowance
3032  vNewTransmissionLine.up(sTopology(z,z2),y)$fAllowTransferExpansion = max(pNewTransmission(z,z2,"MaximumNumOfLines"),pNewTransmission(z2,z,"MaximumNumOfLines"));
3033   
3034  sAdditionalTransfer(sTopology(z,z2),y) = yes;
3035  sAdditionalTransfer(sTopology(z,z2),y) $((y.val < pNewTransmission(z,z2,"EarliestEntry")) or (y.val < pNewTransmission(z2,z,"EarliestEntry"))) = no;
3036   
3037  * Fix
3038  vNewTransmissionLine.fx(commtransmission(z,z2),y)$((max(pNewTransmission(z,z2,"EarliestEntry"),pNewTransmission(z2,z,"EarliestEntry")) <= y.val) and fAllowTransferExpansion) = max(pNewTransmission(z,z2,"MaximumNumOfLines"),pNewTransmission(z2,z,"MaximumNumOfLines"));
3039  vNewTransmissionLine.fx(commtransmission(z,z2),y)$(not sAdditionalTransfer(z,z2,y) and fAllowTransferExpansion) = 0;
3040   
3041  * Compute bounds
3042  vBuildTransmissionLine.lo(sTopology(z,z2),y) = max(0,vNewTransmissionLine.lo(z,z2,y) - vNewTransmissionLine.up(z,z2,y-1));
3043  vBuildTransmissionLine.up(sTopology(z,z2),y) = max(0,vNewTransmissionLine.up(z,z2,y) - vNewTransmissionLine.lo(z,z2,y-1));
3044   
3045  * Fix the storage build variable to zero if the project started before the model start year and storage is included
3046  vBuildStor.fx(eg,y)$(pGenData(eg,"StYr") <= sStartYear.val and fEnableStorage) = 0;
3047   
3048  * Fix the thermal build variable to zero if the project started before the model start year and CSP (Concentrated Solar Power) is included
3049  vBuildTherm.fx(eg,y)$(pGenData(eg,"StYr") <= sStartYear.val and fEnableCSP) = 0;
3050   
3051  * Disable all capacity expansion decisions when flag is off
3052  if (fEnableCapacityExpansion = 0,
3053     vBuild.fx(g,y)            = 0;
3054     vBuiltCapVar.fx(g,y)      = 0;
3055     vBuildStor.fx(g,y)        = 0;
3056     vBuildTherm.fx(g,y)       = 0;
3057     vBuildTransmissionLine.fx(z,z2,y) = 0;
3058     vNewTransmissionLine.fx(z,z2,y)   = 0;
3059     vBuildH2.fx(hh,y)         = 0;
3060     vBuiltCapVarH2.fx(hh,y)   = 0;
3061  );
3062   
3063  *-------------------------------------------------------------------
3064  * Fixed conditions
3065  *-------------------------------------------------------------------
3066   
3067   
3068  ********************* Load a previously saved solution**********************************************************
3069   
3070  * Load a previously saved solution from the specified path (if LOADSOLPATH is defined)
3071  * This solution contains the .l (level) values of capacity-related variables from a previous run
3073   
3074  ********************* Equations for generation capacity**********************************************************
3075  * Fix capacity to zero for generation projects that have not yet started in a given year
3076  vCap.fx(g,y)$(pGenData(g,"StYr") > y.val) = 0;
3077   
3078  * Set the fixed capacity for existing generation projects at the start year, if they were commissioned before the model start year
3079  vCap.fx(eg,sStartYear)$(pGenData(eg,"StYr") < sStartYear.val) = pGenData(eg,"Capacity");
3080   
3081  * Set fixed capacity for generation projects in years where they are within their operational period
3082  vCap.fx(eg,y)$((pGenData(eg,"StYr") <= y.val) and (pGenData(eg,"StYr") >= sStartYear.val)) = pGenData(eg,"Capacity");
3083   
3084  * Retire capacity by setting it to zero in the year of retirement
3085  vCap.fx(eg,y)$(pGenData(eg,"RetrYr") and (pGenData(eg,"RetrYr") <= y.val)) = 0;
3086   
3087  * Set the initial thermal capacity for CSP plants at the model start year, if commissioned before that year
3088  vCapTherm.fx(eg,sStartYear)$(pGenData(eg,"StYr") < sStartYear.val) = pCSPData(eg,"Thermal Field","CapacityMWh");
3089   
3090  * Set the initial storage capacity at the model start year, considering both CSP and standalone storage units
3091  vCapStor.fx(eg,sStartYear)$(pGenData(eg,"StYr") < sStartYear.val) = pCSPData(eg,"Storage","CapacityMWh") + pStorageData(eg,"CapacityMWh");
3092   
3093  * Prevent decommissioning of storage hours from existing storage when economic retirement is disabled
3094  vCapStor.fx(eg,y)$((pSettings("fEnableEconomicRetirement") = 0) and (pGenData(eg,"StYr") <= y.val) and (pGenData(eg,"RetrYr") >= y.val)) = pStorageData(eg,"CapacityMWh");
3095   
3096  * Fix the retirement variable to zero, meaning no unit is retired by default unless specified otherwise
3097  vRetire.fx(ng,y) = 0;
3098   
3099  * Ensure plants with a lifetime of 99 years (considered effectively infinite) are not retired
3100  vRetire.fx(eg,y)$(pGenData(eg,"Life") = 99) = 0;
3101   
3102  * Ensure capacity remains unchanged when economic retirement is disabled and the plant is still within its operational lifetime
3103  vCap.fx(eg,y)$((pSettings("fEnableEconomicRetirement") = 0 and pGenData(eg,"StYr") < y.val) and (pGenData(eg,"RetrYr") >= y.val)) = pGenData(eg,"Capacity");
3104   
3105  * Prevent thermal capacity from appearing in years before the commissioning date
3106  vCapTherm.fx(ng,y)$(pGenData(ng,"StYr") > y.val) = 0;
3107   
3108  * Prevent storage capacity from appearing in years before the commissioning date
3109  vCapStor.fx(ng,y)$(pGenData(ng,"StYr") > y.val) = 0;
3110   
3111  * Ensure storage capacity is set to zero if storage is not included in the scenario
3112  vCapStor.fx(ng,y)$(not fEnableStorage) = 0;
3113   
3114   
3115  ********************* Equations for hydrogen production**********************************************************
3116  *Maximum capacity is equal to "Capacity"
3117  vCapH2.up(hh,y) = pH2Data(hh,"Capacity");
3118   
3119  *No new capacity can be built for existing generators
3120  vBuildH2.fx(eh,y)$(pH2Data(eh,"StYr") <= sStartYear.val) = 0;
3121   
3122  *The new capacity for new generators can not exceed the annual limit
3123  vBuildH2.up(nh,y) = pH2Data(nh,"BuildLimitperYear")*pWeightYear(y);
3124   
3125  *Electrolyzers can not operate at days with zero demand (applicable to dispatch model)
3126  vH2PwrIn.fx(hh,q,d,t,y)$(sum(z,pDemandData(z,q,d,y,t))  =0)   =0;
3127   
3128  *The maximum power drawn for H2 production can't be more than the Capacity of the electrolyzer
3129  vH2PwrIn.up(hh,q,d,t,y)  =pH2Data(hh,"Capacity");
3130   
3131   
3132  vCapH2.fx(hh,y)$(pH2Data(hh,"StYr") > y.val)=0;
3133  vCapH2.fx(eh,sStartYear)$(pH2Data(eh,"StYr") < sStartYear.val) = pH2Data(eh,"Capacity");
3134  vCapH2.fx(eh,y)$((pH2Data(eh,"StYr") <= y.val) and (pH2Data(eh,"StYr") >= sStartYear.val)) = pH2Data(eh,"Capacity");
3135  vCapH2.fx(eh,y)$(pH2Data(eh,"RetrYr") and (pH2Data(eh,"RetrYr") <= y.val)) = 0;
3136   
3137  vRetireH2.fx(nh,y) = 0;
3138  vRetireH2.fx(eh,y)$(pH2Data(eh,"Life") = 99) = 0;
3139   
3140  vCapH2.fx(eh,y)$((pSettings("fEnableEconomicRetirement") = 0 and pH2Data(eh,"StYr") < y.val) and (pH2Data(eh,"RetrYr") >= y.val)) = pH2Data(eh,"Capacity");
3141   
3142  sH2PwrIn(hh,q,d,t,y) = yes;
3143   
3144  vREPwr2H2.fx(nRE,f,q,d,t,y)=0;
3145  vREPwr2Grid.fx(nRE,f,q,d,t,y)=0;
3146   
3147  *******************************************************************************************************************
3148   
3149  sPwrOut(gfmap(g,f),q,d,t,y) = yes;
3150  sPwrOut(gfmap(st,f),q,d,t,y)$(not fEnableStorage) = yes;
3151   
3152  * If price based export is not allowed, set to 0
3153  sExportPrice(z,zext,q,d,t,y)$(fEnableExternalExchange) = yes;
3154  sExportPrice(z,zext,q,d,t,y)$(not fEnableExternalExchange) = no;
3155   
3156  * If price based import is not allowed, set to 0
3157  sImportPrice(z,zext,q,d,t,y)$(fEnableExternalExchange) = yes;
3158  sImportPrice(z,zext,q,d,t,y)$(not fEnableExternalExchange) = no;
3159   
3160  vYearlyImportExternal.up(z,zext,q,d,t,y)$fEnableExternalExchange = pExtTransferLimitIn(z,zext,q,y);
3161  vYearlyExportExternal.up(z,zext,q,d,t,y)$fEnableExternalExchange = pExtTransferLimitOut(z,zext,q,y);
3162   
3163  * Do not allow imports and exports for a zone without import/export prices
3164  sExportPrice(z,zext,q,d,t,y)$(pTradePrice(zext,q,d,y,t)= 0) = no;
3165  sImportPrice(z,zext,q,d,t,y)$(pTradePrice(zext,q,d,y,t)= 0) = no;
3166   
3167  * Define the flow of electricity between zones
3168  sFlow(z,z2,q,d,t,y)$(sTopology(z,z2)) = yes;
3169   
3170  * Define spinning reserve constraints based on the settings for zonal and system spinning reserves
3171  sSpinningReserve(g,q,d,t,y)$((fApplyCountrySpinReserveConstraint or fApplySystemSpinReserveConstraint) ) = yes;
3172   
3173  *To avoid bugs when there is no candidate transmission expansion line
3174  pNewTransmission(z,z2,"EarliestEntry")$(not fAllowTransferExpansion) = 2500;
3175   
3176  *-------------------------------------------------------------------------------------
3177  * Ensure that variables fixed (`.fx`) at specific values remain unchanged during the solve process
3178  PA.HoldFixed=1;
3179   
3180  * Declare a file object `fmipopt` and set its name dynamically based on the modeltype
3181  file fmipopt / cplex.opt /;
3182  * Check if the set `mipopt` contains any elements (i.e., if modeltype options exist)
3183  if (card(mipopt),
3184   put fmipopt;
3185  * Loop over each entry in `mipopt` and write its text content to the file
3186   loop(mipline, put mipopt.te(mipline) /);
3187   putclose;
3188  );
3189   
3190  * Enable the modeltype to read an external modeltype option file
3191  PA.optfile = 1;
3192   
3193   
3194  * ############## SOLVE ##############
3195  * SOLVEMODE == 2 solves as usual
3196  * SOLVEMODE == 1 solves as usual but generates a savepoint file at the end
3197  * SOLVEMODE == 0 uses a savepoint file to skip the solve (This speeds up development of post solve features)
3198   
3201   
3202   
3204  *  Solve model as usual
3205     Solve PA using RMIP minimizing vNPVcost;
3206  *  Abort if model was not solved successfully
3207     abort$(not (PA.modelstat=1 or PA.modelstat=8)) 'ABORT: no feasible solution found.', PA.modelstat;
3209   
3210  *  Export model data only when debugging is enabled
3212  * ####################################
3213   
3214  * Include the external report file specified by `%REPORT_FILE%`
3215   
3218   
INCLUDE    /Data/EAPP/EPM/epm/generate_report.gms
3220  **********************************************************************
3221  * ELECTRICITY PLANNING MODEL (EPM)
3222  * Developed at the World Bank
3223  **********************************************************************
3224  * Description:
3225  * This GAMS-based model is designed for electricity system planning,
3226  * incorporating capacity expansion, generation dispatch, and policy
3227  * constraints such as renewable energy targets, emissions reductions,
3228  * and market mechanisms.
3229  *
3230  * Author(s): ESMAP Modelling Team
3231  * Organization: World Bank
3232  * Version:
3233  * License: Creative Commons Zero v1.0 Universal
3234  *
3235  * Key Features:
3236  * - Optimization of electricity generation and capacity planning
3237  * - Inclusion of renewable energy integration and storage technologies
3238  * - Multi-period, multi-region modeling framework
3239  * - CO2 emissions constraints and policy instruments
3240  *
3241  * Notes:
3242  * - Ensure GAMS is installed before running this model.
3243  * - The model requires input data in .GDX or Excel format.
3244  *
3245  * Contact:
3246  * Claire Nicolas, cnicolas@worldbank.org
3247  **********************************************************************
3248   
3249   
3251  * Report
3252   
3253  set sumhdr /
3254    "Investment costs: $m",
3255    "Fixed O&M: $m",
3256    "Variable O&M: $m",
3257    "Startup costs: $m",
3258    "Fuel costs: $m",
3259    "Transmission costs: $m",
3260    "Spinning reserve costs: $m",
3261    "Unmet demand costs: $m",
3262    "Unmet country spinning reserve costs: $m",
3263    "Unmet country planning reserve costs: $m",
3264    "Unmet country CO2 backstop cost: $m",
3265    "Unmet system planning reserve costs: $m",
3266    "Unmet system spinning reserve costs: $m",
3267    "Unmet system CO2 backstop cost: $m",
3268    "Excess generation: $m",
3269    "VRE curtailment: $m",
3270    "Import costs with external zones: $m",
3271    "Export revenues with external zones: $m",
3272    "Import costs with internal zones: $m",
3273    "Export revenues with internal zones: $m",
3274    "Trade shared benefits: $m",
3275    "Carbon costs: $m",
3276    "NPV of system cost: $m"
3277  /;
3278   
3279  * Set of demand-related summary labels
3280  set dshdr /
3281    "Demand: GWh",
3282    "Electricity demand for H2 production: GWh",
3283    "Total Demand (Including P to H2): GWh",
3284    "Total production: GWh",
3285    "Unmet demand: GWh",
3286    "Surplus generation: GWh",
3287    "Imports exchange: GWh",
3288    "Exports exchange: GWh",
3289    "Net interchange: GWh",
3290    "Net interchange Ratio: GWh"
3291  /;
3292   
