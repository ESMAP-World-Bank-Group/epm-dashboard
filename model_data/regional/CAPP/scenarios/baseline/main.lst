3496    pNetPresentCostPerMWh(z,sumhdr)  'Zone cost per discounted demand [USD/MWh]'
3497    pNetPresentCostCountryPerMWh(c,sumhdr) 'Country cost per discounted demand [USD/MWh]'
3498    pCostsPerMWh(z,sumhdr,y)         'Zone average cost by component [USD/MWh]'
3499    pCostsCountryPerMWh(c,sumhdr,y)  'Country average cost by component [USD/MWh]'
3500    pCostsSystemPerMWh(sumhdr, y)    'System average cost [USD/MWh] by year'
3501   
3502  * ============================================================
3503  * 11. modeltype PARAMETERS
3504  * ============================================================
3505     pSolverParameters(*)                      'modeltype parameters'
3506  ;
3507   
3508  * Mapping
3509   
3510  pGeneratorTechFuel(g, tech, f) = sum(z, gmap(g, z, tech, f));
3511  pGeneratorTechFuel(g, tech, f)$pGeneratorTechFuel(g, tech, f) = 1;
3512   
3513  pZoneCountry(z, c) = zcmap(z, c);
3514  pZoneCountry(z, c)$pZoneCountry(z, c) = 1;
3515   
3516   
3517  * ============================================================
3518  * 1. CAPACITY
3519  * ============================================================
3520   
3521  * ---------------------------------------------------------
3522  * Plant and technology-level capacity and utilization
3523  * ---------------------------------------------------------
3524  * Records installed capacity, retirements, and utilization
3525  * factors for each plant and aggregated by technology:
3526  *   - pCapacityPlant: installed capacity by plant
3527  *   - pRetirementsPlant: retired capacity by plant
3528   
3529  * ---------------------------------------------------------
3530   
3531  pCapacityPlant(zgmap(z,g),y)                 = vCap.l(g,y);
3532   
3533  pNewCapacityPlant(zgmap(z,g),y)              = vBuild.l(g,y);
3534   
3535  pRetirementsPlant(zgmap(z,g),y)                  = vRetire.l(g,y);
3536   
3537   
3538  * ---------------------------------------------------------
3539  * Capacity, new builds, retirements, and utilization by fuel and technology
3540  * ---------------------------------------------------------
3541  * Tracks installed capacity, new capacity, and retirements
3542  * disaggregated by fuel type and technology.
3543  * Also computes utilization factors:
3544  *   - pCapacityTechFuel / pCapacityFuel: installed capacity
3545  *   - pNewCapacityFuel / pNewCapacityTech: new builds
3546  *   - pRetirementsFuel: retirements
3547   
3548  * ---------------------------------------------------------
3549   
3550  * Installed capacity by technology and fuel [MW]
3551  pCapacityTechFuel(z, tech, f, y) =
3552    sum((gzmap(g, z), gtechmap(g, tech), gprimf(g, f)), vCap.l(g, y));
3553   
3554  * Installed capacity by fuel [MW]
3555  pCapacityFuel(z, f, y) =
3556    sum((gzmap(g, z), gprimf(g, f)), vCap.l(g, y));
3557   
3558  * New capacity by fuel [MW]
3559  pNewCapacityFuel(z, f, y) =
3560    sum((gzmap(g, z), gprimf(g, f)), vBuild.l(g, y));
3561   
3562  * New capacity by technology [MW]
3563  pNewCapacityTech(z, tech, y) =
3564    sum((gzmap(g, z), gtechmap(g, tech), gprimf(g, f)), vBuild.l(g, y));
3565   
3566  * New capacity by technology and fuel [MW]
3567  pNewCapacityTechFuel(z, tech, f, y) =
3568    sum((gzmap(g, z), gtechmap(g, tech), gprimf(g, f)), vBuild.l(g, y));
3569   
3570  * Retirements by fuel [MW]
3571  pRetirementsFuel(z, f, y) =
3572    sum((gzmap(g, z), gprimf(g, f)), vRetire.l(g, y));
3573   
3574  * ---------------------------------------------------------
3575  * Transmission capacity expansion and annual limits
3576  * ---------------------------------------------------------
3577  * pNewTransmissionCapacity:
3578  *   - Incremental transmission capacity built in year y
3579  *   - Based on yearly build decisions and per-line capacity
3580  *
3581  * pTransmissionCapacity:
3582  *   - Total available transfer capacity in a year
3583  *   - Equals existing maximum transfer limit plus any new additions
3584  * ---------------------------------------------------------
3585   
3586  pNewTransmissionCapacity(sTopology(z,z2),y) =
3587    vBuildTransmissionLine.l(z,z2,y)
3588    * max(pNewTransmission(z,z2,"CapacityPerLine"),pNewTransmission(z2,z,"CapacityPerLine"))
3589    * fAllowTransferExpansion;
3590   
3591  pAdditionalTransmissionCapacity(sTopology(z,z2),y) = vNewTransmissionLine.l(z,z2,y)*max(pNewTransmission(z,z2,"CapacityPerLine"),pNewTransmission(z2,z,"CapacityPerLine"))*fAllowTransferExpansion;
3592  pTransmissionCapacity(sTopology(z,z2),y) = pAdditionalTransmissionCapacity(z,z2,y) + smax(q, pTransferLimit(z,z2,q,y)) ;
3593   
3594  * ---------------------------------------------------------
3595  * Country-level capacity, new builds, retirements, and utilization
3596  * ---------------------------------------------------------
3597  * Aggregates zonal results to the country level:
3598  *   - pCapacityPlantCountry: installed capacity by plant
3599  *   - pCapacityTechFuelCountry / pCapacityFuelCountry: installed capacity by tech-fuel or fuel
3600  *   - pNewCapacityFuelCountry / pNewCapacityTechCountry: new builds by fuel or tech
3601  *   - pRetirementsFuelCountry / pRetirementsCountry: retirements by fuel and total
3602  *   - pUtilizationFuelCountry / pUtilizationTechFuelCountry:
3603  *       utilization factors (energy ÷ capacity × hours) by fuel or tech-fuel
3604  * ---------------------------------------------------------
3605   
3606  pCapacityTechFuelCountry(c, tech, f, y) =
3607    sum(zcmap(z, c), pCapacityTechFuel(z, tech, f, y));
3608   
3609  pCapacityFuelCountry(c, f, y) =
3610    sum(zcmap(z, c), pCapacityFuel(z, f, y));
3611   
3612  pNewCapacityFuelCountry(c, f, y) =
3613    sum(zcmap(z, c), pNewCapacityFuel(z, f, y));
3614   
3615  pNewCapacityTechCountry(c, tech, y) =
3616    sum(zcmap(z, c), pNewCapacityTech(z, tech, y));
3617   
3618  pNewCapacityTechFuelCountry(c, tech, f, y) =
3619    sum(zcmap(z, c), pNewCapacityTechFuel(z, tech, f, y));
3620   
3621  pRetirementsFuelCountry(c, f, y) =
3622    sum(zcmap(z, c), pRetirementsFuel(z, f, y));
3623   
3624  pRetirementsCountry(c, y) =
3625    sum((zcmap(z, c), f), pRetirementsFuel(z, f, y));
3626   
3627  * ---------------------------------------------------------
3628  * Capacity summary at zone and country level [MW]
3629  * ---------------------------------------------------------
3630  * Provides aggregated indicators of system capacity:
3631  *   - Available capacity
3632  *   - Peak demand (with and without power-to-hydrogen load)
3633  *   - New capacity builds
3634  *   - Retired capacity
3635  *   - Committed total transmission capacity
3636  * Reported at both zonal and country aggregation levels.
3637  * ---------------------------------------------------------
3638   
3639  pCapacitySummary(z,"Available capacity: MW",y) = sum(gzmap(g,z), vCap.l(g,y));
3640  pCapacitySummary(z,"Peak demand: MW"       ,y) = smax((q,d,t), pDemandData(z,q,d,y,t)*pEnergyEfficiencyFactor(z,y));
3641  pCapacitySummary(z,"Peak demand including P to H2: MW"       ,y) = smax((h2zmap(hh,z),q,d,t), pDemandData(z,q,d,y,t)*pEnergyEfficiencyFactor(z,y) + vH2PwrIn.l(hh,q,d,t,y))$fEnableH2Production+1e-6;
3642  pCapacitySummary(z,"New capacity: MW"      ,y) = sum(gzmap(g,z), vBuild.l(g,y));
3643  pCapacitySummary(z,"Retired capacity: MW"  ,y) = sum(gzmap(g,z), vRetire.l(g,y));
3644  pCapacitySummary(z,"Committed Total TX capacity: MW"  ,y) = sum((z2,q), pTransferLimit(z,z2,q,y)/card(q));
3645   
3646  pCapacitySummaryCountry(c,"Available capacity: MW",y) = sum(zcmap(z,c), pCapacitySummary(z,"Available capacity: MW",y));
3647  pCapacitySummaryCountry(c,"Peak demand: MW"       ,y) = smax((q,d,t), sum(zcmap(z,c), pDemandData(z,q,d,y,t)*pEnergyEfficiencyFactor(z,y)));
3648  pCapacitySummaryCountry(c,"New capacity: MW"      ,y) = sum(zcmap(z,c), pCapacitySummary(z,"New capacity: MW",y));
3649  pCapacitySummaryCountry(c,"Retired capacity: MW"  ,y) = sum(zcmap(z,c), pCapacitySummary(z,"Retired capacity: MW",y));
3650  pCapacitySummaryCountry(c,"Committed Total TX capacity: MW",y) = sum(zcmap(z,c), pCapacitySummary(z,"Committed Total TX capacity: MW",y));
3651   
3652  * H2 model additions
3653  pCapacityPlantH2(zh2map(z,hh),y) = vCapH2.l(hh,y)$fEnableH2Production+1e-6;
3654   
3655  * ============================================================
3656  * 2. COSTS
3657  * ============================================================
3658   
3659  * Reporting costs by plant
3660  * Plant-level cost reporting (prettier formatting)
3661  pCostsPlant(z, g, "Investment costs: $m", y)$gzmap(g, z) =
3662    vAnnGenCapex.l(g, y) / 1e6;
3663   
3664  pCostsPlant(z, g, "Fixed O&M: $m", y)$gzmap(g, z) =
3665    (
3666      vCap.l(g, y)      * pGenData(g, "FOMperMW")
3667      + vCapStor.l(g, y)  * pStorageData(g, "FixedOMMWh")
3668      + vCapStor.l(g, y)  * pCSPData(g, "Storage", "FixedOMMWh")
3669      + vCapTherm.l(g, y) * pCSPData(g, "Thermal field", "FixedOMMWh")
3670    ) / 1e6;
3671   
3672  pCostsPlant(z, g, "Variable Cost: $m", y)$gzmap(g, z) =
3673    sum((gfmap(g, f), q, d, t),
3674      pVarCost(g, f, y) * vPwrOut.l(g, f, q, d, t, y) * pHours(q, d, t)
3675    ) / 1e6;
3676   
3677  pCostsPlant(z, g, "Spinning Reserve Cost: $m", y)$gzmap(g, z) =
3678    sum((q, d, t),
3679      vSpinningReserve.l(g, q, d, t, y) * pGenData(g, "ReserveCost") * pHours(q, d, t)
3680    ) / 1e6;
3681   
3682  * ---------------------------------------------------------
3683  * Plant-level CAPEX investment breakdown [USD]
3684  * ---------------------------------------------------------
3685  * Stores the non-Investment costs flows for each plant and
3686  * component so that we can add dedicated transmission and
3687  * hydrogen entries later on.
3688  * ---------------------------------------------------------
3689   
3690  pCapexInvestmentPlant(zgmap(z,g), "Generation", y)$((not st(g))) =
3691    1e6 * vBuild.l(g, y) * pGenData(g, "Capex") * pCapexTrajectories(g, y);
3692   
3693  pCapexInvestmentPlant(zgmap(z,g), "StorageEnergy", y)$((st(g)) and (not cs(g))) =
3694    1e3 * vBuildStor.l(g, y) * pStorageData(g, "CapexMWh") * pCapexTrajectories(g, y) +
3695    1e6 * vBuild.l(g, y) * pGenData(g, "Capex") * pCapexTrajectories(g, y);
3696   
3697  pCapexInvestmentPlant(zgmap(z,g), "CSPThermalField", y)$cs(g) =
3698    1e3 * vBuildTherm.l(g, y) * pCSPData(g, "Thermal Field", "CapexMWh") * 1e3 * pCapexTrajectories(g, y);
3699   
3700  pCapexInvestmentPlant(zgmap(z,g), "CSPStorage", y)$cs(g) =
3701    1e3 * vBuildStor.l(g, y) * pCSPData(g, "Storage", "CapexMWh") * pCapexTrajectories(g, y);
3702   
3703  * Derive zonal totals per component (generation-related ones come from plants)
3704  pCapexInvestmentComponent(z, capexComponentPlant, y) =
3705    sum(zgmap(z, g), pCapexInvestmentPlant(z, g, capexComponentPlant, y));
3706   
3707  * Hydrogen CAPEX is tracked separately
3708  pCapexInvestmentComponent(z, "Hydrogen", y)$fEnableH2Production =
3709    1e6 * sum(zH2map(z, hh),
3710      vBuildH2.l(hh, y) * pH2Data(hh, "Capex") * pCapexTrajectoriesH2(hh, y)
3711    );
3712   
3713  * Transmission CAPEX additions
3714  pCapexInvestmentComponent(z, "Transmission", y)$(fAllowTransferExpansion and sum(sTopology(z, z2), 1)) =
3715    0.5 * sum(sTopology(z, z2),
3716      vBuildTransmissionLine.l(z, z2, y)
3717      * max(pNewTransmission(z,z2,"CostPerLine"),pNewTransmission(z2,z,"CostPerLine"))
3718      * 1e6
3719    );
3720   
3721  pCapexInvestmentTransmission(sTopology(z, z2), y)$fAllowTransferExpansion =
3722    0.5 * vBuildTransmissionLine.l(z, z2, y)
3723    * max(pNewTransmission(z,z2,"CostPerLine"),pNewTransmission(z2,z,"CostPerLine"))
3724    * 1e6;
3725   
3726  * ---------------------------------------------------------
3727  * Zone-level CAPEX investment flows [$]
3728  * ---------------------------------------------------------
3729  * Captures the annual capital expenditures for new builds
3730  * in zone z and year y, before annualization.
3731  *
3732  * Components:
3733  *   - Generation builds (MW × $/MW × cost trajectory)
3734  *   - Storage builds (MWh × $/MWh × cost trajectory)
3735  *   - CSP thermal field and storage builds (MWh × $/MWh × trajectory)
3736  *   - Hydrogen builds (MW × $/MW × cost trajectory), optional
3737  *   - Small epsilon added to avoid divide-by-zero issues
3738  * ---------------------------------------------------------
3739   
3740  pCapexInvestment(z, y) =
3741    sum(capexComponent, pCapexInvestmentComponent(z, capexComponent, y))
3742    + 1e-6;
3743   
3744   
3745  * ---------------------------------------------------------
3746  * Price calculation [$/MWh]
3747  * ---------------------------------------------------------
3748  * Market clearing price derived from the dual variable of the
3749  * demand-supply balance constraint, scaled by operating hours,
3750  * discount rate (pRR), and year weight.
3751  * --------------------------------------------------------
3752   
3753  pHourlyPrice(z,q,d,t,y)$(pHours(q,d,t)) = -eDemSupply.m(z,q,d,t,y)/pHours(q,d,t)/pRR(y)/pWeightYear(y);
3754   
3755  * ---------------------------------------------------------
3756  * Import and export costs with internal zones [$]
3757  * ---------------------------------------------------------
3758  * Import costs:
3759  *   - Value of inflows from neighboring zones
3760  *   - Calculated as local price × imported flow × hours
3761  *
3762  * Export revenues:
3763  *   - Value of outflows to neighboring zones
3764  *   - Negative sign ensures revenues reduce total cost
3765  * ---------------------------------------------------------
3766   
3767  pImportCostsInternal(z,y) = sum((sTopology(Zd,z),q,d,t), pHourlyPrice(z,q,d,t,y)*vFlow.l(Zd,z,q,d,t,y)*pHours(q,d,t));
3768   
3769  pExportRevenuesInternal(z,y) = - sum((sTopology(z,Zd),q,d,t), pHourlyPrice(z,q,d,t,y)*vFlow.l(z,Zd,q,d,t,y)*pHours(q,d,t));
3770   
3771  * ---------------------------------------------------------
3772  * Congestion rents between zones [$]
3773  * ---------------------------------------------------------
3774  * Difference in marginal prices × traded flow × hours
3775  * Negative sign ensures consistency with rent allocation
3776  * ---------------------------------------------------------
3777   
3778  pCongestionRevenues(z,Zd,y) = - sum((q,d,t), (pHourlyPrice(zD,q,d,t,y) - pHourlyPrice(z,q,d,t,y))*vFlow.l(z,Zd,q,d,t,y)*pHours(q,d,t));
3779   
3780  * ---------------------------------------------------------
3781  * Trade shared benefits [$]
3782  * ---------------------------------------------------------
3783  * Congestion rents are split equally (50/50) between
3784  * importing and exporting zones as the allocation rule
3785  * ---------------------------------------------------------
3786   
3787  pTradeSharedBenefits(z,y) = 0.5*sum(sTopology(Zd,z), pCongestionRevenues(Zd,z,y)) + 0.5*sum(sTopology(z,Zd), pCongestionRevenues(z,Zd,y));
3788   
3789  * ---------------------------------------------------------
3790  * Net trade costs with internal zones [$]
3791  * ---------------------------------------------------------
3792  * Equivalent formulation where:
3793  *   Trade cost = Import cost + Export revenues + Shared rents
3794  * This matches pricing trades at the average marginal price
3795  * between connected zones
3796  * ---------------------------------------------------------
3797   
3798  * pTradeCostsInternal(z,y) = pExportRevenuesInternal(z,y) + pImportCostsInternal(z,y) + pTradeSharedBenefits(z,y);
3799   
3800  * ---------------------------------------------------------
3801  * Demand allocation [GWh → TWh]
3802  * ---------------------------------------------------------
3803  * Zone-level demand:
3804  *   - Sum of hourly demand × operating hours
3805  *   - Adjusted by efficiency factor
3806  *   - Converted from GWh to TWh
3807  *
3808  * Country-level demand:
3809  *   - Aggregation of zonal demand by mapping zones to countries
3810  * ---------------------------------------------------------
3811  Parameter
3812    pDemandEnergyZone(z,y)         'Total energy demand [GWh] by zone and year'
3813    pDemandEnergyCountry(c,y)      'Total energy demand [GWh] by country and year'
3814    pDemandEnergySystem(y)         'Total system energy demand [GWh] by year'
3815    pDemandPeakZone(z,y)           'Peak demand [MW] by zone and year'
3816    pDemandPeakCountry(c,y)        'Peak demand [MW] by country and year'
3817    pDemandPeakSystem(y)           'Peak demand [MW] by year'
3818  ;
3819   
3820  pDemandEnergyZone(z,y) = sum((q,d,t), pDemandData(z,q,d,y,t) * pHours(q,d,t) * pEnergyEfficiencyFactor(z,y)) / 1e3;
3821  pDemandEnergyCountry(c,y) = sum(zcmap(z,c), pDemandEnergyZone(z,y));
3822  pDemandEnergySystem(y) = sum(z, pDemandEnergyZone(z,y));
3823   
3824  pDemandPeakZone(z,y) = smax((q,d,t), pDemandData(z,q,d,y,t) * pEnergyEfficiencyFactor(z,y));
3825  pDemandPeakCountry(c,y) = smax((q,d,t), sum(zcmap(z,c), pDemandData(z,q,d,y,t) * pEnergyEfficiencyFactor(z,y)));
3826  pDemandPeakSystem(y) = smax((q,d,t), sum(z, pDemandData(z,q,d,y,t) * pEnergyEfficiencyFactor(z,y)));
3827   
3828  * ---------------------------------------------------------
3829  * Zone-level cost components [$m]
3830  * ---------------------------------------------------------
3831  * Each entry in pCosts stores one annual cost component
3832  * at the zonal level in million $.
3833  *
3834  * Categories included:
3835  *   - Investment costs
3836  *   - Fixed O&M
3837  *   - Variable O&M
3838  *   - Fuel costs
3839  *   - Transmission costs
3840  *   - Spinning reserve costs
3841  *   - Unmet demand, reserve, and CO2 backstop costs
3842  *       (allocated proportionally to zonal demand at country/system level)
3843  *   - Excess generation
3844  *   - VRE curtailment
3845  *   - Import/export costs (external and internal zones)
3846  *   - Trade shared benefits
3847  *   - Carbon costs (system-wide total)
3848  * ---------------------------------------------------------
3849   
3850  * Investment-related costs
3851  pCosts(z, "Investment costs: $m", y) =
3852    vAnnCapex.l(z, y) / 1e6;
3853   
3854  pCosts(z, "Transmission costs: $m", y) =
3855    vAnnualizedTransmissionCapex.l(z, y) / 1e6;
3856   
3857  * Operation-related costs
3858  pCosts(z, "Fixed O&M: $m", y) =
3859    vYearlyFOMCost.l(z, y) / 1e6;
3860   
3861  pCosts(z, "Variable O&M: $m", y) =
3862    vYearlyVOMCost.l(z, y) / 1e6;
3863   
3864  pCosts(z, "Startup costs: $m", y) =
3865    vYearlyStartupCost.l(z, y) / 1e6;
3866   
3867  pCosts(z, "Fuel costs: $m", y) =
3868    vYearlyFuelCost.l(z, y) / 1e6;
3869   
3870  * System balancing costs
3871  pCosts(z, "Unmet demand costs: $m", y) =
3872    vYearlyUSECost.l(z, y) / 1e6;
3873   
3874  pCosts(z, "Excess generation: $m", y) =
3875    vYearlySurplus.l(z, y) / 1e6;
3876   
3877  pCosts(z, "VRE curtailment: $m", y) =
3878    vYearlyCurtailmentCost.l(z, y) / 1e6;
3879   
3880  * Reserve-related costs
3881  pCosts(z, "Spinning reserve costs: $m", y) =
3882    vYearlySpinningReserveCost.l(z, y) / 1e6;
3883   
3884  pCosts(z, "Unmet country spinning reserve costs: $m", y) =
3885    sum(c$(zcmap(z, c) and pDemandEnergyCountry(c, y) > 0),
3886      vYearlyUnmetSpinningReserveCostCountry.l(c, y) * (pDemandEnergyZone(z, y) / pDemandEnergyCountry(c, y))
3887    ) / 1e6;
3888   
3889  pCosts(z, "Unmet country planning reserve costs: $m", y) =
3890    sum(c$(zcmap(z, c) and pDemandEnergyCountry(c, y) > 0),
3891      vYearlyUnmetPlanningReserveCostCountry.l(c, y) * (pDemandEnergyZone(z, y) / pDemandEnergyCountry(c, y))
3892    ) / 1e6;
3893   
3894  pCosts(z, "Unmet system planning reserve costs: $m", y) =
3895    vYearlyUnmetPlanningReserveCostSystem.l(y) * (pDemandEnergyZone(z, y) / pDemandEnergySystem(y)) / 1e6;
3896   
3897  pCosts(z, "Unmet system spinning reserve costs: $m", y) =
3898    vYearlyUnmetSpinningReserveCostSystem.l(y) * (pDemandEnergyZone(z, y) / pDemandEnergySystem(y)) / 1e6;
3899   
3900  * Carbon-related costs
3901  pCosts(z, "Carbon costs: $m", y) =
3902    vYearlyCarbonCost.l(z, y) / 1e6;
3903   
3904  pCosts(z, "Unmet country CO2 backstop cost: $m", y) =
3905    sum(c$(zcmap(z, c) and pDemandEnergyCountry(c, y) > 0),
3906      vYearlyCO2BackstopCostCountry.l(c, y) * (pDemandEnergyZone(z, y) / pDemandEnergyCountry(c, y))
3907    ) / 1e6;
3908   
3909  pCosts(z, "Unmet system CO2 backstop cost: $m", y) =
3910    vYearlyCO2BackstopCostSystem.l(y) * (pDemandEnergyZone(z, y) / pDemandEnergySystem(y)) / 1e6;
3911   
3912  * Trade-related costs
3913  pCosts(z, "Import costs with internal zones: $m", y) =
3914    pImportCostsInternal(z, y) / 1e6;
3915   
3916  pCosts(z, "Export revenues with internal zones: $m", y) =
3917    pExportRevenuesInternal(z, y) / 1e6;
3918   
3919  pCosts(z, "Trade shared benefits: $m", y) =
3920    pTradeSharedBenefits(z, y) / 1e6;
3921   
3922  pCosts(z, "Import costs with external zones: $m", y) =
3923    vYearlyImportExternalCost.l(z, y) / 1e6;
3924   
3925  pCosts(z, "Export revenues with external zones: $m", y) =
3926    vYearlyExportExternalCost.l(z, y) / 1e6;
3927   
3928  * Discounted weighted yearly costs by zone
3929  pDiscountedWeightedCosts(z, sumhdr, y) =
3930      pCosts(z, sumhdr, y) * pRR(y) * pWeightYear(y);
3931   
3932  * Cost
3933  pNetPresentCost(z, sumhdr) =
3934      sum(y, pDiscountedWeightedCosts(z, sumhdr, y));
3935   
3936  * ---------------------------------------------------------
3937   
3938  * Cost by country and year
3939  pCostsCountry(c,sumhdr,y) = sum(z$(zcmap(z,c)), pCosts(z,sumhdr,y));
3940   
3941  * ---------------------------------------------------------
3942  * System-level cost summary
3943  * ---------------------------------------------------------
3944  * Aggregates all zone-level costs into a single system-wide
3945  * metric across the entire time horizon.
3946  *
3947  * - pNetPresentCostSystem(sumhdr):
3948  *     Weighted sum of all zone-level costs
3949  *     Units: million $ (after scaling)
3950  *
3951  * - "NPV of system cost: $m":
3952  *     The model's computed Net Present Value of system costs
3953  *     Directly taken from optimization variable vNPVCost
3954  * ---------------------------------------------------------
3955   
3956  pCostsSystem(sumhdr, y) = sum(z, pCosts(z, sumhdr, y));
3957   
3958  * pNetPresentCostSystem(sumhdr) = sum((y,z), pCosts(z,sumhdr,y) * pRR(y) * pWeightYear(y));
3959  pNetPresentCostSystem(sumhdr) = sum(z, pNetPresentCost(z,sumhdr));
3960   
3961  pNetPresentCostSystem("NPV of system cost: $m") = vNPVCost.l/1e6;
3962   
3963  * ---------------------------------------------------------
3964   
3965  * Annual average cost benchmarks ($/MWh) without discounting:
3966  * divide yearly costs by the matching energy basis.
3967  pCostsPerMWh(z,sumhdr,y) =
3968      pCosts(z,sumhdr,y)*1e6 / (pDemandEnergyZone(z,y) * 1e3);
3969   
3970  pCostsCountryPerMWh(c,sumhdr,y) =
3971      1e6 * pCostsCountry(c,sumhdr,y) / (pDemandEnergyCountry(c,y) * 1e3);
3972   
3973  pCostsSystemPerMWh(sumhdr,y) =
3974      1e6 * pCostsSystem(sumhdr, y) / (pDemandEnergySystem(y) * 1e3);
3975   
3976  * Discount zonal demand over the horizon; convert GWh -> MWh via 1e3
3977  * and apply both the discount rate (pRR) and scenario weight (pWeightYear).
3978  pDiscountedDemandZoneMWh(z) =
3979      sum(y, pDemandEnergyZone(z,y) * 1e3 * pRR(y) * pWeightYear(y));
3980   
3981  pDiscountedDemandCountryMWh(c) =
3982      sum(zcmap(z,c), pDiscountedDemandZoneMWh(z));
3983   
3984  pDiscountedDemandSystemMWh =
3985      sum(z, pDiscountedDemandZoneMWh(z));
3986   
3987  * Divide the discounted cost ledger by discounted demand to express
3988  * each zonal cost component as an average $/MWh metric.
3989  pNetPresentCostPerMWh(z,sumhdr)$pDiscountedDemandZoneMWh(z) =
3990      pNetPresentCost(z,sumhdr) * 1e6 / pDiscountedDemandZoneMWh(z);
3991   
3992  * Country totals reuse the zonal discounted costs and demands,
3993  * aggregating before taking the ratio so shared demand weights apply.
3994  pNetPresentCostCountryPerMWh(c,sumhdr)$pDiscountedDemandCountryMWh(c) =
3995      1e6 * sum(zcmap(z,c), pNetPresentCost(z,sumhdr)) / pDiscountedDemandCountryMWh(c);
3996   
3997  * System-wide average cost: sum of discounted zonal costs divided by
3998  * the discounted system demand (sum of zonal denominators).
3999  pNetPresentCostSystemPerMWh(sumhdr)$pDiscountedDemandSystemMWh =
4000      (pNetPresentCostSystem(sumhdr) * 1e6) / pDiscountedDemandSystemMWh;
4001   
4002  * ---------------------------------------------------------
4003  * Fuel costs and consumption [$m, PJ] by zone and country
4004  * ---------------------------------------------------------
4005  * Calculates annual fuel expenditures and consumption
4006  * based on generation output, heat rates, and fuel prices.
4007  * Results are stored at both zonal and country aggregation levels.
4008  * ---------------------------------------------------------
4009   
4010  pFuelCosts(z,f,y) = sum((gzmap(g,z),gfmap(g,f),zcmap(z,c),q,d,t), vPwrOut.l(g,f,q,d,t,y)*pHours(q,d,t)*pFuelPrice(c,f,y)*pHeatRate(g,f))/1e6;
4011  pFuelConsumption(z,f,y) = vFuel.l(z,f,y)/1e6;
4012   
4013  pFuelCostsCountry(c,f,y) = sum(zcmap(z,c), pFuelCosts(z,f,y));
4014  pFuelConsumptionCountry(c,f,y) = sum(zcmap(z,c), pFuelConsumption(z,f,y));
4015   
4016  * ============================================================
4017  * 3. ENERGY BALANCE
4018  * ============================================================
4019   
4020  * ---------------------------------------------------------
4021  * Energy generation by plant, technology-fuel, and country
4022  * ---------------------------------------------------------
4023  * Calculates annual electricity generation (TWh) from model
4024  * outputs at different aggregation levels:
4025  *   - pEnergyPlant: plant-level generation
4026  *   - pEnergyTechFuel / pEnergyTechFuelCountry: by technology and fuel, zonal and country
4027  *   - pEnergyTechFuelComplete: tech-fuel generation plus balance components
4028  *   - pEnergyFuel / pEnergyFuelCountry: by fuel, zonal and country
4029  * ---------------------------------------------------------
4030   
4031  pEnergyPlant(zgmap(z,g),y) = sum((gfmap(g,f),q,d,t), vPwrOut.l(g,f,q,d,t,y)*pHours(q,d,t))/1e3;
4032  pEnergyFuel(z,f,y) = sum((gzmap(g,z),gfmap(g,f),q,d,t), vPwrOut.l(g,f,q,d,t,y)*pHours(q,d,t))/1e3;
4033  pEnergyFuelCountry(c,f,y) = sum(zcmap(z,c), pEnergyFuel(z,f,y));
4034   
4035  * Energy balance including demand slack, surplus, and exchanges
4036  pEnergyFuelComplete(z,f,y) = pEnergyFuel(z,f,y);
4037  pEnergyFuelComplete(z,"UnmetDemand",y) = sum((q,d,t), vUSE.l(z,q,d,t,y)*pHours(q,d,t))/1e3;
4038  pEnergyFuelComplete(z,"Surplus",y) = sum((q,d,t), vSurplus.l(z,q,d,t,y)*pHours(q,d,t))/1e3;
4039  pEnergyFuelComplete(z,"Imports",y) = sum((sTopology(Zd,z),q,d,t), vFlow.l(Zd,z,q,d,t,y)*pHours(q,d,t))/1e3;
4040  pEnergyFuelComplete(z,"Imports External",y) = sum((zext,q,d,t), vYearlyImportExternal.l(z,zext,q,d,t,y)*pHours(q,d,t))/1e3;
4041  pEnergyFuelComplete(z,"Exports",y) = -sum((sTopology(z,Zd),q,d,t), vFlow.l(z,Zd,q,d,t,y)*pHours(q,d,t))/1e3;
4042  pEnergyFuelComplete(z,"Exports External",y) = -sum((zext,q,d,t), vYearlyExportExternal.l(z,zext,q,d,t,y)*pHours(q,d,t))/1e3;
4043   
4044  pEnergyTechFuel(z,tech,f,y) = sum((gzmap(g,z),gtechmap(g,tech),gfmap(g,f),q,d,t), vPwrOut.l(g,f,q,d,t,y)*pHours(q,d,t))/1e3;
4045  pEnergyTechFuelCountry(c,tech,f,y) = sum(zcmap(z,c), pEnergyTechFuel(z,tech,f,y));
4046  * Copy slack components under synthetic technology "EnergyBalance"
4047  pEnergyTechFuelComplete(z,tech,f,y) = pEnergyTechFuel(z,tech,f,y);
4048  pEnergyTechFuelComplete(z,"EnergyBalance",fEnergyBalance,y) = pEnergyFuelComplete(z,fEnergyBalance,y);
4049   
4050   
4051  * ---------------------------------------------------------
4052  * Utilization factors by plant, technology, fuel, and country
4053  * ---------------------------------------------------------
4054  * Computes average utilization (capacity factor) as the ratio
4055  * of generated energy to available capacity and hours:
4056  *   - pUtilizationPlant / pUtilizationTech: plant-level
4057  *     and tech-level capacity factors
4058  *   - pUtilizationFuel / pUtilizationTechFuel: by fuel and tech-fuel at zone level
4059  *   - pUtilizationFuelCountry / pUtilizationTechFuelCountry:
4060  *     by fuel and tech-fuel at country level
4061  * ---------------------------------------------------------
4062   
4063   
4064  * Plant-level utilization (capacity factor, annual average)
4065  pUtilizationPlant(zgmap(z,g),y)$vCap.l(g,y) =
4066    sum((gfmap(g,f), q, d, t), vPwrOut.l(g,f,q,d,t,y) * pHours(q,d,t))
4067    / vCap.l(g,y) / 8760;
4068   
4069  * Technology-level utilization (capacity factor, annual average)
4070  pUtilizationTech(z, tech, y)$sum((zgmap(z,g), gfmap(g,f), gtechmap(g,tech))$vCap.l(g,y), vCap.l(g,y)) =
4071    sum((zgmap(z,g), gfmap(g,f), gtechmap(g,tech), q, d, t)$vCap.l(g,y),
4072      vPwrOut.l(g,f,q,d,t,y) * pHours(q,d,t))
4073    / sum((zgmap(z,g), gfmap(g,f), gtechmap(g,tech))$vCap.l(g,y), vCap.l(g,y))
4074    / 8760;
4075   
4076  * Fuel-level utilization (capacity factor, annual average)
4077  pUtilizationFuel(z, f, y)$(pCapacityFuel(z, f, y)) =
4078    pEnergyFuel(z, f, y)
4079    / (pCapacityFuel(z, f, y) * sum((q, d, t), pHours(q, d, t)))
4080    * 1000;
4081   
4082  * Technology-fuel-level utilization (capacity factor, annual average)
4083  pUtilizationTechFuel(z, tech, f, y)$(pCapacityTechFuel(z, tech, f, y)) =
4084    pEnergyTechFuel(z, tech, f, y)
4085    / (pCapacityTechFuel(z, tech, f, y) * sum((q, d, t), pHours(q, d, t)))
4086    * 1000;
4087   
4088  * Country-level fuel utilization (capacity factor, annual average)
4089  pUtilizationFuelCountry(c, f, y)$(pCapacityFuelCountry(c, f, y)) =
4090    pEnergyFuelCountry(c, f, y)
4091    / (pCapacityFuelCountry(c, f, y) * sum((q, d, t), pHours(q, d, t)))
4092    * 1000;
4093   
4094  * Country-level technology-fuel utilization (capacity factor, annual average)
4095  pUtilizationTechFuelCountry(c, tech, f, y)$(pCapacityTechFuelCountry(c, tech, f, y)) =
4096    pEnergyTechFuelCountry(c, tech, f, y)
4097    / (pCapacityTechFuelCountry(c, tech, f, y) * sum((q, d, t), pHours(q, d, t)))
4098    * 1000;
4099   
4100   
4101  * ---------------------------------------------------------
4102  * Energy balance [GWh] by zone and country
4103  * ---------------------------------------------------------
4104  * Accounts for demand (electricity and H2), production,
4105  * unmet demand, surplus generation, imports/exports,
4106  * and net interchange, with aggregation to country level.
4107  * ---------------------------------------------------------
4108   
4109  pEnergyBalance(z, "Demand: GWh", y) =
4110    sum((q, d, t), pDemandData(z, q, d, y, t) * pHours(q, d, t) * pEnergyEfficiencyFactor(z, y)) / 1e3;
4111   
4112  pEnergyBalance(z, "Demand H2: GWh", y) =
4113    (sum((h2zmap(hh, z), q, d, t), vH2PwrIn.l(hh, q, d, t, y) * pHours(q, d, t)) / 1e3) $ (fEnableH2Production + 1e-6);
4114   
4115  pEnergyBalance(z, "Total Demand: GWh", y) =
4116    pEnergyBalance(z, "Demand: GWh", y) + pEnergyBalance(z, "Demand H2: GWh", y);
4117   
4118  pEnergyBalance(z, "Total production: GWh", y) =
4119    sum(gzmap(g, z), pEnergyPlant(z, g, y));
4120   
4121  pEnergyBalance(z, "Unmet demand: GWh", y) =
4122    sum((q, d, t), vUSE.l(z, q, d, t, y) * pHours(q, d, t)) / 1e3;
4123   
4124  pEnergyBalance(z, "Surplus generation: GWh", y) =
4125    sum((q, d, t), vSurplus.l(z, q, d, t, y) * pHours(q, d, t)) / 1e3;
4126   
4127  pEnergyBalance(z, "Imports exchange: GWh", y) =
4128    (sum((sTopology(z, z2), q, d, t), vFlow.l(z2, z, q, d, t, y) * pHours(q, d, t))
4129     + sum((zext, q, d, t), vYearlyImportExternal.l(z, zext, q, d, t, y) * pHours(q, d, t))) / 1e3;
4130   
4131  pEnergyBalance(z, "Exports exchange: GWh", y) =
4132    (sum((sTopology(z, z2), q, d, t), vFlow.l(z, z2, q, d, t, y) * pHours(q, d, t))
4133     + sum((zext, q, d, t), vYearlyExportExternal.l(z, zext, q, d, t, y) * pHours(q, d, t))) / 1e3;
4134   
4135  pEnergyBalance(z, "Net interchange: GWh", y) =
4136    pEnergyBalance(z, "Imports exchange: GWh", y) - pEnergyBalance(z, "Exports exchange: GWh", y);
4137   
4138  pEnergyBalance(z, "Net interchange Ratio: GWh", y) $ pEnergyBalance(z, "Demand: GWh", y) =
4139    pEnergyBalance(z, "Net interchange: GWh", y) / pEnergyBalance(z, "Demand: GWh", y);
4140   
4141  pEnergyBalanceCountry(c,dshdr,y) = sum(z$(zcmap(z,c)), pEnergyBalance(z,dshdr,y));
4142   
4143   
4144  *--- H2 Demand-Supply Balance
4145  pEnergyBalanceH2(z,"Demand H2: GWh",y)   =(sum( (h2zmap(hh,z), q,d,t), vH2PwrIn.l(hh,q,d,t,y)*pHours(q,d,t))/1000)$fEnableH2Production+1e-6;
4146  pEnergyBalanceH2(z,"Production H2: mmBTU",           y)        =sum( (h2zmap(hh,z), q,d,t), vH2PwrIn.l(hh,q,d,t,y)*pHours(q,d,t)*pH2Data(hh,"HeatRate"))$fEnableH2Production+1e-6;
4147  pEnergyBalanceH2(z,"External Demand H2: mmBTU",         y)        =sum(q,pExternalH2(z,q,y)       )$fEnableH2Production+1e-6;
4148  pEnergyBalanceH2(z,"Unmet External Demand H2: mmBTU",   y)        =sum(q,vUnmetExternalH2.l(z,q,y))$fEnableH2Production+1e-6;
4149  pEnergyBalanceH2(z,"H2 Power: mmBTU",       y)        =sum(q,vFuelH2Quarter.l(z,q,y)  )$fEnableH2Production+1e-6;
4150   
4151  pEnergyBalanceCountryH2(c,dsH2hdr,y) = sum(z$(zcmap(z,c)), pEnergyBalanceH2(z,dsH2hdr,y));
4152   
4153  * ============================================================
4154  * 4. ENERGY DISPATCH
4155  * ============================================================
4156   
4157  * ---------------------------------------------------------
4158  * Hourly dispatch reporting: plant, fuel, and zone level
4159  * ---------------------------------------------------------
4160  * - pDispatchPlant: plant-level hourly generation and reserve [MW]
4161  * - pDispatchFuel: fuel-level hourly generation [MW]
4162  * - pDispatch: zone-level hourly imports, exports, unmet demand, storage charge, and demand [MW]
4163  * ---------------------------------------------------------
4164   
4165  pDispatchPlant(z, y, q, d, g, t, "Generation")$zgmap(z, g) = sum(gfmap(g, f), vPwrOut.l(g, f, q, d, t, y));
4166  pDispatchPlant(z, y, q, d, g, t, "Reserve")$zgmap(z, g) = vSpinningReserve.l(g, q, d, t, y);
4167   
4168  pDispatchFuel(z, y, q, d, f, t) = sum((gzmap(g, z), gfmap(g, f)), vPwrOut.l(g, f, q, d, t, y));
4169  pDispatchTechFuel(z, y, q, d, tech, f, t) =
4170    sum((gzmap(g, z), gtechmap(g, tech), gfmap(g, f)), vPwrOut.l(g, f, q, d, t, y));
4171   
4172  pDispatch(z, y, q, d, "Imports", t) = sum(sTopology(z, z2), vFlow.l(z2, z, q, d, t, y)) + sum(zext, vYearlyImportExternal.l(z, zext, q, d, t, y));
4173  pDispatch(z, y, q, d, "Exports", t) = -sum(sTopology(z, z2), vFlow.l(z, z2, q, d, t, y)) - sum(zext, vYearlyExportExternal.l(z, zext, q, d, t, y));
4174  pDispatch(z, y, q, d, "Unmet demand", t) = vUSE.l(z, q, d, t, y);
4175  pDispatch(z, y, q, d, "Storage Charge", t) = -sum(zgmap(z, st), vStorInj.l(st, q, d, t, y));
4176  pDispatch(z, y, q, d, "Demand", t) = pDemandData(z, q, d, y, t) * pEnergyEfficiencyFactor(z, y);
4177   
4178  * ============================================================
4179  * 5. RESERVES
4180  * ============================================================
4181   
4182  * ---------------------------------------------------------
4183  * Spinning reserve and reserve margin reporting
4184  * ---------------------------------------------------------
4185  * - pReserveSpinningPlantZone: annual spinning reserve provided by plant and zone [GWh]
4186  * - pReserveSpinningFuelZone: annual spinning reserve provided by fuel and zone [GWh]
4187  * - pReserveSpinningPlantCountry: annual spinning reserve provided by plant and country [GWh]
4188  * - pReserveMargin / pReserveMarginCountry: peak demand, total firm capacity, and reserve margin by zone/country
4189  * ---------------------------------------------------------
4190   
4191  pReserveSpinningPlantZone(zgmap(z,g),y) = sum((q,d,t), vSpinningReserve.l(g,q,d,t,y)*pHours(q,d,t))/1e3 ;
4192  pReserveSpinningFuelZone(z,f,y) = sum((gzmap(g,z),gfmap(g,f),q,d,t), vSpinningReserve.l(g,q,d,t,y)*pHours(q,d,t))/1e3 ;
4193  pReserveSpinningTechFuelZone(z,tech,f,y) =
4194    sum((gzmap(g,z),gtechmap(g,tech),gfmap(g,f),q,d,t), vSpinningReserve.l(g,q,d,t,y)*pHours(q,d,t))/1e3 ;
4195  pReserveSpinningPlantCountry(c,g,y)=  sum((zcmap(z,c),zgmap(z,g)), pReserveSpinningPlantZone(z,g,y));
4196  pReserveSpinningTechFuelCountry(c,tech,f,y) =
4197    sum(zcmap(z,c), pReserveSpinningTechFuelZone(z,tech,f,y));
4198   
4199  pReserveMargin(z,"Peak demand: MW",y) = smax((q,d,t), pDemandData(z,q,d,y,t)*pEnergyEfficiencyFactor(z,y));
4200  pReserveMargin(z,"TotalFirmCapacity",y) = sum(zgmap(z,g), pCapacityCredit(g,y)* vCap.l(g,y));
4201  pReserveMargin(z,"ReserveMargin",y)$(pReserveMargin(z,"TotalFirmCapacity",y)) = pReserveMargin(z,"TotalFirmCapacity",y)/pReserveMargin(z,"Peak demand: MW",y)  ;
4202   
4203  pReserveMarginCountry(c,"Peak demand: MW",y) =   pCapacitySummaryCountry(c,"Peak demand: MW"       ,y);
4204  pReserveMarginCountry(c,"TotalFirmCapacity",y) = sum(zcmap(z,c), pReserveMargin(z,"TotalFirmCapacity",y));
4205  pReserveMarginCountry(c,"ReserveMargin",y)$(pReserveMarginCountry(c,"TotalFirmCapacity",y)) = pReserveMarginCountry(c,"TotalFirmCapacity",y)/ pReserveMarginCountry(c,"Peak demand: MW",y)  ;
4206   
4207  * ============================================================
4208  * 6. INTERCONNECTIONS
4209  * ============================================================
4210   
4211  * ---------------------------------------------------------
4212  * Internal zones: interchange, utilization, losses, congestion
4213  * ---------------------------------------------------------
4214  * - pInterchange / pInterchangeCountry: net interchange flow [GWh]
4215  * - pInterconUtilization: utilization of transfer capacity [%]
4216  * - pLossesTransmission / pLossesTransmissionCountry: transmission losses [GWh]
4217  * - isCongested / pCongestionShare: binary indicator and share of time congested
4218  * ---------------------------------------------------------
4219   
4220  * Annual interchange between internal zones [GWh]
4221  pInterchange(sTopology(z, z2), y) =
4222    sum((q, d, t), vFlow.l(z, z2, q, d, t, y) * pHours(q, d, t)) / 1e3;
4223   
4224   
4225  * Utilization of interconnection throughout modeling horizon [%]
4226  pInterconUtilization(sTopology(z, z2), y)$pInterchange(z, z2, y) =
4227    1e3 * pInterchange(z, z2, y)
4228    / sum((q, d, t),
4229      (pTransferLimit(z, z2, q, y)
4230       + vNewTransmissionLine.l(z, z2, y)
4231         * max(pNewTransmission(z, z2, "CapacityPerLine"),
4232           pNewTransmission(z2, z, "CapacityPerLine"))
4233         * fAllowTransferExpansion)
4234      * pHours(q, d, t)
4235      );
4236   
4237  * Transmission losses between internal zones in MWh per zone
4238  pLossesTransmission(z, y) =
4239    sum((sTopology(z, z2), q, d, t),
4240      vFlow.l(z2, z, q, d, t, y) * pLossFactorInternal(z, z2, y) * pHours(q, d, t)
4241    );
4242   
4243  * Country-level interchange and losses
4244  alias (zcmap, zcmap2);
4245   
4246  pInterchangeCountry(c, c2, y) =
4247    sum((zcmap(z, c), zcmap2(z2, c2), sMapConnectedZonesDiffCountries(z2, z)),
4248      pInterchange(z, z2, y)
4249    );
4250   
4251  pLossesTransmissionCountry(c, y) =
4252    sum(zcmap(z, c), pLossesTransmission(z, y));
4253   
4254  * Binary indicator for congestion per time step
4255  isCongested(z, z2, q, d, t, y)$(
4256    sTopology(z, z2)
4257    and abs(
4258      vFlow.l(z, z2, q, d, t, y)
4259      - (
4260        pTransferLimit(z, z2, q, y)
4261        + vNewTransmissionLine.l(z, z2, y)
4262          * max(pNewTransmission(z, z2, "CapacityPerLine"),
4263            pNewTransmission(z2, z, "CapacityPerLine"))
4264          * fAllowTransferExpansion
4265        )
4266      ) < 1e-5
4267  ) = 1;
4268   
4269  * Percentage of time (weighted by pHours) when the line is congested
4270  pCongestionShare(sTopology(z, z2), y) =
4271    sum((q, d, t), isCongested(z, z2, q, d, t, y) * pHours(q, d, t))
4272    / sum((q, d, t), pHours(q, d, t));
4273   
4274   
4275  * ---------------------------------------------------------
4276  * External zones: imports and exports
4277  * ---------------------------------------------------------
4278  * - pHourlyInterchangeExternal / pYearlyInterchangeExternal: hourly and annual imports/exports [GWh]
4279  * - pInterchangeExternalExports / pInterconUtilizationExternalExports: exports and line utilization [%]
4280  * - pInterchangeExternalImports / pInterconUtilizationExternalImports: imports and line utilization [%]
4281  * - pHourlyInterchangeExternalCountry / pYearlyInterchangeExternalCountry: aggregated country-level interchange [GWh]
4282  * ---------------------------------------------------------
4283   
4284  set thrd / Imports, Exports /;
4285  set isExternal / Internal, External /;
4286   
4287  * Hourly interchange with external zones [MW]
4288  pHourlyInterchangeExternal(z, y, q, d, "Imports", t) =
4289    sum(zext, vYearlyImportExternal.l(z, zext, q, d, t, y));
4290   
4291  pHourlyInterchangeExternal(z, y, q, d, "Exports", t) =
4292    sum(zext, vYearlyExportExternal.l(z, zext, q, d, t, y));
4293   
4294  * Annual interchange with external zones [GWh]
4295  pYearlyInterchangeExternal(z, thrd, y) =
4296    sum((q, d, t), pHourlyInterchangeExternal(z, y, q, d, thrd, t) * pHours(q, d, t)) / 1e3;
4297   
4298  * Annual exports and imports with external zones [GWh]
4299  pInterchangeExternalExports(z, zext, y) =
4300    sum((q, d, t), vYearlyExportExternal.l(z, zext, q, d, t, y) * pHours(q, d, t)) / 1e3;
4301   
4302  pInterchangeExternalImports(zext, z, y) =
4303    sum((q, d, t), vYearlyImportExternal.l(z, zext, q, d, t, y) * pHours(q, d, t)) / 1e3;
4304   
4305  * Utilization of external interconnections [%]
4306  pInterconUtilizationExternalExports(z, zext, y)$pInterchangeExternalExports(z, zext, y) =
4307    1e3 * pInterchangeExternalExports(z, zext, y)
4308    / sum((q, d, t), pExtTransferLimitOut(z, zext, q, y) * pHours(q, d, t));
4309   
4310  pInterconUtilizationExternalImports(zext, z, y)$pInterchangeExternalImports(zext, z, y) =
4311    1e3 * pInterchangeExternalImports(zext, z, y)
4312    / sum((q, d, t), pExtTransferLimitIn(z, zext, q, y) * pHours(q, d, t));
4313   
4314  * Country-level hourly and annual interchange with external zones
4315  pHourlyInterchangeExternalCountry(c, y, q, d, thrd, t) =
4316    sum(zcmap(z, c), pHourlyInterchangeExternal(z, y, q, d, thrd, t));
4317   
4318  pYearlyInterchangeExternalCountry(c, thrd, y) =
4319    sum(zcmap(z, c), pYearlyInterchangeExternal(z, thrd, y));
4320   
4321  * ---------------------------------------------------------
4322  * Net import by zone and source zone type
4323  * ---------------------------------------------------------
4324  * Calculates net import (imports - exports) for each zone from
4325  * every other zone, distinguishing between internal and external zones.
4326  * Positive values indicate net imports, negative values indicate net exports.
4327  * ---------------------------------------------------------
4328   
4329  * Net import from internal zones
4330  * pInterchange(z, z2, y) represents flow from z to z2
4331  * Net import from z2 to z = -pInterchange(z, z2, y) when sTopology(z, z2) exists
4332  * If only reverse direction exists, use pInterchange(z2, z, y) directly
4333  pNetImport(z, z2, y, "Internal")$sTopology(z, z2) = -pInterchange(z, z2, y) / 1e3;
4334  pNetImport(z, z2, y, "Internal")$(sTopology(z2, z) and not sTopology(z, z2)) = pInterchange(z2, z, y) / 1e3;
4335   
4336  * Net import from external zones
4337  * Net import from zext to z = imports from zext - exports to zext
4338  pNetImport(z, zext, y, "External") =
4339    pInterchangeExternalImports(zext, z, y) - pInterchangeExternalExports(z, zext, y) / 1e3;
4340   
4341  * ============================================================
4342  * 7. EMISSIONS
4343  * ============================================================
4344   
4345  * ---------------------------------------------------------
4346  * Emissions reporting: zone, country, and marginal costs
4347  * ---------------------------------------------------------
4348  * - pEmissionsZone: total CO2 emissions [Mt] by zone and year
4349  * - pEmissionsIntensityZone: CO2 intensity [tCO2/GWh] by zone and year
4350  * - pEmissionsCountrySummary: total and backstop CO2 emissions [Mt] by country and year
4351  * - pEmissionsIntensityCountry: CO2 intensity [tCO2/GWh] by country and year
4352  * - pEmissionMarginalCosts / pEmissionMarginalCostsCountry: marginal cost of emission constraints [USD/tCO2]
4353  * ---------------------------------------------------------
4354   
4355  pEmissionsZone(z,y)                                                     =  vZonalEmissions.l(z,y)/1e6 ;
4356  pEmissionsIntensityZone(z,y)$pEnergyBalance(z,"Total production: GWh",y) = 1e-3*pEmissionsZone(z,y)/pEnergyBalance(z,"Total production: GWh",y);
4357  pEmissionsCountrySummary(c,"Emissions: mm tCO2eq",y)                               = sum(zcmap(z,c), pEmissionsZone(z,y));
4358  pEmissionsCountrySummary(c,"CO2backstopEmissions: mm tCO2eq",y)                    = vYearlyCO2backstop.l(c,y)/1e6;
4359  pEmissionsIntensityCountry(c,y)$pEnergyBalanceCountry(c,"Total production: GWh",y) = 1e-3*sum(zcmap(z,c), vZonalEmissions.l(z,y))/pEnergyBalanceCountry(c,"Total production: GWh",y);
4360   
4361  pEmissionMarginalCosts(y) $(pWeightYear(y))                  = -eTotalEmissionsConstraint.M(y)/pRR(y)/pWeightYear(y);
4362  pEmissionMarginalCostsCountry(c,y) $(pWeightYear(y))         = -eEmissionsCountry.M(c,y)/pRR(y)/pWeightYear(y);
4363   
4364  * ============================================================
4365  * 8. PRICES
4366  * ============================================================
4367  * ---------------------------------------------------------
4368  * Average yearly electricity prices at zone and country level
4369  * ---------------------------------------------------------
4370  * Calculates demand-weighted consumer prices, export/import
4371  * prices weighted by actual flows (internal & external),
4372  * and hub prices. Aggregates results to country averages
4373  * using zonal weights and interconnection flows.
4374  * ---------------------------------------------------------
4375   
4376  * Average yearly price paid by consumers, weighted by demand
4377  pPrice(z,y)$pEnergyBalance(z,"Demand: GWh",y) = 1e-3*sum((q,d,t),pHourlyPrice(z,q,d,t,y)*pDemandData(z,q,d,y,t)*pHours(q,d,t)*pEnergyEfficiencyFactor(z,y))
4378                                                       /pEnergyBalance(z,"Demand: GWh",y) ;
4379   
4380  Parameter
4381    pFlowMWSum(z,z2,y)    "Sum of hourly MW flows over the year (used for weights)"
4382    pFlowMWh(z,z2,y)      "Annual energy flow between zones [MWh]"
4383  ;
4384   
4385  pFlowMWSum(z,z2,y) = sum(sFlow(z,z2,q,d,t,y),vFlow.l(z,z2,q,d,t,y));
4386  pFlowMWh(z,z2,y) = sum(sFlow(z,z2,q,d,t,y),vFlow.l(z,z2,q,d,t,y)*pHours(q,d,t));
4387   
4388  * Average price of exports and imports, weighted by actual flows on the lines
4389  pPriceExport(z,y) $(sum(Zd, pFlowMWh(z,Zd,y))  > 0) = (sum((sTopology(z,Zd),q,d,t),  pHourlyPrice(z,q,d,t,y) *vFlow.l(z,Zd,q,d,t,y)*pHours(q,d,t))
4390                                                             + sum((zext,q,d,t), vYearlyExportExternal.l(z,zext,q,d,t,y) * pTradePrice(zext,q,d,y,t) * pHours(q,d,t)))
4391                                                           /(sum(Zd, pFlowMWh(z,Zd,y))+ sum((zext,q,d,t), vYearlyExportExternal.l(z,zext,q,d,t,y)* pHours(q,d,t)));
4392   
4393  pPriceImport(z,y) $(sum(Zd, pFlowMWh(Zd,z,y))  > 0) = (sum((sTopology(Zd,z),q,d,t),  pHourlyPrice(Zd,q,d,t,y)*vFlow.l(Zd,z,q,d,t,y)*pHours(q,d,t))
4394                                                              + sum((zext,q,d,t), vYearlyImportExternal.l(z,zext,q,d,t,y) * pTradePrice(zext,q,d,y,t) * pHours(q,d,t)))
4395                                                           /(sum(Zd, pFlowMWh(Zd,z,y))+ sum((zext,q,d,t), vYearlyImportExternal.l(z,zext,q,d,t,y)  * pHours(q,d,t)));
4396   
4397  * Average price at the hub, weighted by actual flows on the lines (TODO: check not with pHours)
4398  pPriceHub(Zt,y)$(sum(Zd, pFlowMWSum(Zt,Zd,y))   > 0) = sum((sTopology(Zt,Zd),q,d,t), pHourlyPrice(Zt,q,d,t,y)*vFlow.l(Zt,Zd,q,d,t,y))
4399                                                           /sum(Zd, pFlowMWSum(Zt,Zd,y));
4400   
4401  * Average yearly price paid by consumers, weighted by demand
4402  pPriceCountry(c,y)$pEnergyBalanceCountry(c,"Demand: GWh",y) = sum(zcmap(z,c), pPrice(z,y)*pEnergyBalance(z,"Demand: GWh",y))/pEnergyBalanceCountry(c,"Demand: GWh",y);
4403   
4404  * ---------------------------------------------------------
4405  * Country-level interconnection energy flows [MWh]
4406  * ---------------------------------------------------------
4407  * Aggregated annual energy exchanged between a country and its
4408  * neighboring countries, used as weights to compute average
4409  * export and import prices:
4410  *   - pCountryExportFlowMWh: total export energy from country c
4411  *   - pCountryImportFlowMWh: total import energy into country c
4412  * ---------------------------------------------------------
4413   
4414  Parameter
4415      pCountryExportFlowMWh(c,y) "Annual exported energy [MWh] from country c"
4416      pCountryImportFlowMWh(c,y) "Annual imported energy [MWh] into country c";
4417   
4418  pCountryExportFlowMWh(c,y) = sum((zcmap(z,c), sMapConnectedZonesDiffCountries(z,Zd)), pFlowMWh(z,Zd,y));
4419   
4420  pPriceExportCountry(c,y)$(pCountryExportFlowMWh(c,y) > 0) =
4421      sum((zcmap(z,c), sMapConnectedZonesDiffCountries(z,Zd),q,d,t),
4422          pHourlyPrice(z,q,d,t,y)*vFlow.l(z,Zd,q,d,t,y)*pHours(q,d,t))
4423      / pCountryExportFlowMWh(c,y);
4424   
4425  pCountryImportFlowMWh(c,y) = sum((zcmap(z,c), sMapConnectedZonesDiffCountries(Zd,z)), pFlowMWh(Zd,z,y));
4426   
4427  pPriceImportCountry(c,y)$(pCountryImportFlowMWh(c,y) > 0) =
4428      sum((zcmap(z,c), sMapConnectedZonesDiffCountries(Zd,z),q,d,t),
4429          pHourlyPrice(Zd,q,d,t,y)*vFlow.l(Zd,z,q,d,t,y)*pHours(q,d,t))
4430      / pCountryImportFlowMWh(c,y);
4431   
4432   
4433   
4434  * ============================================================
4435  * 9. SPECIAL TECHNOLOGIES
4436  * ============================================================
4437  * ---------------------------------------------------------
4438  * CSP, PV+Storage, and Generic Storage balances and components
4439  * ---------------------------------------------------------
4440  * Tracks technology-specific balances and installed components:
4441  *   - pCSPBalance: thermal, storage input/output, and power output by CSP
4442  *   - pCSPComponents: thermal field, storage, power block, solar multiple, storage hours
4443  *   - pPVwSTOBalance: PV output, storage input/output, storage losses and levels for PV+storage systems
4444  *   - pPVwSTOComponents: PV capacity, storage MW/MWh, storage hours
4445  *   - pStorageBalance: input, output, losses, net change, and storage level for generic storage
4446  *   - pStorageComponents: installed MW, MWh, and storage hours
4447  * ---------------------------------------------------------
4448   
4449  pCSPBalance(y, g,q,d,"Thermal output",t) = vThermalOut.l(g,q,d,t,y);
4450  pCSPBalance(y,cs,q,d,"Storage Input" ,t) = vStorInj.l(cs,q,d,t,y);
4451  pCSPBalance(y,cs,q,d,"Storage Output",t) = vStorOut.l(cs,q,d,t,y);
4452  pCSPBalance(y,cs,q,d,"Power Output"  ,t) = sum(gfmap(cs,f), vPwrOut.l(cs,f,q,d,t,y));
4453   
4454  pCSPComponents(g, "Thermal Field: WM" ,y) = vCapTherm.l(g,y);
4455  pCSPComponents(cs,"Storage: MWh"      ,y) = vCapStor.l(cs,y);
4456  pCSPComponents(cs,"Power Block: MW"   ,y) = vCap.l(cs,y);
4457  pCSPComponents(g, "Solar Multiple"    ,y) = vCapTherm.l(g,y)/max(vCap.l(g,y),1);
4458  pCSPComponents(cs,"Storage Hours: hrs",y) = vCapStor.l(cs,y)/max(vCap.l(cs,y),1);
4459   
4460  pPVwSTOBalance(y,q,d,so, "PV output"     ,t) = sum(gfmap(so,f), vPwrOut.l(so,f,q,d,t,y));
4461  pPVwSTOBalance(y,q,d,stp,"Storage Input" ,t) = vStorInj.l(stp,q,d,t,y);
4462  pPVwSTOBalance(y,q,d,stp,"Storage output",t) = sum(gfmap(stp,f), vPwrOut.l(stp,f,q,d,t,y));
4463  pPVwSTOBalance(y,q,d,stp,"Storage Losses",t) = (1-pStorageData(stp,"Efficiency"))*vStorInj.l(stp,q,d,t,y);
4464  pPVwSTOBalance(y,q,d,stp,"Storage level" ,t) = vStorage.l(stp,q,d,t,y);
4465   
4466  pPVwSTOComponents(so, "PV Plants"           ,y) = vCap.l(so,y);
4467  pPVwSTOComponents(stp,"Storage Capacity MW" ,y) = vCap.l(stp,y);
4468  pPVwSTOComponents(stp,"Storage Capacity MWh",y) = vCapStor.l(stp,y);
4469  pPVwSTOComponents(stp,"Storage Hours"       ,y) = vCapStor.l(stp,y)/max(vCap.l(stp,y),1);
4470   
4471  pStorageBalance(y,stg,q,d,"Storage Input"     ,t) = vStorInj.l(stg,q,d,t,y);
4472  pStorageBalance(y,stg,q,d,"Storage Output"    ,t) = sum(gfmap(stg,f), vPwrOut.l(stg,f,q,d,t,y));
4473  pStorageBalance(y,stg,q,d,"Storage Losses"    ,t) = (1-pStorageData(stg,"Efficiency"))*vStorInj.l(stg,q,d,t,y);
4474  pStorageBalance(y,stg,q,d,"Net Storage Change",t) = vStorNet.l(stg,q,d,t,y);
4475  pStorageBalance(y,stg,q,d,"Storage Level"     ,t) = vStorage.l(stg,q,d,t,y);
4476   
4477  pStorageComponents(stg,"Storage Capacity: MW",y) = vCap.l(stg,y);
4478  pStorageComponents(stg,"Storage Capacity: MWh"  ,y) = vCapStor.l(stg,y);
4479  pStorageComponents(stg,"Storage Hours"         ,y) = vCapStor.l(stg,y)/max(vCap.l(stg,y),1);
4480   
4481  * ---------------------------------------------------------
4482  * Zonal solar energy, value, and cost indicators
4483  * ---------------------------------------------------------
4484  * Computes solar power output, annual energy, market value,
4485  * and levelized cost of solar at the zonal level:
4486  *   - pSolarPower: hourly solar generation
4487  *   - pSolarEnergyZone: total annual solar energy (MWh)
4488  *   - pSolarValueZone: average market value of solar ($/MWh)
4489  *   - pSolarCost: levelized cost of solar based on Investment costs ($/MWh)
4490  * ---------------------------------------------------------
4491   
4492  set PVtech(tech) / PV, PVwSTO /;
4493  Parameter pSolarEnergyZone(z,y);
4494   
4495  pSolarPower(z,q,d,t,y) = sum((gzmap(g,z),gtechmap(g,PVtech),gfmap(g,f)), vPwrOut.l(g,f,q,d,t,y));
4496  pSolarEnergyZone(z,y) = sum((q,d,t), pSolarPower(z,q,d,t,y)*pHours(q,d,t));
4497  pSolarValueZone(z,y)$(pSolarEnergyZone(z,y) > 0) = sum((q,d,t), pHourlyPrice(z,q,d,t,y)*pSolarPower(z,q,d,t,y))/pSolarEnergyZone(z,y);
4498  pSolarCost(z,y)$(pSolarEnergyZone(z,y) > 0) = (sum((gzmap(ng,z),gtechmap(ng,PVtech)), pCRF(ng)*vCap.l(ng,y)*pGenData(ng,"Capex")*pCapexTrajectories(ng,y))*1e6)/pSolarEnergyZone(z,y);
4499   
4500   
4501  * ============================================================
4502  * 10. METRICS
4503  * ============================================================
4504   
4505  * ---------------------------------------------------------
4506  * LCOE by plant [$/MWh]
4507  * ---------------------------------------------------------
4508   
4509  Parameter
4510    pPlantEnergyMWh(z,g,y) "Annual energy production by plant [MWh]"
4511  ;
4512   
4513  * Plant-level energy denominator
4514  pPlantEnergyMWh(z,g,y)$pEnergyPlant(z,g,y) = pEnergyPlant(z,g,y)*1e3;
4515   
4516  * LCOE for new capacity plants (without direct spinning reserve cost)
4517  pPlantAnnualLCOE(z,g,y)$((pPlantEnergyMWh(z,g,y)) and (pPlantEnergyMWh(z,g,y) >= 1e3)) =
4518      1e6 * (
4519          pCostsPlant(z, g, "Investment costs: $m", y)
4520        + pCostsPlant(z, g, "Fixed O&M: $m", y)
4521        + pCostsPlant(z, g, "Variable Cost: $m", y)
4522  *      + pCostsPlant(z, g, "Spinning Reserve Cost: $m", y)
4523      ) / pPlantEnergyMWh(z,g,y);
4524   
4525   
4526  * Zone-level generation cost intensity by component [$/MWh]
4527  pGenCostsPerMWh(z,genCostCmp,y)$sum(gzmap(g,z), pEnergyPlant(z,g,y)) =
4528      1e6 * sum(gzmap(g,z), pCostsPlant(z, g, genCostCmp, y))
4529      / (sum(gzmap(g,z), pEnergyPlant(z,g,y)) * 1e3);
4530   
4531   
4532  * ============================================================
4533  * 11. modeltype PARAMETERS
4534  * ============================================================
4535   
4536  pSolverParameters("modeltype Status")               = PA.modelstat + EPS;
4537  pSolverParameters("modeltype Time: ms")             = PA.etSolve + EPS;
4538  pSolverParameters("Absolute gap")                = PA.objVal-PA.objEst + EPS;
4539  pSolverParameters("Relative gap")$(PA.objVal >0) = pSolverParameters("Absolute gap")/PA.objVal + EPS;
4540   
4541  *--- END RESULTS
4542   
