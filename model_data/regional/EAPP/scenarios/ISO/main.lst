1558  * ------------------------------
1559  * Unit-commitment transition equations
1560  * ------------------------------
1561     eCommitmentConsistency 'Keeps each hour’s on/off change consistent with the recorded startup/shutdown activity'
1562     eCommitmentInitialization 'Applies the same accounting for the first chronological slot using the initial status'
1563     eCommitmentSingleTransition 'Prevents multiple start/shutdown actions within a single chronological slot'
1564     eStartupCostConstraint(g,q,d,t,y) 'Aggregate startup cost per representative timeslice'
1565     eMinUpInitial(g,y) 'Initial minimum up-time accounting'
1566     eMinUpRolling(g,AT2,y) 'Rolling minimum up-time enforcement for startups'
1567     eMinDownInitial(g,y) 'Initial minimum down-time accounting'
1568     eMinDownRolling(g,AT2,y) 'Rolling minimum down-time enforcement for shutdowns'
1569  ;
1570   
1571   
1572  *-------------------------------------------------------------------
1573  * OBJECTIVE FUNCTION
1574  *-------------------------------------------------------------------
1575  * Adding system-level cost of reserves and CO2 backstop to the total cost
1576  eNPVCost..
1577     vNPVCost =e= sum(y, pRR(y)*pWeightYear(y)*(sum(c,
1578                                   vYearlyTotalCost(c,y)) +
1579                                   vYearlyUnmetPlanningReserveCostSystem(y) +
1580                                   vYearlyUnmetSpinningReserveCostSystem(y) +
1581                                   vYearlyCO2BackstopCostSystem(y))
1582                                   );
1583   
1584  *-------------------------------------------------------------------
1585  * 1. COST
1586  *-------------------------------------------------------------------
1587  * ------------------------------
1588  * System-level Cost accounting
1589  * ------------------------------
1590   
1591  eYearlyUnmetPlanningReserveCostSystem(y)..
1592     vYearlyUnmetPlanningReserveCostSystem(y) =e= vUnmetPlanningReserveSystem(y)*pPlanningReserveVoLL;
1593   
1594  eYearlyUnmetSpinningReserveCostSystem(y)..
1595     vYearlyUnmetSpinningReserveCostSystem(y) =e= sum((q,d,t), vUnmetSpinningReserveSystem(q,d,t,y)*pHours(q,d,t)*pSpinningReserveVoLL);
1596   
1597  eYearlyCO2BackstopCostsSystem(y)..
1598     vYearlyCO2BackstopCostSystem(y) =e= vYearlySysCO2backstop(y)*pCostOfCO2backstop;
1599   
1600  * Note capex is full capex in $m per MW. Also note VarCost includes fuel cost and VOM -
1601  * essentially the short run marginal cost for the generator
1602   
1603  * Adding country-level cost of reserves and CO2 backstop to the total cost
1604  eYearlyTotalCost(c,y)..
1605     vYearlyTotalCost(c,y) =e= vYearlyUnmetReserveCostCountry(c,y)+ vYearlyCO2BackstopCostCountry(c,y)
1606                             + sum(zcmap(z,c), vAnnCapex(z, y)
1607                                             + vYearlyFOMCost(z, y)
1608                                             + vYearlyVariableCost(z,y)
1609                                             + vYearlySpinningReserveCost(z,y)
1610                                             + vYearlyUSECost(z,y)
1611                                             + vYearlyCarbonCost(z,y)
1612                                             + vYearlyExternalTradeCost(z,y)
1613                                             + vAnnualizedTransmissionCapex(z,y)
1614                                             + vYearlyCurtailmentCost(z,y)
1615                                             + vYearlySurplus(z,y));
1616   
1617  * ------------------------------
1618  * Country-level Cost accounting
1619  * ------------------------------
1620   
1621  * Yearly unmet reserve cost at the country level
1622  eYearlyUnmetReserveCostCountry(c,y)..
1623     vYearlyUnmetReserveCostCountry(c,y) =e= vYearlyUnmetPlanningReserveCostCountry(c,y) + vYearlyUnmetSpinningReserveCostCountry(c,y);
1624   
1625  * Yearly unmet spinning reserve cost at the country level
1626  eYearlyUnmetSpinningReserveCostCountry(c,y)..
1627     vYearlyUnmetSpinningReserveCostCountry(c,y) =e= sum((q,d,t), vUnmetSpinningReserveCountry(c,q,d,t,y)*pHours(q,d,t)*pSpinningReserveVoLL);
1628   
1629  * Yearly unmet planning reserve cost at the country level
1630  eYearlyUnmetPlanningReserveCostCountry(c,y)..
1631     vYearlyUnmetPlanningReserveCostCountry(c,y) =e= vUnmetPlanningReserveCountry(c,y)*pPlanningReserveVoLL;
1632   
1633  * Yearly CO2 backstop cost at the country level
1634  eYearlyCO2BackstopCostCountry(c,y)..
1635     vYearlyCO2BackstopCostCountry(c,y) =e= vYearlyCO2backstop(c,y)*pCostOfCO2backstop;
1636   
1637  * ------------------------------
1638  * Zonal CAPEX accounting
1639  * Aggregates generator-level annualized CAPEX to the zone level.
1640  * ------------------------------
1641  * Annualized CAPEX for all zones in year y
1642  eTotalAnnualizedCapex(z, y)..
1643     vAnnCapex(z,y) =e= sum(gzmap(g,z), vAnnGenCapex(g,y));
1644   
1645  * Annualized CAPEX for all generators in year y
1646  * Separate treatment keeps time-varying CAPEX trajectories (dc) distinct
1647  * from flat-cost assets (ndc) when annualizing capital costs.
1648  * Assets tagged in set dc(g) follow time-varying CAPEX trajectories (stored
1649  * in vAnnCapexGenTraj), while flat-cost assets (ndc(g)) use
1650  * conventional CRF-based annualization. We keep both paths to preserve the
1651  * different depreciation logic without double-counting.
1652  eTotalAnnualizedGenCapex(g,y)..
1653     vAnnGenCapex(g,y) =e=
1654         vAnnCapexGenTraj(g,y)$(dc(g) and ng(g))
1655       + pCRF(g)*vCap(g,y)*pGenData(g,"Capex")*1e6$(ndc(g) and ng(g))
1656       + pCRFsst(g)*vCapStor(g,y)*pStorageData(g,"CapexMWh")*1e3$(ndc(g) and ng(g) and not cs(g))
1657       + pCRFcst(g)*vCapStor(g,y)*pCSPData(g,"Storage","CapexMWh")*1e3$(ndc(g) and ng(g) and not st(g))
1658       + pCRFcth(g)*vCapTherm(g,y)*pCSPData(g,"Thermal Field","CapexMWh")*1e6$(ndc(g) and ng(g));
1659   
1660  * Annualized CAPEX accumulation (years after the start year) for generators with capex trajectory
1661  eAnnualizedCapexUpdate(dc,y)$(not sStartYear(y))..
1662     vAnnCapexGenTraj(dc,y) =e= vAnnCapexGenTraj(dc,y-1)
1663                       + vBuild(dc,y)*pGenData(dc,"Capex")*pCapexTrajectories(dc,y)*pCRF(dc)*1e6
1664                       + vBuildStor(dc,y)*pStorageData(dc,"CapexMWh")*pCapexTrajectories(dc,y)*pCRFsst(dc)*1e3
1665                       + vBuildStor(dc,y)*pCSPData(dc,"Storage","CapexMWh")*pCapexTrajectories(dc,y)*pCRFcst(dc)*1e3
1666                       + vBuildTherm(dc,y)*pCSPData(dc,"Thermal Field","CapexMWh")*pCapexTrajectories(dc,y)*pCRFcth(dc)*1e6;
1667   
1668  * Initial annualized CAPEX in the start year for generators with capex trajectory
1669  eAnnualizedCapexInit(dc,sStartYear(y))..
1670     vAnnCapexGenTraj(dc,y) =e=
1671         vBuild(dc,y)     *pGenData(dc,"Capex")        *pCapexTrajectories(dc,y)*pCRF(dc)   *1e6
1672       + vBuildStor(dc,y) *pStorageData(dc,"CapexMWh")    *pCapexTrajectories(dc,y)*pCRFsst(dc)*1e3
1673       + vBuildStor(dc,y) *pCSPData(dc,"Storage","CapexMWh")*pCapexTrajectories(dc,y)*pCRFcst(dc)*1e3
1674       + vBuildTherm(dc,y)*pCSPData(dc,"Thermal Field","CapexMWh")*pCapexTrajectories(dc,y)*pCRFcth(dc)*1e6;
1675   
1676  * FOM costs including fixed O&M costs for generators, storage, and CSP thermal field
1677  eYearlyFOMCost(z,y)..
1678     vYearlyFOMCost(z,y) =e= sum(gzmap(g,z),  vCap(g,y)*pGenData(g,"FOMperMW"))
1679              + sum(gzmap(st,z), vCapStor(st,y)*pStorageData(st,"FixedOMMWh"))
1680              + sum(gzmap(cs,z), vCapStor(cs,y)*pCSPData(cs,"Storage","FixedOMMWh"))
1681              + sum(gzmap(cs,z), vCapTherm(cs,y)*pCSPData(cs,"Thermal field","FixedOMMWh"));
1682   
1683  * Variable costs equals fuel cost plus VOM cost
1684  eYearlyVariableCost(z,y)..
1685     vYearlyVariableCost(z,y) =e= vYearlyFuelCost(z,y) + vYearlyVOMCost(z,y) + vYearlyStartupCost(z,y);
1686   
1687  * Annualized startup cost pulled from dispatch slots (links to time-sliced variable).
1688  eYearlyStartupCost(z,y)$((fDispatchMode and fApplyStartupCost))..
1689     vYearlyStartupCost(z,y) =e= sum((gzmap(g,z),q,d,t)$MinGenPoint(g),
1690           vStartupCost(g,q,d,t,y)*pHours(q,d,t));
1691   
1692  * If startup costs are disabled, force the reporting variable to zero.
1693  eYearlyStartupCostOff(z,y)$(fDispatchMode=0 or fApplyStartupCost=0)..
1694     vYearlyStartupCost(z,y) =e= 0;
1695  *  Startup cost flows through the same time-slice weighting as the rest of the variable cost stack.
1696   
1697  * Fuel costs
1698  eYearlyFuelCost(z,y)..
1699     vYearlyFuelCost(z,y) =e= sum((gzmap(g,z),f,q,d,t), pFuelCost(g,f,y)*vPwrOut(g,f,q,d,t,y)*pHours(q,d,t));
1700   
1701  * VOM
1702  eYearlyVOMCost(z,y)..
1703     vYearlyVOMCost(z,y) =e= sum((gzmap(g,z),f,q,d,t), pVOMCost(g,f,y)*vPwrOut(g,f,q,d,t,y)*pHours(q,d,t));
1704   
1705  * Note: ReserveCost is in $/MWh -- this is the DIRECT cost of holding reserve like wear and tear that a generator bids in a market
1706  eYearlySpinningReserveCost(z,y)..
1707     vYearlySpinningReserveCost(z,y) =e= sum((gzmap(g,z),q,d,t), vSpinningReserve(g,q,d,t,y)*pGenData(g,"ReserveCost")*pHours(q,d,t));
1708   
1709  * Unserved energy cost (USE)
1710  eYearlyUSECost(z,y)..
1711     vYearlyUSECost(z,y) =e= sum((q,d,t), vUSE(z,q,d,t,y)*pVoLL*pHours(q,d,t));
1712   
1713  * Surplus cost
1714  eYearlySurplusCost(z,y)..
1715     vYearlySurplus(z,y) =e= sum((q,d,t), vSurplus(z,q,d,t,y)*pSurplusPenalty*pHours(q,d,t));
1716   
1717  * Curtailment cost
1718  eYearlyCurtailmentCost(z,y)..
1719     vYearlyCurtailmentCost(z,y) =e= sum((gzmap(g,z),q,d,t), vCurtailedVRE(z,g,q,d,t,y)*pCostOfCurtailment*pHours(q,d,t));
1720   
1721  * Yearly trade cost
1722  eYearlyExternalTradeCost(z,y)..
1723     vYearlyExternalTradeCost(z,y) =e= vYearlyImportExternalCost(z,y) - vYearlyExportExternalCost(z,y);
1724   
1725  * Yearly import and export costs from external zones
1726  eYearlyImportExternalCost(z,y)..
1727     vYearlyImportExternalCost(z,y) =e= sum((zext,q,d,t), vYearlyImportExternal(z,zext,q,d,t,y)*pTradePrice(zext,q,d,y,t)*pHours(q,d,t));
1728   
1729  * Yearly export cost to external zones
1730  eYearlyExportExternalCost(z,y)..
1731     vYearlyExportExternalCost(z,y) =e= sum((zext,q,d,t), vYearlyExportExternal(z,zext,q,d,t,y)*pTradePrice(zext,q,d,y,t)*pHours(q,d,t));
1732   
1733  * Yearly CO2 emissions cost for each zone
1734  eYearlyCarbonCost(z,y)..
1735     vYearlyCarbonCost(z,y) =e= fEnableCarbonPrice*pCarbonPrice(y)
1736                              * Sum((gzmap(g,z),gfmap(g,f),q,d,t), vPwrOut(g,f,q,d,t,y)*pHeatRate(g,f)*pFuelCarbonContent(f)*pHours(q,d,t));
1737   
1738   
1739  * Ensures that when accessing parameters like CostPerLine or Life for a connection between zones i and j,
1740  * the model always uses the maximum of both directions, regardless of ordering.
1741  $macro symmax(s,i,j,h) max(s(i,j,h),s(j,i,h))
1742   
1743  * Computes annualized investment cost of new transmission lines connected to zone z
1744  * using the annuity formula and averaging (divided by 2) to avoid double-counting symmetric lines
1745  eAnnualizedTransmissionCapex(z,y)$(fAllowTransferExpansion and sum(sTopology(z,z2),1))..
1746     vAnnualizedTransmissionCapex(z,y) =e=
1747         sum(sTopology(z,z2),
1748             vNewTransmissionLine(z,z2,y)
1749           * max(pNewTransmission(z,z2,"CostPerLine"),pNewTransmission(z2,z,"CostPerLine"))
1750           * 1e6)
1751       / 2
1752       * (pWACC / (1 - (1 / ((1 + pWACC) ** sum(sTopology(z,z2), max(pNewTransmission(z,z2,"Life"),pNewTransmission(z2,z,"Life")))))));
1753   
1754  * ------------------------------
1755  * Demand and supply balance
1756  * Ensures zonal demand matches supply components.
1757  * ------------------------------
1758  eDemSupply(z,q,d,t,y)$FD(q,d,t)..
1759     pDemandData(z,q,d,y,t) * pEnergyEfficiencyFactor(z,y) =e= vSupply(z,q,d,t,y);
1760   
1761  eDefineSupply(z,q,d,t,y)$FD(q,d,t)..
1762     vSupply(z,q,d,t,y) =e=
1763       sum((gzmap(g,z),gfmap(g,f)), vPwrOut(g,f,q,d,t,y))
1764     - sum(sTopology(z,z2), vFlow(z,z2,q,d,t,y))
1765     + sum(sTopology(z,z2), vFlow(z2,z,q,d,t,y) * (1 - pLossFactorInternal(z,z2,y)))
1766     - sum(gzmap(st,z), vStorInj(st,q,d,t,y))$(fEnableStorage)
1767     + sum(zext, vYearlyImportExternal(z,zext,q,d,t,y))
1768     - sum(zext, vYearlyExportExternal(z,zext,q,d,t,y))
1769     + vUSE(z,q,d,t,y)
1770     - vSurplus(z,q,d,t,y);
1771   
1772   
1773  * ------------------------------
1774  * Generator capacity equations
1775  * Tracks installed capacity for existing/new units.
1776  * ------------------------------
1777  * Initial capacity balance in the first model year
1778  eInitialCapacity(g,sStartYear(y))..
1779     vCap(g,y) =e= pGenData(g,"Capacity")$(eg(g) and (pGenData(g,"StYr") <= sStartYear.val))
1780                 + vBuild(g,y) - vRetire(g,y);
1781   
1782  * Year-on-year capacity tracking for existing generators
1783  eCapacityEvolutionExist(eg,y)$(not sStartYear(y))..
1784     vCap(eg,y) =e= vCap(eg,y-1) + vBuild(eg,y) - vRetire(eg,y);
1785   
1786  * Year-on-year capacity tracking for new generators (non-retirable)
1787  eCapacityEvolutionNew(ng,y)$(not sStartYear(y))..
1788     vCap(ng,y) =e= vCap(ng,y-1) + vBuild(ng,y);
1789   
1790  * Limit on initial build for new generators (starting after model year 1)
1791  eInitialBuildLimit(eg)$(pGenData(eg,"StYr") > sStartYear.val)..
1792     sum(y, vBuild(eg,y)) =l= pGenData(eg,"Capacity");
1793   
1794  eMinGenRE(c,y)$(pMinRE and y.val >= pMinsRenewableTargetYear)..
1795     sum((zcmap(z,c),gzmap(RE,z),gfmap(RE,f),q,d,t), vPwrOut(RE,f,q,d,t,y)*pHours(q,d,t)) =g=
1796     sum((zcmap(z,c),q,d,t), pDemandData(z,q,d,y,t)*pHours(q,d,t)*pEnergyEfficiencyFactor(z,y))*pMinRE;
1797   
1798  eBuiltCap(ng,y)$pGenData(ng,"DescreteCap")..
1799     vBuild(ng,y) =e= pGenData(ng,"UnitSize")*vBuiltCapVar(ng,y);
1800   
1801  eRetireCap(eg,y)$(pGenData(eg,"DescreteCap") and (y.val <= pGenData(eg,"RetrYr")))..
1802     vRetire(eg,y) =e= pGenData(eg,"UnitSize")*vRetireCapVar(eg,y);
1803   
1804  * ------------------------------
1805  * Production equations
1806  * Constrains generator dispatch, ramping, and minimum output.
1807  * ------------------------------
1808  * Enforces dispatch/reserve only when the generator is committed for the chronological slot.
1809  eJointResCap(g,q,d,t,y)$FD(q,d,t)..
1810     sum(gfmap(g,f), vPwrOut(g,f,q,d,t,y)) + vSpinningReserve(g,q,d,t,y)
1811        =l= vCap(g,y)*(1+pGenData(g,"Overloadfactor"));
1812   
1813  eMaxCF(g,q,y)..
1814     sum((gfmap(g,f),d,t), vPwrOut(g,f,q,d,t,y)*pHours(q,d,t)) =l= pAvailability(g,y,q)*vCap(g,y)*sum((d,t), pHours(q,d,t));
1815   
1816  * Note that we are effectively assuming grid-connected RE generation to be dispatchable. Generally speaking, most RE will be
1817  * dispatched anyway because they have zero cost (i.e., not a different outcome from net load approach, but this allows for
1818  * RE generation to be rejected as well
1819  eVREProfile(gfmap(VRE,f),z,q,d,t,y)$(gzmap(VRE,z) and FD(q,d,t))..
1820     vPwrOut(VRE,f,q,d,t,y) + vCurtailedVRE(z,VRE,q,d,t,y) =e= pVREgenProfile(VRE,q,d,t)*pAvailability(VRE,y,q)*vCap(VRE,y);
1821   
1822  eFuel(zfmap(z,f),y)..
1823     vFuel(z,f,y) =e= sum((gzmap(g,z),gfmap(g,f),q,d,t), vPwrOut(g,f,q,d,t,y)*pHours(q,d,t)*pHeatRate(g,f));
1824   
1825  eFuelLimit(c,f,y)$(fApplyFuelConstraint and pMaxFuelLimit(c,f,y) > 0)..
1826     sum((zcmap(z,c),zfmap(z,f)), vFuel(z,f,y)) =l= pMaxFuelLimit(c,f,y)*1e6;
1827   
1828  * Phase-out constraint: limits annual generation by zone-technology-fuel combination
1829  eMaxGenerationByFuel(z,tech,f,y)$(fApplyGenerationPhaseout and pMaxGenerationByFuel(z,tech,f,y))..
1830     sum((gzmap(g,z),gtechmap(g,tech),gfmap(g,f),q,d,t), vPwrOut(g,f,q,d,t,y)*pHours(q,d,t))/1e3 =l= pMaxGenerationByFuel(z,tech,f,y);
1831   
1832  * Applies the minimum output requirement per capacity share.
1833  eMinGen(g,q,d,t,y)$((fApplyMinGenShareAllHours and pGenData(g,"MinGenShareAllHours") > 0) and FD(q,d,t))..
1834      sum(gfmap(g,f), vPwrOut(g,f,q,d,t,y)) =g= vCap(g,y)*pGenData(g,"MinGenShareAllHours");
1835   
1836  * ------------------------------
1837  * Unit-commitment transition equations
1838  * Ensures the recorded on/off state matches startups/shutdowns and forbids more than one transition per slot.
1839  * Since the state alone cannot capture how many switches occurred, we introduce startup/shutdown binaries alongside `isOn`.
1840  * ------------------------------
1841   
1842  * Dispatch-mode minimum generation only when the generator is recorded as online.
1843  eDispatchMinGenPoint(g,q,d,t,y)$((fDispatchMode and fApplyMinGenCommitment and MinGenPoint(g) and FD(q,d,t)))..
1844     sum(gfmap(g,f), vPwrOut(g,f,q,d,t,y))
1845        =g= pGenData(g,"MinGenCommitment")*pGenData(g,"Capacity")
1846            * sum(AT$mapTS(q,d,t,AT), isOn(g,q,d,t,AT,y));
1847   
1848  * Prevents exceeding capacity while the generator reports being online in dispatch slots.
1849  eDispatchMaxGenPoint(g,q,d,t,y)$((fDispatchMode and fApplyMinGenCommitment and MinGenPoint(g) and FD(q,d,t)))..
1850     sum(gfmap(g,f), vPwrOut(g,f,q,d,t,y))
1851        =l= pGenData(g,"Capacity")*sum(AT$mapTS(q,d,t,AT), isOn(g,q,d,t,AT,y));
1852   
1853  * Keeps each hour’s on/off change consistent with the recorded startup/shutdown activity.
1854  eCommitmentConsistency(g,AT,y)$(ord(AT) > 1 and fDispatchMode and fApplyMinGenCommitment and MinGenPoint(g))..
1855     sum((q,d,t)$mapTS(q,d,t,AT), isStartup(g,q,d,t,AT,y) - isShutdown(g,q,d,t,AT,y))
1856        =e= sum((q,d,t)$mapTS(q,d,t,AT), isOn(g,q,d,t,AT,y))
1857           - sum((q,d,t)$mapTS(q,d,t,AT-1), isOn(g,q,d,t,AT-1,y));
1858   
1859  * Applies the same accounting for the first chronological slot using the initial status.
1860  eCommitmentInitialization(g,AT,y)$(ord(AT) = 1 and fDispatchMode and fApplyMinGenCommitment and MinGenPoint(g))..
1861     sum((q,d,t)$mapTS(q,d,t,AT), isStartup(g,q,d,t,AT,y) - isShutdown(g,q,d,t,AT,y))
1862        =e= sum((q,d,t)$mapTS(q,d,t,AT), isOn(g,q,d,t,AT,y)) - pInitialOnStart(g);
1863   
1864  * Prevents multiple start/shutdown actions within a single chronological slot.
1865  eCommitmentSingleTransition(g,AT,y)$(fDispatchMode and fApplyMinGenCommitment and MinGenPoint(g))..
1866     sum((q,d,t)$mapTS(q,d,t,AT), isStartup(g,q,d,t,AT,y) + isShutdown(g,q,d,t,AT,y)) =l= 1;
1867   
1868  * ------------------------------
1869  * Minimum up/down-time constraints
1870  * ------------------------------
1871  * Initial minimum up-time: if HoursOn > 0, force the remaining required online hours.
1872  eMinUpInitial(g,y)$(fDispatchMode and fApplyMUDT and fApplyMinGenCommitment and MinGenPoint(g) and pGenData(g,"HoursOn")
1873        and pGenData(g,"HoursOff") = 0 and pGenData(g,"minUT") > 0.999)..
1874     sum(AT$(ord(AT) < (pGenData(g,"minUT") - pGenData(g,"HoursOn") + 1)),
1875         sum((q,d,t)$mapTS(q,d,t,AT), 1 - isOn(g,q,d,t,AT,y))) =e= 0;
1876   
1877  * Rolling minimum up-time: every startup must be followed by minUT consecutive on hours.
1878  eMinUpRolling(g,AT2,y)$(fDispatchMode and fApplyMUDT and fApplyMinGenCommitment and MinGenPoint(g) and pGenData(g,"minUT") > 0.999
1879        and ord(AT2) > (pGenData(g,"minUT") - pGenData(g,"HoursOn") + 1)$pGenData(g,"HoursOn")
1880        and ord(AT2) < (card(AT2) - pGenData(g,"minUT") + 1))..
1881     sum(AT$((ord(AT) >= ord(AT2)) and (ord(AT) < ord(AT2) + pGenData(g,"minUT"))),
1882         sum((q,d,t)$mapTS(q,d,t,AT), isOn(g,q,d,t,AT,y)))
1883        =g= pGenData(g,"minUT") * sum((q,d,t)$mapTS(q,d,t,AT2), isStartup(g,q,d,t,AT2,y));
1884   
1885  * Initial minimum down-time: if HoursOff > 0, force the remaining offline hours.
1886  eMinDownInitial(g,y)$(fDispatchMode and fApplyMUDT and fApplyMinGenCommitment and MinGenPoint(g) and pGenData(g,"HoursOn") = 0
1887        and pGenData(g,"HoursOff") and pGenData(g,"minDT") > 0.999)..
1888     sum(AT$(ord(AT) < (pGenData(g,"minDT") - pGenData(g,"HoursOff") + 1)),
1889         sum((q,d,t)$mapTS(q,d,t,AT), isOn(g,q,d,t,AT,y))) =e= 0;
1890   
1891  * Rolling minimum down-time: every shutdown must be followed by minDT consecutive off hours.
1892  eMinDownRolling(g,AT2,y)$(fDispatchMode and fApplyMUDT and fApplyMinGenCommitment and MinGenPoint(g) and pGenData(g,"minDT") > 0.999
1893        and ord(AT2) > (pGenData(g,"minDT") - pGenData(g,"HoursOff") + 1)$pGenData(g,"HoursOff")
1894        and ord(AT2) < (card(AT2) - pGenData(g,"minDT") + 1))..
1895     sum(AT$((ord(AT) >= ord(AT2)) and (ord(AT) < ord(AT2) + pGenData(g,"minDT"))),
1896         sum((q,d,t)$mapTS(q,d,t,AT), 1 - isOn(g,q,d,t,AT,y)))
1897        =g= pGenData(g,"minDT") * sum((q,d,t)$mapTS(q,d,t,AT2), isShutdown(g,q,d,t,AT2,y));
1898   
1899  * ------------------------------
1900  * Startup-cost translation
1901  * ------------------------------
1902  * Aggregate startup events per representative bucket by summing every chronological `AT` slot that belongs to (q,d,t).
1903  * The resulting cost is tied to the time slice so the variable-cost stack can weight it just like fuel and VOM.
1904  eStartupCostConstraint(g,q,d,t,y)$((fDispatchMode and fApplyMinGenCommitment and MinGenPoint(g) and fApplyStartupCost and FD(q,d,t)))..
1905     vStartupCost(g,q,d,t,y) =e= sum(AT$mapTS(q,d,t,AT), isStartup(g,q,d,t,AT,y)) * pGenData(g,"StUpCost");
1906   
1907  * ------------------------------
1908  * Dispatch-level ramping continuity
1909  * ------------------------------
1910   
1911  eRampDnLimit(g,q,d,t,y)$((Ramprate(g) and not sFirstHour(t) and fApplyRampConstraint and fDispatchMode=0) and FD(q,d,t))..
1912     sum(gfmap(g,f), vPwrOut(g,f,q,d,t-1,y)) - sum(gfmap(g,f), vPwrOut(g,f,q,d,t,y)) =l= vCap(g,y)*pGenData(g,"RampDnRate");
1913   
1914  eRampUpLimit(g,q,d,t,y)$((Ramprate(g) and not sFirstHour(t) and fApplyRampConstraint and fDispatchMode=0) and FD(q,d,t))..
1915     sum(gfmap(g,f), vPwrOut(g,f,q,d,t,y)) - sum(gfmap(g,f), vPwrOut(g,f,q,d,t-1,y)) =l= vCap(g,y)*pGenData(g,"RampUpRate");
1916   
1917  * Tie the chronological slot totals to the underlying hourly dispatch so that ramp limits can aggregate across AT.
1918  eRampContinuity(g,q,d,t,AT,y)$((Ramprate(g) and fApplyRampConstraint and fDispatchMode) and mapTS(q,d,t,AT))..
1919     sum(gfmap(g,f), vPwrOut(g,f,q,d,t,y)) =e= vPwrOutDispatch(g,q,d,t,AT,y);
1920   
1921  * Ensure ramp-up across consecutive AT slots respects the ramp rate plus any additional headroom from startups when min-gen constraints are active.
1922  eDispatchRampUpLimit(g,AT,y)$((not sFirstHourAT(AT) and Ramprate(g) and fApplyRampConstraint and fDispatchMode))..
1923     sum((q,d,t)$mapTS(q,d,t,AT), vPwrOutDispatch(g,q,d,t,AT,y))
1924     - sum((q,d,t)$mapTS(q,d,t,AT-1), vPwrOutDispatch(g,q,d,t,AT-1,y))
1925            =l= sum((q,d,t)$mapTS(q,d,t,AT), isStartup(g,q,d,t,AT,y))*pGenData(g,"Capacity")$(fApplyMinGenCommitment and MinGenPoint(g))
1926            + vCap(g,y)*pGenData(g,"RampUpRate");
1927   
1928  * Ensure ramp-down across slots respects ramp-down rates while allowing shutdowns to absorb faster decreases.
1929  eDispatchRampDownLimit(g,AT,y)$((not sFirstHourAT(AT) and Ramprate(g) and fApplyRampConstraint and fDispatchMode))..
1930     sum((q,d,t)$mapTS(q,d,t,AT-1), vPwrOutDispatch(g,q,d,t,AT-1,y))
1931     - sum((q,d,t)$mapTS(q,d,t,AT), vPwrOutDispatch(g,q,d,t,AT,y))
1932            =l= sum((q,d,t)$mapTS(q,d,t,AT), isShutdown(g,q,d,t,AT,y))*pGenData(g,"Capacity")$(fApplyMinGenCommitment and MinGenPoint(g))
1933            + vCap(g,y)*pGenData(g,"RampDnRate");
1934   
1935  * ------------------------------
1936  * Reserve equations
1937  * Enforces spinning and planning reserve requirements.
1938  * ------------------------------
1939  * Spinning reserve limit as a share of capacity
1940  eSpinningReserveLim(g,q,d,t,y)$((fApplyCountrySpinReserveConstraint or fApplySystemSpinReserveConstraint) and FD(q,d,t))..
1941     vSpinningReserve(g,q,d,t,y) =l= vCap(g,y)*pGenData(g,"ResLimShare");
1942   
1943  * Spinning reserve limit for VRE as a share of capacity adjusted for production profile
1944  eSpinningReserveLimVRE(gfmap(VRE,f),q,d,t,y)$((fApplyCountrySpinReserveConstraint or fApplySystemSpinReserveConstraint) and FD(q,d,t))..
1945      vSpinningReserve(VRE,q,d,t,y) =l= vCap(VRE,y)*pGenData(VRE,"ResLimShare")* pVREgenProfile(VRE,q,d,t);
1946   
1947  * This constraint increases solving time x3
1948  * Reserve constraints include interconnections as reserves too
1949  eSpinningReserveReqCountry(c,q,d,t,y)$((fApplyCountrySpinReserveConstraint) and FD(q,d,t))..
1950     sum((zcmap(z,c),gzmap(g,z)),vSpinningReserve(g,q,d,t,y))
1951   + vUnmetSpinningReserveCountry(c,q,d,t,y)
1952  * + sIntercoReserveContributionPct * sum((zcmap(z,c),sMapConnectedZonesDiffCountries(z2,z)), pTransferLimit(z2,z,q,y)
1953  *                                        + vNewTransmissionLine(z2,z,y)*symmax(pNewTransmission,z,z2,"CapacityPerLine")*fAllowTransferExpansion
1954  *                                        - vFlow(z2,z,q,d,t,y))
1955     =g= pSpinningReserveReqCountry(c,y) + sum((zcmap(z,c),gzmap(VRE_noROR,z),gfmap(VRE_noROR,f)), vPwrOut(VRE_noROR,f,q,d,t,y))*psVREForecastErrorPct;
1956   
1957  * System spinning reserve requirement
1958  eSpinningReserveReqSystem(q,d,t,y)$((fApplySystemSpinReserveConstraint) and FD(q,d,t))..
1959     sum(g, vSpinningReserve(g,q,d,t,y)) + vUnmetSpinningReserveSystem(q,d,t,y) =g= pSpinningReserveReqSystem(y) + sum(gfmap(VRE_noROR,f), vPwrOut(VRE_noROR,f,q,d,t,y))*psVREForecastErrorPct;
1960   
1961  * Planning reserve requirement at the country level
1962  ePlanningReserveReqCountry(c,y)$(fApplyPlanningReserveConstraint and pPlanningReserveMargin(c))..
1963     sum((zcmap(z,c),gzmap(g,z)), vCap(g,y)*pCapacityCredit(g,y))
1964   + vUnmetPlanningReserveCountry(c,y)
1965   + (sum((zcmap(z,c),sMapConnectedZonesDiffCountries(z2,z)), sum(q,pTransferLimit(z2,z,q,y))/card(q) + vNewTransmissionLine(z2,z,y)*max(pNewTransmission(z,z2,"CapacityPerLine"),pNewTransmission(z2,z,"CapacityPerLine"))*fAllowTransferExpansion))$fCountIntercoForReserves
1966     =g= (1+pPlanningReserveMargin(c))*smax((q,d,t), sum(zcmap(z,c), pDemandData(z,q,d,y,t)*pEnergyEfficiencyFactor(z,y)));
1967   
1968  * Planning reserve requirement at the system level
1969  ePlanningReserveReqSystem(y)$(fApplyPlanningReserveConstraint and sReserveMarginPct)..
1970     sum(g, vCap(g,y)*pCapacityCredit(g,y)) + vUnmetPlanningReserveSystem(y)
1971     =g= (1+sReserveMarginPct)*smax((q,d,t), sum(z, pDemandData(z,q,d,y,t)*pEnergyEfficiencyFactor(z,y)));
1972   
1973   
1974  * ------------------------------
1975  * Transfer equations
1976  * Limits internal flows and applies trade caps.
1977  * ------------------------------
1978  * Limits flow between zones to existing + expandable transmission capacity
1979  eTransferCapacityLimit(sTopology(z,z2),q,d,t,y)$FD(q,d,t)..
1980     vFlow(z,z2,q,d,t,y) =l= pTransferLimit(z,z2,q,y) + vNewTransmissionLine(z,z2,y)*max(pNewTransmission(z,z2,"CapacityPerLine"),pNewTransmission(z2,z,"CapacityPerLine"))*fAllowTransferExpansion;
1981   
1982  * Enforces minimum import flow into a zone when specified
1983  eMinImportRequirement(sTopology(z,z2),q,d,t,y)$(pMinImport(z2,z,y) and FD(q,d,t))..
1984     vFlow(z2,z,q,d,t,y) =g= pMinImport(z2,z,y);
1985   
1986  * Cumulative build-out of new transfer capacity over time
1987  eCumulativeTransferExpansion(sTopology(z,z2),y)$fAllowTransferExpansion..
1988     vNewTransmissionLine(z,z2,y) =e=  vNewTransmissionLine(z,z2,y-1) + vBuildTransmissionLine(z,z2,y);
1989   
1990  * Ensures symmetry in bidirectional transmission investment
1991  eSymmetricTransferBuild(sTopology(z,z2),y)$fAllowTransferExpansion..
1992     vBuildTransmissionLine(z,z2,y)  =e=  vBuildTransmissionLine(z2,z,y);
1993   
1994  * External trade
1995   
1996  * Caps total import energy based on annual demand and max external trade share
1997  eMaxAnnualImportShareEnergy(c,y)$fEnableExternalExchange..
1998     sum((zcmap(z,c),zext,q,d,t), vYearlyImportExternal(z,zext,q,d,t,y)*pHours(q,d,t)) =l=
1999     sum((zcmap(z,c),q,d,t), pDemandData(z,q,d,y,t)*pHours(q,d,t)*pEnergyEfficiencyFactor(z,y))*pMaxAnnualExternalTradeShare(y,c);
2000   
2001  * Caps total export energy based on annual demand and max external trade share
2002  eMaxAnnualExportShareEnergy(c,y)$fEnableExternalExchange..
2003     sum((zcmap(z,c),zext,q,d,t), vYearlyExportExternal(z,zext,q,d,t,y)*pHours(q,d,t)) =l=
2004     sum((zcmap(z,c),q,d,t), pDemandData(z,q,d,y,t)*pHours(q,d,t)*pEnergyEfficiencyFactor(z,y))*pMaxAnnualExternalTradeShare(y,c);
2005   
2006  * Limits hourly import energy as a share of hourly demand
2007  eMaxHourlyImportShareEnergy(c,q,d,t,y)$((sMaxHourlyImportExternalShare<1 and fEnableExternalExchange) and FD(q,d,t))..
2008     sum((zcmap(z,c), zext), vYearlyImportExternal(z,zext,q,d,t,y))  =l= sum(zcmap(z,c), pDemandData(z,q,d,y,t)*sMaxHourlyImportExternalShare * pEnergyEfficiencyFactor(z,y));
2009   
2010  * Limits hourly export energy as a share of hourly demand
2011  eMaxHourlyExportShareEnergy(c,q,d,t,y)$((sMaxHourlyExportExternalShare<1 and fEnableExternalExchange) and FD(q,d,t))..
2012     sum((zcmap(z,c), zext),vYearlyExportExternal(z,zext,q,d,t,y)) =l= sum(zcmap(z,c), pDemandData(z,q,d,y,t)*sMaxHourlyExportExternalShare * pEnergyEfficiencyFactor(z,y));
2013   
2014  * Caps import volume from an external zone to internal zone
2015  eExternalImportLimit(z,zext,q,d,t,y)$((fEnableExternalExchange) and FD(q,d,t))..
2016     vYearlyImportExternal(z,zext,q,d,t,y)=l= pExtTransferLimitIn(z,zext,q,y);
2017   
2018  * Caps export volume from internal zone to an external zone
2019  eExternalExportLimit(z,zext,q,d,t,y)$((fEnableExternalExchange) and FD(q,d,t))..
2020     vYearlyExportExternal(z,zext,q,d,t,y)=l= pExtTransferLimitOut(z,zext,q,y);
2021   
2022  * ------------------------------
2023  * Storage operations
2024  * Controls storage SOC, charging, and reserve support.
2025  * ------------------------------
2026  * Limits state of charge (SOC) by capacity
2027  eSOCUpperBound(st,q,d,t,y)$(fEnableStorage and FD(q,d,t))..
2028     vStorage(st,q,d,t,y) =l= vCapStor(st,y);
2029   
2030  * Prevents storage being used to meet reserves only
2031  eStorageCapMinConstraint(st,q,d,t,y)$(fEnableStorage and FD(q,d,t))..
2032     vCapStor(st,y) =g= vCap(st,y);
2033   
2034  * Enforces fixed storage duration when StorageDuration parameter is specified
2035  eStorageFixedDuration(st,y)$(fEnableStorage and pStorageData(st,"StorageDuration"))..
2036     vCapStor(st,y) =e= vCap(st,y) * pStorageData(st,"StorageDuration");
2037   
2038  * Charging power ≤ power capacity
2039  eChargeCapacityLimit(st,q,d,t,y)$(fEnableStorage and FD(q,d,t))..
2040     vStorInj(st,q,d,t,y) =l= vCap(st,y);
2041   
2042  * Charge cap from PV-following storage logic
2043  eChargeLimitWithPVProfile(stp,q,d,t,y)$(fEnableStorage and FD(q,d,t))..
2044     vStorInj(stp,q,d,t,y) =l= sum(gsmap(so,stp), vCap(so,y)*pStoPVProfile(so,q,d,t));
2045   
2046  * Max rate of charge decrease (ramp-down)
2047  eChargeRampDownLimit(st,q,d,t,y)$((not sFirstHour(t) and fEnableStorage and fApplyRampConstraint) and FD(q,d,t))..
2048     vStorInj(st,q,d,t-1,y) - vStorInj(st,q,d,t,y) =l= pGenData(st,'RampDnRate')*vCap(st,y);
2049   
2050  * Max rate of charge increase (ramp-up)
2051  eChargeRampUpLimit(st,q,d,t,y)$((not sFirstHour(t) and fEnableStorage and fApplyRampConstraint) and FD(q,d,t))..
2052     vStorInj(st,q,d,t,y) - vStorInj(st,q,d,t-1,y) =l= pGenData(st,'RampUpRate')*vCap(st,y);
2053   
2054  * Defines net charge as output - input
2055  eNetChargeBalance(st,q,d,t,y)$(fEnableStorage and FD(q,d,t))..
2056     vStorNet(st,q,d,t,y) =e= sum(gfmap(st,f), vPwrOut(st,f,q,d,t,y)) - vStorInj(st,q,d,t,y);
2057   
2058  * Anchors the first hour of the representative-day cycle to the configured capacity share (dispatch mode only).
2059  eStorageSOCInitDispatch(st,g,q,d,t,y)$((fDispatchMode and sFirstHour(t) and sFirstDay(d) and fEnableStorage) and FD(q,d,t))..
2060     vStorage(st,q,d,t,y) =e= vCapStor(st,y)*pStorageInitShare;
2061   
2062  * Forces the last hour of the cycle to return to the same capacity share, ensuring the wrap-around matches the initial value (dispatch mode only).
2063  eStorageSOCFinalDispatch(st,q,d,t,y)$((fDispatchMode and sLastHour(t) and sLastDay(d) and fEnableStorage) and FD(q,d,t))..
2064     vStorage(st,q,d,t,y) =e= vCapStor(st,y)*pStorageInitShare;
2065   
2066  * Representative-day mode: enforce SOC recursion on the first hour without cross-day anchoring.
2067  eStateOfChargeInitRep(st,q,d,t,y)$((not fDispatchMode) and fEnableStorage and sFirstHour(t) and FD(q,d,t))..
2068     vStorage(st,q,d,t,y) =e= pStorageData(st,"Efficiency")*vStorInj(st,q,d,t,y) - sum(gfmap(st,f), vPwrOut(st,f,q,d,t,y));
2069   
2070  * eStorageHourTransition rolls storage state forward using the previous chronological hour (t-1), assuming storage is enabled.
2071  eStorageHourTransition(st,q,d,t,y)$((not sFirstHour(t) and fEnableStorage) and FD(q,d,t))..
2072     vStorage(st,q,d,t,y) =e= vStorage(st,q,d,t-1,y)
2073        + pStorageData(st,"Efficiency")*vStorInj(st,q,d,t,y)
2074        - sum(gfmap(st,f), vPwrOut(st,f,q,d,t,y));
2075   
2076  * Dispatch mode: wrap the first hour of each day to the previous chronological hour (AT-1); no wrap in representative-day mode.
2077  eStorageDayWrap(st,q,d,t,AT,y)$((fDispatchMode and fEnableStorage and sFirstHour(t) and mapTS(q,d,t,AT) and ord(AT) > 1) and FD(q,d,t))..
2078     vStorage(st,q,d,t,y) =e= sum((q2,d2,t2)$mapTS(q2,d2,t2,AT-1), vStorage(st,q2,d2,t2,y))
2079        + pStorageData(st,"Efficiency")*vStorInj(st,q,d,t,y)
2080        - sum(gfmap(st,f), vPwrOut(st,f,q,d,t,y));
2081   
2082  * Ensures SOC level can cover spinning reserve
2083  eSOCSupportsReserve(st,q,d,t,y)$((fEnableStorage) and FD(q,d,t))..
2084     vSpinningReserve(st,q,d,t,y) =l= vStorage(st,q,d,t,y);
2085   
2086  * In dispatch mode, the day-wrap constraint ties each day’s first hour to AT-1, preventing artificial SOC jumps.
2087  * In representative-day mode the wrap is skipped, avoiding cross-day links that do not exist in that chronology.
2088   
2089  * Ensures energy conservation over the full representative day: total input × efficiency = total output
2090  * eDailyStorageEnergyBalance(st,q,d,y)$(fEnableStorage)..
2091  *   pStorageData(st,"efficiency") * sum(t, vStorInj(st,q,d,t,y)) =e= sum((gfmap(st,f),t), vPwrOut(st,f,q,d,t,y));
2092   
2093  * ------------------------------
2094  * CSP-specific equations
2095  * Constrains CSP thermal and storage operations.
2096  * ------------------------------
2097   
2098  * Limits CSP storage level to installed storage capacity.
2099  eCSPStorageCapacityLimit(cs,q,d,t,y)$(fEnableCSP and FD(q,d,t))..
2100     vStorage(cs,q,d,t,y) =l= vCapStor(cs,y);
2101   
2102  * Limits CSP storage injection to thermal energy output * efficiency. Prevents unrealistic injection behavior.
2103  eCSPStorageInjectionLimit(cs,q,d,t,y)$(fEnableCSP and FD(q,d,t))..
2104     vStorInj(cs,q,d,t,y) =l= vThermalOut(cs,q,d,t,y)*pCSPData(cs,"Thermal Field","Efficiency");
2105   
2106  * Prevents CSP storage injection exceeding installed capacity.
2107  eCSPStorageInjectionCap(cs,q,d,t,y)$(fEnableCSP and FD(q,d,t))..
2108     vStorInj(cs,q,d,t,y) =l= vCapStor(cs,y);
2109   
2110  *Limits thermal energy output to installed thermal field capacity * hourly solar profile.
2111  eCSPThermalOutputLimit(cs,q,d,t,y)$(fEnableCSP and FD(q,d,t))..
2112     vThermalOut(cs,q,d,t,y) =l= vCapTherm(cs,y)*pCSPProfile(cs,q,d,t);
2113   
2114  * Balances CSP thermal output, storage in/out, and generator dispatch.
2115  eCSPPowerBalance(cs,q,d,t,y)$(fEnableCSP and FD(q,d,t))..
2116     vThermalOut(cs,q,d,t,y)*pCSPData(cs,"Thermal Field","Efficiency")
2117   - vStorInj(cs,q,d,t,y) + vStorOut(cs,q,d,t,y)*pCSPData(cs,"Storage","Efficiency")
2118     =e= sum(gfmap(cs,f), vPwrOut(cs,f,q,d,t,y));
2119   
2120  * Tracks CSP storage state of charge across time (except for first hour).
2121  eCSPStorageEnergyBalance(cs,q,d,t,y)$((not sFirstHour(t) and fEnableCSP) and FD(q,d,t))..
2122     vStorage(cs,q,d,t,y) =e= vStorage(cs,q,d,t-1,y) + vStorInj(cs,q,d,t,y) - vStorOut(cs,q,d,t,y);
2123   
2124  * Initializes CSP storage balance for the first hour of the day.
2125  eCSPStorageInitialBalance(cs,q,d,sFirstHour(t),y)$((fEnableCSP) and FD(q,d,t))..
2126     vStorage(cs,q,d,t,y) =e= vStorInj(cs,q,d,t,y) - vStorOut(cs,q,d,t,y);
2127   
2128  * ------------------------------
2129  * Storage capacity evolution
2130  * Tracks storage energy capacity builds/retirements.
2131  * ------------------------------
2132   
2133  * TODO: Why is it defined for all generators (g) rather than just storage (st)?
2134  * Limits total installed storage capacity to predefined technical data from pStorageData and CSP-related capacity from pCSPData. Only applies if storage is included (fEnableStorage).
2135  eCapacityStorLimit(g,y)$fEnableStorage..
2136     vCapStor(g,y) =l= pStorageData(g,"CapacityMWh") + pCSPData(g,"Storage","CapacityMWh");
2137   
2138  * Sets initial year’s storage capacity equal to existing capacity (if online) plus new builds minus retirements.
2139  eCapStorBalance(g, sStartYear(y))..
2140      vCapStor(g,y) =e= pStorageData(g,"CapacityMWh")$(eg(g) and (pGenData(g,"StYr") <= sStartYear.val)) + vBuildStor(g,y) - vRetireStor(g,y);
2141   
2142  * Tracks annual storage capacity changes for existing generators (EGs): previous year’s capacity + builds − retirements.
2143  eCapStorAnnualUpdateEG(eg,y)$(not sStartYear(y) and fEnableStorage)..
2144     vCapStor(eg,y) =e= vCapStor(eg,y-1) + vBuildStor(eg,y) - vRetireStor(eg,y);
2145   
2146  * Tracks annual storage capacity for new generators (NGs): previous year’s capacity + builds. Assumes no retirement.
2147  eCapStorAnnualUpdateNG(ng,y)$(not sStartYear(y) and fEnableStorage)..
2148     vCapStor(ng,y) =e= vCapStor(ng,y-1) + vBuildStor(ng,y);
2149   
2150  * Sets initial capacity for new generators at start year equal to build amount. Applies only in the first year.
2151  eCapStorInitialNG(ng,sStartYear(y))$fEnableStorage..
2152     vCapStor(ng,y) =e= vBuildStor(ng,y);
2153   
2154  eBuildStorNew(eg)$((pGenData(eg,"StYr") > sStartYear.val) and fEnableStorage)..
2155     sum(y, vBuildStor(eg,y)) =l= pStorageData(eg,"CapacityMWh");
2156   
2157  * ------------------------------
2158  * CSP thermal capacity limits
2159  * Tracks CSP thermal field builds and limits.
2160  * ------------------------------
2161  eCapacityThermLimit(g,y)$fEnableCSP..
2162     vCapTherm(g,y) =l= pCSPData(g,"Thermal Field","CapacityMWh");
2163   
2164  eCapThermBalance1(eg,y)$(not sStartYear(y) and fEnableCSP)..
2165     vCapTherm(eg,y) =e= vCapTherm(eg,y-1) + vBuildTherm(eg,y) - vRetireTherm(eg,y);
2166   
2167  eCapThermBalance2(ng,y)$(not sStartYear(y) and fEnableCSP)..
2168     vCapTherm(ng,y) =e= vCapTherm(ng,y-1) + vBuildTherm(ng,y);
2169   
2170  eCapThermBalance3(ng,sStartYear(y))$fEnableCSP..
2171     vCapTherm(ng,y) =e= vBuildTherm(ng,y);
2172   
2173  eBuildThermNew(eg)$((pGenData(eg,"StYr") > sStartYear.val) and fEnableCSP)..
2174     sum(y, vBuildTherm(eg,y)) =l= pCSPData(eg,"Thermal Field","CapacityMWh");
2175   
2176  * ------------------------------
2177  * Capital budget constraint
2178  * Enforces the global investment ceiling.
2179  * ------------------------------
2180   
2181  eCapitalConstraint$fApplyCapitalConstraint..
2182     sum(y, pRR(y)*pWeightYear(y)*sum(ng, pCRF(ng)*vCap(ng,y)*pGenData(ng,"Capex"))) =l= ssMaxCapitalInvestmentInvestment*1e3;
2183   
2184  * ------------------------------
2185  * Emissions related equations
2186  * Computes CO₂ emissions and applies caps/backstops.
2187  * ------------------------------
2188   
2189  eZonalEmissions(z,y)..
2190     vZonalEmissions(z,y) =e=
2191     sum((gzmap(g,z),gfmap(g,f),q,d,t), vPwrOut(g,f,q,d,t,y)*pHeatRate(g,f)*pFuelCarbonContent(f)*pHours(q,d,t));
2192   
2193  eEmissionsCountry(c,y)$fApplyCountryCo2Constraint..
2194     sum(zcmap(z,c), vZonalEmissions(z,y))-vYearlyCO2backstop(c,y)=l= pEmissionsCountry(c,y);
2195   
2196  eTotalEmissions(y)..
2197      sum(z, vZonalEmissions(z,y))=e= vTotalEmissions(y);
2198   
2199  eTotalEmissionsConstraint(y)$fApplySystemCo2Constraint..
2200      vTotalEmissions(y)-vYearlySysCO2backstop(y) =l= pEmissionsTotal(y);
2201   
