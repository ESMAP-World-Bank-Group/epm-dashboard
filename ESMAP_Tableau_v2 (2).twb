      <column caption='Attribute' datatype='string' name='[Calculation_1938799658917277697]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [Calculation_1938799658917425155]&#13;&#10;WHEN &apos;pTransmissionCapacity&apos; THEN &apos;Annual Transmission Capacity: MW&apos;&#13;&#10;WHEN &apos;pCapacityTechFuel&apos; THEN &apos;Capacity: MW&apos;&#13;&#10;WHEN &apos;pEmissionsZone&apos; THEN &apos;Emissions: MtCO2&apos;&#13;&#10;WHEN &apos;pEnergyTechFuel&apos; THEN &apos;Energy: GWh&apos;&#13;&#10;WHEN &apos;pCosts&apos; THEN [uni]&#13;&#10;WHEN &apos;pNewCapacityTechFuel&apos; THEN &apos;New Capacity: MW&apos;&#13;&#10;WHEN &apos;pEnergyBalance&apos; THEN [uni]&#13;&#10;WHEN &apos;pCostsSystem&apos; THEN [uni]&#13;&#10;WHEN &apos;pReserveSpinningPlantZone&apos; THEN &apos;Spinning Reserve: GWh&apos;&#13;&#10;END' />
