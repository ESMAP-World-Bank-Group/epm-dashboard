 154  * Input data parameters
 155  Parameter
 156  * Generator data
 157     pTechFuel(tech<,f<,pTechFuelHeader)                    'Technology-fuel specifications'
 158     pGenDataInput(*,z,tech,f,pGenDataInputHeader)       'Generator data from Excel input'
 159     pGenDataInputDefault(z,tech,f,pGenDataInputHeader)    'Default generator data by zone/tech/fuel'
 160     pGenDataInputGeneric(tech,f,pGenDataInputHeader)     'Generic generator data by tech/fuel'
 161     pCapexTrajectoriesDefault(z,tech,f,y)                 'Default CAPEX trajectories'
 162     pCapexTrajectoriesGeneric(tech,f,y)                   'Generic CAPEX trajectories by tech/fuel'
 163     pCapexTrajectories(g,y)                               'Generator CAPEX trajectories'
 164     pAvailabilityGeneric(tech,f)                        'Generic availability factors by tech/fuel'
 165     pAvailabilityDefault(z,tech,f,q)                      'Default availability factors'
 166   
 167  * Storage data
 168     pStorageDataInput(*,z,tech,f,pStorageDataHeader)          'Storage unit specifications'
 169     pStorageDataInputDefault(z,tech,f,pStorageDataHeader)     'Default storage data by zone/tech/fuel'
 170     pStorageDataInputGeneric(tech,f,pStorageDataHeader)       'Generic storage data by tech/fuel'
