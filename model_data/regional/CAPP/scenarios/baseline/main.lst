 118   
 119  * Core domain sets loaded from external files
 120  Sets
 121     g        'Generators or technology-fuel types'
 122     f        'Fuels'
 123     tech     'Technologies'
 124     y        'Planning years'
 125     q        'Seasonal blocks (quarters)'
 126     d        'Representative days'
 127     t        'Hours of day'
 128     z        'System zones'
 129     c        'Countries'
 130     zext     'External trading zones'
 131     AT       'Full-year hourly chronology' /AT1*AT8760/
 132     pGenDataInputHeader 'Generator data input headers'
 133     pSettingsHeader
 134     pStorageDataHeader                                        'Storage data headers'
 135     pCSPDataHeader       'CSP data headers'                 / 'Storage', 'Thermal Field' /
 136     pTransmissionHeader  'Transmission data headers'
 137     pH2Header            'Hydrogen data headers'
 138     pTechFuelHeader      'Technology-fuel data headers'  / 'HourlyVariation', 'RETechnology', 'FuelIndex' /
 139     pe                   'Peak/energy tags for demand'      / 'peak', 'energy' /
 140     hh                   'Hydrogen production units'
 141  ;
 142   
 143   
 144  * Relationship sets derived from the inputs
 145  Sets
 146     zcmap(z<,c<) 'Zone-to-country mapping'
 147     gmap(g,z,tech,f) 'Generator-to-zone/technology/fuel mapping'
 148     sRelevant(d) 'Days where minimum generation limits apply'
 149     mapTS(q,d,t,AT) 'Mapping from season/day/hour tuples to chronological AT index'
 150  ;
 151   
 152  alias (z,z2), (g,g1,g2);
 153   
 154  * Input data parameters
 155  Parameter
 156  * Generator data
 157     pTechFuel(tech<,f<,pTechFuelHeader)                    'Technology-fuel specifications'
 158     pGenDataInput(*,z,tech,f,pGenDataInputHeader)       'Generator data from Excel input'
 159     pGenDataInputDefault(z,tech,f,pGenDataInputHeader)    'Default generator data by zone/tech/fuel'
 160     pGenDataInputGeneric(tech,f,pGenDataInputHeader)     'Generic generator data by tech/fuel'
 161     pCapexTrajectoriesDefault(z,tech,f,y)                 'Default CAPEX trajectories'
 162     pCapexTrajectoriesGeneric(tech,f,y)                   'Generic CAPEX trajectories by tech/fuel'
 163     pCapexTrajectories(g,y)                               'Generator CAPEX trajectories'
 164     pAvailabilityGeneric(tech,f)                        'Generic availability factors by tech/fuel'
 165     pAvailabilityDefault(z,tech,f,q)                      'Default availability factors'
 166   
 167  * Storage data
 168     pStorageDataInput(*,z,tech,f,pStorageDataHeader)          'Storage unit specifications'
 169     pStorageDataInputDefault(z,tech,f,pStorageDataHeader)     'Default storage data by zone/tech/fuel'
 170     pStorageDataInputGeneric(tech,f,pStorageDataHeader)       'Generic storage data by tech/fuel'
 171   
 172  * CSP and technology data
 173     pCSPData(g,pCSPDataHeader,pStorageDataHeader)           'Concentrated solar power data'
 174   
 175  * Fuel data
 176     pFuelCarbonContent(f)                                 'Carbon content by fuel (tCO2/MMBtu)'
 177     pMaxFuellimit(c,f,y)                                  'Fuel limit in MMBTU*1e6 (million) by country'
 178     pFuelPrice(c,f,y)                                     'Fuel price forecasts'
 179   
 180  * Storage and transmission
 181     pNewTransmission(z,z2,pTransmissionHeader)           'New transmission line specifications'
 182   
 183  * Trade parameters
 184     pTradePrice(zext,q,d,y,t)                             'External trade prices'
 185     pMaxAnnualExternalTradeShare(y,c)                     'Maximum trade share by country'
 186   
 187  * Demand parameters
 188     pDemandProfile(z,q,d,t)                               'Normalized demand profiles'
 189     pDemandForecast(z,pe,y)                               'Peak/energy demand forecasts (MW/GWh)'
 190     pDemandData(z,q,d,y,t)                                'Hourly load curves'
 191   
 192  * Emissions and carbon
 193     pEmissionsCountry(c,y)                                'Country emission limits (tons)'
 194     pEmissionsTotal(y)                                    'System-wide emission limits (tons)'
 195     pCarbonPrice(y)                                       'Carbon price (USD/ton CO2)'
 196   
 197  * Time and transfer parameters
 198     pHours(q<,d<,t<)                                      'Hours mapping'
 199     pDays(q)                                              'Number of days represented by each period'
 200     pTransferLimit(z,z2,q,y)                              'Inter-zonal transfer limits'
 201     pMinImport(z2,z,y)                                    'Minimum import requirements'
 202     pLossFactorInternal(z,z2,y)                           'Transmission loss factors'
 203   
 204  * VRE and availability
 205     pVREProfile(z,tech,q,d,t)                             'VRE generation profiles by site'
 206     pVREgenProfile(g,q,d,t)                               'VRE generation profiles by plant'
 207     pAvailabilityInput(g,q)                              'Seasonal availability factors (from CSV, no year)'
 208     pAvailability(g,y,q)                                  'Seasonal availability factors (expanded to years)'
 209     pEvolutionAvailability(g,y)                           'Year-dependent availability evolution factors'
 210   
 211  * Reserve requirements
 212     pSpinningReserveReqCountry(c,y)                       'Country spinning reserve requirements'
 213     pSpinningReserveReqSystem(y)                          'System spinning reserve requirements'
 214     pPlanningReserveMargin(c)                             'Planning reserve margins'
 215   
 216  * Other parameters
 217     pSettings(pSettingsHeader)                            'Model settings and penalties'
 218     pEnergyEfficiencyFactor(z,y)                          'Energy efficiency adjustment factors'
 219     pExtTransferLimit(z,zext,q,*,y)                       'External transfer limits'
 220   
 221  * Hydrogen parameters
 222     pH2DataExcel(hh<,pH2Header)                           'Hydrogen data from Excel'
 223     pAvailabilityH2(hh,q)                                 'H2 plant availability'
 224     pFuelDataH2(f)                                        'Hydrogen fuel properties'
 225     pCapexTrajectoryH2(hh,y)                              'H2 CAPEX trajectories'
 226     pExternalH2(z,q,y)                                    'External H2 demand (MMBtu) to be met'
