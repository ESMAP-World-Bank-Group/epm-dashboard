2322   
2323  Sets
2324     H2status  'H2 generation plant status' / Existing, Candidate, Committed /
2325     eh(hh)           'existing hydrogen generation plants'
2326     nh(hh)           'new hydrogen generation plants'
2327     RampRateH2(hh)   'ramp rate constrained H2 generator blocks' // Ramprate takes out inflexible generators for a stronger formulation so that it runs faster
2328     dcH2(hh)         'candidate generators with capex trajectory'
2329     ndcH2(hh)        'candidate generators without capex trajectory'
2330     nRE(g)           'non RE generators'
2331     nVRE(g)          'non VRE generators'
2332     REH2(g)          'set of RE generators which are NOT VRE'
2333     nREH2(g)         'set of generators that are dont belong to subset REH2(g)'
2334     h2zmap(hh,z)
2335     sH2PwrIn(hh,q,d,t,y)
2336  ;
2337   
2338  Sets
2339     H2statusmap(hh,H2status) 'Hydrogen unit status'
2340  ;
2341   
2342  Parameters
2343      fEnableH2Production
2344     pCRFH2(hh)                       'Capital recovery factor'
2345     pCapexTrajectoriesH2(hh,y)       'CAPEX trajectories for hydrogen generation units'
2346     pVarCostH2(hh,y)                 'Variable cost - H2 production'
2347     pH2UnservedCost                  'Cost of external H2 unserved'
2348     pH2Data(hh,pH2Header)                    'Hydrogen production specifications'
2349  ;
2350   
2351  Positive Variables
2352     vCapH2(hh,y)                'total capacity in place accounting for legacy, new and retired plants (MW)'
2353     vBuildH2(hh,y)              'Build (MW)'
2354     vRetireH2(hh,y)             'Retire (MW)'
2355     vH2PwrIn(hh,q,d,t,y)        'Power drawn by H2 plants for H2 production in MW'
2356     vFuelH2(z,y)                'Annual H2 production in MMBTU'
2357     vAnnCapexH2(hh,y)           'Annualized CAPEX of H2 producing technologies'
2358     vPwrREH2(z,q,d,t,y)          'Generation from RE generators that goes to H2 production'
2359     vPwrREGrid(z,q,d,t,y)       'Generation from RE generators that goes to the grid'
2360     vREPwr2H2(g,f,q,d,t,y)       'Generation from RE generators that goes to H2 production'
2361     vREPwr2Grid(g,f,q,d,t,y)    'Generation from VRE generators that goes to the grid'
2362     vFuelH2Quarter(z,q,y)        'H2 fuel saved for H2 electricity generationon a quarterly basis'
2363     vUnmetExternalH2(z,q,y)        'mmBTU of external H2 demand that cant be met'
2364     vYearlyH2UnservedCost(z,y)   'Annual Cost of external H2 unserved in USD'
2365  ;
2366   
2367  Integer variable
2368     vBuiltCapVarH2(hh,y)
2369     vRetireCapVarH2(hh,y)
2370  ;
2371   
2372  Equations
2373      eH2UnservedCost(z,y)
2374      eCapBalanceH2(hh,y)
2375      eCapBalance1H2(hh,y)
2376      eCapBalance2H2
2377      eBuildNewH2(hh)
2378      eBuiltCapH2(hh,y)
2379      eRetireCapH2(hh,y)
2380      eMaxCF_H2(hh,q,y)
2381      eFuel_H2(c,q,y)
2382      eFuel_H2_2(c,z,y)
2383      eRampDnLimitH2(hh,q,d,t,y)
2384      eRampUpLimitH2(hh,q,d,t,y)
2385      eFuelLimitH2(c,f,y)
2386      eFuelLimitH2_2(c,f,y)
2387      eAnnCapexH2_1(hh,y)
2388      eAnnCapexH2(hh,y)
2389      eRE2H2(g,f,q,d,t,y)
2390      eRE2H2_2(z,q,d,t,y)
2391      eRE2H2_3(z,q,d,t,y)
2392      eRE2H2_4(z,q,d,t,y)
2393      eMaxH2PwrInjection(hh,q,d,t,y)
2394  ;
2395   
2396   
2397  * =============================
2398  * Hydrogen Contributions to Main Equations
2399  * =============================
2400   
2401  * --- Hydrogen Contribution to Yearly Cost ---
2402  Equation eYearlyTotalCost_H2Contribution;
2403   
2404  eYearlyTotalCost_H2Contribution(c,y)..
2405  *   vYearlyTotalCost(c,y) =e= vYearlyTotalCost(c,y)
2406      0 =e=
2407                            + sum(zcmap(z,c), vYearlyH2UnservedCost(z,y))$fEnableH2Production;
2408   
2409  * --- Hydrogen Contribution to Total Annualized CAPEX ---
2410  Equation eTotalAnnualizedCapex_H2Contribution;
2411   
2412  eTotalAnnualizedCapex_H2Contribution(z,y)..
2413  *   vAnnCapex(z,y) =e= vAnnCapex(z,y)
2414      0 =e=
2415                     + sum(h2zmap(ndcH2,z), pCRFH2(ndcH2)*vCapH2(ndcH2,y)*pH2Data(ndcH2,"Capex")*1e6)$fEnableH2Production
2416                     + sum(h2zmap(dcH2,z), vAnnCapexH2(dcH2,y))$fEnableH2Production;
2417   
2418  * --- Hydrogen Contribution to Yearly Variable O&M Cost ---
2419  Equation eYearlyVOMCost_H2Contribution;
2420   
2421  eYearlyVOMCost_H2Contribution(z,y)..
2422  *   vYearlyVOMCost(z,y) =e= vYearlyVOMCost(z,y)
2423      0 =e=
2424                           + sum((h2zmap(hh,z),q,d,t), pVarCostH2(hh,y)*pH2Data(hh,"Heatrate")*vH2PwrIn(hh,q,d,t,y)*pHours(q,d,t))$fEnableH2Production;
2425   
2426  * --- Hydrogen Unserved Demand Cost (can stay modular as-is) ---
2427  Equation eH2UnservedCost;
2428   
2429  eH2UnservedCost(z,y)..
2430     vYearlyH2UnservedCost(z,y) =e= sum(q, vUnmetExternalH2(z,q,y)) * pH2UnservedCost $fEnableH2Production;
2431   
2432  * --- Hydrogen Supply Contribution to Demand Balance ---
2433  Equation eSupply_H2Contribution;
2434   
2435  * TODO: Change that
2436  eSupply_H2Contribution(z,q,d,t,y)..
2437  *   vSupply(z,q,d,t,y) =e=vSupply(z,q,d,t,y)
2438  *        -sum((gzmap(g,z),gfmap(g,f)),vPwrOut(g,f,q,d,t,y))
2439      0 =e=
2440       + sum((gzmap(nRE,z),gfmap(nRE,f)),vPwrOut(nRE,f,q,d,t,y))$(fEnableH2Production)
2441       + vPwrREGrid(z,q,d,t,y)$fEnableH2Production;
2442   
2443  * =============================
2444  * Hydrogen Specific Equations
2445  * =============================
2446   
2447   
2448  * Total capacity of H2 plants at 1st year of optimization is equal to pre-existing capacity plus capacity being bulit minus retired capacity
2449  eCapBalanceH2(hh,sStartYear(y))$(fEnableH2Production)..
2450     vCapH2(hh,y) =e= pH2Data(hh,"Capacity")$(eh(hh) and (pH2Data(hh,"StYr") <= sStartYear.val))
2451                 + vBuildH2(hh,y) - vRetireH2(hh,y);
2452   
2453  * Total capacity of existing H2 palnts is equal to capacity over previous year plus capacity being built in current year minus retired capacity in current year
2454  *Checked
2455  eCapBalance1H2(eh,y)$(not sStartYear(y) and fEnableH2Production)..
2456     vCapH2(eh,y) =e= vCapH2(eh,y-1) + vBuildH2(eh,y) - vRetireH2(eh,y);
2457   
2458  * Total capacity of candidate H2 plants is equal to total capacity at previous year plus capacity being built in current year minus retired capacity in current year
2459  *Checked
2460  eCapBalance2H2(nh,y)$(not sStartYear(y) and fEnableH2Production)..
2461     vCapH2(nh,y) =e= vCapH2(nh,y-1) + vBuildH2(nh,y);
2462   
2463  * New H2 plants can be buuilt only after the StYr; the newly built capacity need to be less than declared capacity
2464  *Checked
2465  eBuildNewH2(eh)$(pH2Data(eh,"StYr") > sStartYear.val and fEnableH2Production)..
2466      sum(y, vBuildH2(eh,y)) =l= pH2Data(eh,"Capacity");
2467   
2468   
2469  * (Integer units ) Built capacity each year is equal to unit size
2470  *Checked
2471  eBuiltCapH2(nh,y)$(pH2Data(nh,"DescreteCap") and fEnableH2Production)..
2472     vBuildH2(nh,y) =e= pH2Data(nh,"UnitSize")*vBuiltCapVarH2(nh,y);
2473   
2474  * (Integer units ) Retired capacity each year is equal to unit size
2475  *Checked
2476  eRetireCapH2(eh,y)$(pH2Data(eh,"DescreteCap") and (y.val <= pH2Data(eh,"RetrYr")) and fEnableH2Production)..
2477     vRetireH2(eh,y) =e= pH2Data(eh,"UnitSize")*vRetireCapVarH2(eh,y);
2478   
2479  *  Maximum capacity factor of H2 production based on availability
2480  *Checked
2481  eMaxCF_H2(hh,q,y)$(fEnableH2Production)..
2482     sum((d,t), vH2PwrIn(hh,q,d,t,y)*pHours(q,d,t)) =l= pAvailabilityH2(hh,q)*vCapH2(hh,y)*sum((d,t), pHours(q,d,t));
2483   
2484  *       mmBTU of H2 produced
2485  eFuel_H2(c,q,y)$(fEnableH2Production)..
2486  *                   mmBTU            mmBTU                    mmBTU                                                                     -MWe-                Hr                mmBTU/MWhe
2487      sum(zcmap(z,c), pExternalH2(z,q,y)-vUnmetExternalH2(z,q,y)$pExternalH2(z,q,y)+vFuelH2Quarter(z,q,y)) =e= sum( (zcmap(z,c),h2zmap(hh,z), d,t), vH2PwrIn(hh,q,d,t,y)*pHours(q,d,t)*pH2Data(hh,"HeatRate"));
2488   
2489  eFuel_H2_2(c,z,y)$(fEnableH2Production)..
2490      sum((zcmap(z,c),q),vFuelH2Quarter(z,q,y)) =e=  sum(zcmap(z,c),vFuelH2(z,y));
2491   
2492  eMaxH2PwrInjection(hh,q,d,t,y)$fEnableH2Production..
2493      vH2PwrIn(hh,q,d,t,y)  =l= vCapH2(hh,y);
2494   
2495  * The amount of hydrogen fuel that can be used for electricity generation can not be more than the amount of H2 that was produced from VRE curtailment
2496  eFuelLimitH2(c,f,y)$(pFuelDataH2(f) and fEnableH2Production)..
2497     sum((zcmap(z,c)),  vFuel(z,f,y)) =e=  sum((zcmap(z,c)), vFuelH2(z,y));
2498   
2499   
2500  *When the H2 production flag is off don't account for H2 fuel
2501  eFuelLimitH2_2(c,f,y)$(pFuelDataH2(f) and fEnableH2Production=0)..
2502     sum((zcmap(z,c)),  vFuel(z,f,y)) =e=  0;
2503   
2504   
2505  eRampDnLimitH2(hh,q,d,t,y)$(RamprateH2(hh) and not sFirstHour(t) and fApplyRampConstraint and fEnableH2Production)..
2506      vH2PwrIn(hh,q,d,t-1,y) -  vH2PwrIn(hh,q,d,t,y) =l= vCapH2(hh,y)*pH2Data(hh,"RampDnRate");
2507   
2508  eRampUpLimitH2(hh,q,d,t,y)$(RamprateH2(hh) and not sFirstHour(t) and fApplyRampConstraint and fEnableH2Production)..
2509     vH2PwrIn(hh,q,d,t,y) -  vH2PwrIn(hh,q,d,t-1,y) =l= vCapH2(hh,y)*pH2Data(hh,"RampUpRate");
2510   
2511  *Calculation of Annualized CAPEX for electrolyzers
2512  eAnnCapexH2_1(dcH2,y)$(not sStartYear(y) and fEnableH2Production)..
2513     vAnnCapexH2(dcH2,y) =e= vAnnCapexH2(dcH2,y-1)
2514                       + vBuildH2(dcH2,y)*pH2Data(dcH2,"Capex")*pCapexTrajectoriesH2(dcH2,y)*pCRFH2(dcH2)*1e6;
2515   
2516  eAnnCapexH2(dcH2,sStartYear(y))$fEnableH2Production..
2517     vAnnCapexH2(dcH2,y) =e= vBuildH2(dcH2,y)*pH2Data(dcH2,"Capex")*pCapexTrajectoriesH2(dcH2,y)*pCRFH2(dcH2)*1e6;                                                                          ;
2518   
2519  eRE2H2_4(z,q,d,t,y)$fEnableH2Production..
2520    sum(h2zmap(hh,z),vH2PwrIn(hh,q,d,t,y))=e=vPwrREH2(z,q,d,t,y);
2521   
2522   
2523  eRE2H2_3(z,q,d,t,y)$fEnableH2Production..
2524   vPwrREH2(z,q,d,t,y) =e= sum((gfmap(RE,f),gzmap(RE,z)),vREPwr2H2(RE,f,q,d,t,y));
2525   
2526  eRE2H2_2(z,q,d,t,y)$fEnableH2Production..
2527  vPwrREGrid(z,q,d,t,y)=e=sum((gfmap(RE,f),gzmap(RE,z)),vREPwr2Grid(RE,f,q,d,t,y));
2528   
2529  eRE2H2(RE,f,q,d,t,y)$fEnableH2Production..
2530   vPwrOut(RE,f,q,d,t,y)=e=vREPwr2Grid(RE,f,q,d,t,y)+vREPwr2H2(RE,f,q,d,t,y);
2531   
2532  *For example equation below is deactivated when H2 is on and is replaced by eVREProfile2
2533   
2534  * =============================
2535  * Updating Hydrogen Model
2536  * =============================
2537   
2538   
2540  Model PA /
2541   
2542      eYearlyTotalCost_H2Contribution,
2543      eTotalAnnualizedCapex_H2Contribution,
2544      eYearlyVOMCost_H2Contribution,
2545      eH2UnservedCost,
2546      eSupply_H2Contribution
2547   
2548     vH2PwrIn(sH2PwrIn)
2549     eBuildNewH2
2550     eCapBalance1H2
2551     eCapBalance2H2
2552     eCapBalanceH2
2553     eBuiltCapH2
2554     eRetireCapH2
2555  *eDemSupplyH2
2556     eMaxCF_H2
2557     eFuel_H2
2558     eFuel_H2_2
2559     eRampDnLimitH2
2560     eRampUpLimitH2
2561     eFuelLimitH2
2562     eFuelLimitH2_2
2563  *eYearlyCurtailmentCost2
2564   
2565     eRE2H2
2566     eRE2H2_2
2567     eRE2H2_3
2568     eRE2H2_4
2569     eMaxH2PwrInjection
2570   
2571     eAnnCapexH2_1
2572     eAnnCapexH2
2573     /
2574  ;
2576   
2577  *-------------------------------------------------------------------------------------
2578  * Generate gfmap and others from pGenDataInput
2579  parameter gstatIndex(gstatus) / Existing 1, Candidate 3, Committed 2 /;
2580  parameter tstatIndex(tstatus) / Candidate 3, Committed 2 /;
2581   
2582  *H2 model parameter
2583  parameter H2statIndex(H2status) / Existing 1, Candidate 3, Committed 2 /;
2584   
2585   
2586  * Aggregate `gmap(g,z,tech,f)` over `tech` and `f` to get `gzmap(g,z)`,
2587  * which represents the mapping of generator `g` to zone `z`.
2588  gzmap(g,z) = sum((tech,f), gmap(g,z,tech,f));
2589   
2590  * Aggregate `gmap(g,z,tech,f)` over `tech` and `z` to get `gfmap(g,f)`,
2591  * which represents the mapping of generator `g` to fuel `f`.
2592  gfmap(g,f) = sum((tech,z), gmap(g,z,tech,f));
2593   
2594  * Compute `gprimf(g,f)`, which is similar to `gfmap(g,f)`,
2595  * aggregating over `tech` and `z` to represent the primary fuel mapping.
2596  gprimf(g,f) = sum((tech,z), gmap(g,z,tech,f));
2597   
2598  * Aggregate `gmap(g,z,tech,f)` over `z` and `f` to get `gtechmap(g,tech)`,
2599  * which represents the mapping of generator `g` to technology `tech`.
2600  gtechmap(g,tech) = sum((z,f), gmap(g,z,tech,f));
2601   
2602  * TODO: Update `gfmap(g,f)`, ensuring it includes additional mappings
2603  * based on `pGenDataInput(g,z,tech,f2,'fuel2')` when a condition is met.
2604  * gfmap(g,f) = gfmap(g,f) or sum((z,tech,f2), (pGenDataInput(g,z,tech,f2,'fuel2') = pTechFuel(tech,f,'FuelIndex')));
2605   
2606   
2607  * Map generator status from input data
2608  gstatusmap(g,gstatus) = sum((z,tech,f),pGenDataInput(g,z,tech,f,'status')=gstatIndex(gstatus));
2609   
2610   
2611  pHeatrate(gprimf(g,f)) = sum((z,tech), pGenDataInput(g,z,tech,f,"Heatrate"));
2612  pHeatrate(g,f2)$(gfmap(g,f2) and not gprimf(g,f2)) =
2613      sum((z,tech,f), pGenDataInput(g,z,tech,f,"Heatrate2")
2614  *  $(pGenDataInput(g,z,tech,f,"fuel2") = pTechFuel(tech,f2,'FuelIndex'))
2615      );
2616   
2617   
2618  pGenData(g,pGenDataInputHeader) = sum((z,tech,f),pGenDataInput(g,z,tech,f,pGenDataInputHeader));
2619   
2620  ***********************H2 model parameters***************************************************
2621   
2622  pH2Data(hh,pH2Header)=pH2DataExcel(hh,pH2Header);
2623  H2statusmap(hh,H2status) = pH2DataExcel(hh,'status')=H2statIndex(H2status);
2624  * TODO: Check is that works for H2
2625  * h2zmap(hh,z) = pH2DataExcel(hh,'Zone')=pZoneIndex(z);
2626  h2zmap(hh,z) = pH2DataExcel(hh,'Zone');
2627   
2628  *-------------------------------------------------------------------------------------
2629   
2630  *--- Parameter initialisation for same demand profile for all years
2631   
INCLUDE    /Users/lucas/Documents/World Bank/Projects/EPM_APPLIED/EPM_main/epm/generate_demand.gms
2633  **********************************************************************
2634  * ELECTRICITY PLANNING MODEL (EPM)
2635  * Developed at the World Bank
2636  **********************************************************************
2637  * Description:
2638  * This GAMS-based model is designed for electricity system planning,
2639  * incorporating capacity expansion, generation dispatch, and policy
2640  * constraints such as renewable energy targets, emissions reductions,
2641  * and market mechanisms.
2642  *
2643  * Author(s): ESMAP Modelling Team
2644  * Organization: World Bank
2645  * Version:
2646  * License: Creative Commons Zero v1.0 Universal
2647  *
2648  * Key Features:
2649  * - Optimization of electricity generation and capacity planning
2650  * - Inclusion of renewable energy integration and storage technologies
2651  * - Multi-period, multi-region modeling framework
2652  * - CO2 emissions constraints and policy instruments
2653  *
2654  * Notes:
2655  * - Ensure GAMS is installed before running this model.
2656  * - The model requires input data in .GDX or Excel format.
2657  *
2658  * Contact:
2659  * Claire Nicolas, cnicolas@worldbank.org
2660  **********************************************************************
2661   
2662  *--- Adjust peak and energy in case user selected same demand profile for all years
2663   
2664  Parameters
2665     pmax(z,y)
2666     pmin(z,y)
2667     pdiff(z,y)
2668     ptotalenergy(z,y)
2669     ptemp2(y)
2670     ptemp(y)
2671     pTempDemand(z,q,d,y,t)
2672  ;
2673   
2674  Variable
2675     pyval(z,q,d,y,t)
2676     divisor(z,y)
2677     obj
2678  ;
2679   
2680  divisor.lo(z,y) = card(q)*card(d)*card(t);
2681   
2682  Equation
2683     getDivisor(z,q,d,y,t)
2684     getArea(z,y)
2685     objFn
2686  ;
2687   
2688  getDivisor(z,q,d,y,t)..  pyval(z,q,d,y,t) =e=  [2*pdiff(z,y)/divisor(z,y) * (pmax(z,y) - pDemandProfile(z,q,d,t))]/sqr(pmax(z,y) - pmin(z,y));
2689  getArea(z,y)..           sum((q,d,t), pyval(z,q,d,y,t) * pHours(q,d,t)) =e=  pdiff(z,y);
2690  objFn..                  obj =e= sum((z,q,d,y,t), pyval(z,q,d,y,t));
2691   
2692  model demand / getDivisor, getArea, objFn /;
2693   
2694  * If using alt demand:
2695  if (pSettings("fUseSimplifiedDemand") = 1,
2696     pTempDemand(z,q,d,y,t) = pDemandProfile(z,q,d,t) * pDemandForecast(z,"Peak",y);
2697   
2698     pdiff(z,y) = ((pDemandForecast(z,"Energy",y)*1e3) - sum((q,d,t), pTempDemand(z,q,d,y,t)*pHours(q,d,t) )) ;
2699   
2700     pmax(z,y) = smax((q,d,t), pDemandProfile(z,q,d,t));
2701     pmin(z,y) = smin((q,d,t)$pDemandProfile(z,q,d,t), pDemandProfile(z,q,d,t));
2702  *   option limrow=1000; debugging
2703     Solve demand using nlp min obj;
2704   
2705     abort$(demand.modelstat<>1 and demand.modelstat<>2) 'Demand model not solved successfully';
2707     pDemandData(z,q,d,y,t) =  pTempDemand(z,q,d,y,t) + pyval.l(z,q,d,y,t);
2709     ptemp(y) = sum((z,q,d,t), pdemanddata(z,q,d,y,t)*pHours(q,d,t))/1000;
2710     ptemp2(y) = smax((q,d,t),sum(z, pdemanddata(z,q,d,y,t)));
2711  );
2712   
2713  ptotalenergy(z,y) =  sum((q,d,t), pdemanddata(z,q,d,y,t)*pHours(q,d,t))/1e3;
2714   
2715  *--- Part2: Start of initialisation of other parameters
2716   
2717  * Read main parameters from pSettings
2718   
2719  fEnableStorage                     = pSettings("fEnableStorage");
2720  fDispatchMode                      = pSettings("fDispatchMode");
2721   
2722  * --- Settings: Dispatch constraint switches
2723  fApplyMinGenCommitment      = pSettings("fApplyMinGenCommitment");
2724  fApplyStartupCost                  = pSettings("fApplyStartupCost");
2725  fApplyRampConstraint               = pSettings("fApplyRampConstraint");
2726  fApplyMUDT                       = pSettings("fApplyMUDT");
2727   
2728  * --- Settings: Economic parameters and penalties
2729  pDR                          = pSettings("DR");
2730  pWACC                        = pSettings("WACC");
2731  pVoLL                        = pSettings("VoLL");
2732  pPlanningReserveVoLL         = pSettings("ReserveVoLL");
2733  pSpinningReserveVoLL         = pSettings("SpinReserveVoLL");
2734  pSurplusPenalty              = pSettings("CostSurplus");
2735  pCostOfCurtailment           = pSettings("CostCurtail");
2736  pCostOfCO2backstop           = pSettings("CO2backstop");
2737  pH2UnservedCost              = pSettings("H2UnservedCost");
2738  ssMaxCapitalInvestmentInvestment = pSettings("sMaxCapitalInvestment") * 1e6;
2739   
2740  * --- Settings: Reserve requirements
2741  fApplyPlanningReserveConstraint    = pSettings("fApplyPlanningReserveConstraint");
2742  sReserveMarginPct                  = pSettings("sReserveMarginPct");
2743  fApplyCountrySpinReserveConstraint = pSettings("fApplyCountrySpinReserveConstraint");
2744  fApplySystemSpinReserveConstraint = pSettings("fApplySystemSpinReserveConstraint");
2745  psVREForecastErrorPct              = pSettings("sVREForecastErrorPct");
2746  sIntercoReserveContributionPct     = pSettings("sIntercoReserveContributionPct");
2747  fCountIntercoForReserves           = pSettings("fCountIntercoForReserves");
2748   
2749  * --- Settings: Policy and operational switches
2750  fApplyMinGenShareAllHours      = pSettings("fApplyMinGenShareAllHours");
2751  fApplyFuelConstraint               = pSettings("fApplyFuelConstraint");
2752  fApplyCapitalConstraint            = pSettings("fApplyCapitalConstraint");
2753  fEnableCSP                         = pSettings("fEnableCSP");
2754  fEnableCapacityExpansion           = pSettings("fEnableCapacityExpansion");
2755  pMinRE                             = pSettings("sMinRenewableSharePct");
2756  pMinsRenewableTargetYear           = pSettings("sRenewableTargetYear");
2757  fApplyCountryCo2Constraint         = pSettings("fApplyCountryCo2Constraint");
2758  fApplySystemCo2Constraint         = pSettings("fApplySystemCo2Constraint");
2759  fEnableCarbonPrice                     = pSettings("fEnableCarbonPrice");
2760  fEnableEnergyEfficiency           = pSettings("fEnableEnergyEfficiency");
2761   
2762   
2763  * --- Settings: Transmission and trade
2764  fEnableInternalExchange            = pSettings("fEnableInternalExchange");
2765  fRemoveInternalTransferLimit       = pSettings("fRemoveInternalTransferLimit");
2766  fAllowTransferExpansion            = pSettings("fAllowTransferExpansion");
2767  fAllowTransferExpansion            = fAllowTransferExpansion * fEnableCapacityExpansion;
2768   
2769  fEnableExternalExchange            = pSettings("fEnableExternalExchange");
2770  sMaxHourlyImportExternalShare                 = pSettings("sMaxHourlyImportExternalShare");
2771  sMaxHourlyExportExternalShare                 = pSettings("sMaxHourlyExportExternalShare");
2772   
2773  * --- Settings: Hydrogen options
2774  fEnableCapexTrajectoryH2           = pSettings("fEnableCapexTrajectoryH2");
2775  fEnableH2Production               = pSettings("fEnableH2Production");
2776   
2777  * ----------------------------
2778  singleton set sFinalYear(y);
2779  scalar TimeHorizon;
2780   
2781  sStartYear(y) = y.first;
2782  sFinalYear(y) = y.last;
2783  TimeHorizon = sFinalYear.val - sStartYear.val + 1;
2784  sFirstHour(t) = t.first;
2785  sLastHour(t) = t.last;
2786  sFirstDay(d) = d.first;
2787   
2788  sFirstHourAT(AT) = AT.first;
2789   
2790  sLastDay(d) = yes$(ord(d) = card(d));
2791   
2792  * ------------------------------
2793  * Commitment initialization defaults
2794  * Consolidates initial ON/OFF values so a single section shows which units start online.
2795  * ------------------------------
2796  pInitialOnStart(g) = 0;
2797  pInitialOnStart(g)$pGenData(g,"InitialOn") = pGenData(g,"InitialOn");
2798   
2799   
2800  pStorageInitShare = pSettings("InitialSOCforBattery");
2801  if (pStorageInitShare < 0,
2802     pStorageInitShare = 0.5;
2803  );
2804   
2805  FD(q,d,t) = yes;
2806  if (fDispatchMode,
2807     FD(q,d,t)$(ord(q) eq 2 and ord(d) > 28) = no;
2808     FD(q,d,t)$((ord(q) eq 4 or ord(q) eq 6 or ord(q) eq 9 or ord(q) eq 11) and ord(d) > 30) = no;
2809  );
2810   
2811  * Identify which generators carry minimum-generation commitments so that startup cost logic can focus on them.
2812  MinGenPoint(g) = yes$(pGenData(g,"MinGenCommitment") > 0);
2813   
2814  * ------------------------------
2815   
2816   
2817  * Set external transfer limits to zero if exports are not allowed
2818  pExtTransferLimit(z,zext,q,"Import",y)$(not fEnableExternalExchange)  = 0 ;
2819  pExtTransferLimit(z,zext,q,"Export",y)$(not fEnableExternalExchange)  = 0 ;
2820   
2821  * Assign import and export transfer limits only if exports are allowed
2822  pExtTransferLimitIn(z,zext,q,y)$fEnableExternalExchange   = pExtTransferLimit(z,zext,q,"Import",y) ;
2823  pExtTransferLimitOut(z,zext,q,y)$fEnableExternalExchange  = pExtTransferLimit(z,zext,q,"Export",y) ;
2824   
2825  * Define `Zt(z)` to check if total demand in a zone `z` is zero
2826  Zt(z) = sum((q,d,y,t),pDemandData(z,q,d,y,t)) = 0;
2827  * Define `Zd(z)` as the complement of `Zt(z)`, indicating zones with demand
2828  Zd(z) = not Zt(z);
2829   
2830   
2831  * Aggregate storage data from the 4-index pStorageDataInput to pStorageData(g,header)
2832  pStorageData(g,pStorageDataHeader) = sum((z,tech,f), pStorageDataInput(g,z,tech,f,pStorageDataHeader));
2833   
2834  * gsmap is used for linked storage (PV+storage pairs)
2835  * gsmap(g2,g) means storage g is linked to generator g2
2836  * For standalone storage (empty "Linked plant"), gsmap remains empty
2837  * Note: If linked storage is needed, the "Linked plant" column should contain the generator name
2838  gsmap(g2,g) = no;
2839   
2840  * Identify candidate generators (`ng(g)`) based on their status in `gstatusmap`
2841  ng(g)  = gstatusmap(g,'candidate') or gstatusmap(g,'committed');
2842   
2843  * Define existing generators (`eg(g)`) as those that are not candidates, include comitted
2844  eg(g)  = not ng(g);
2845   
2846  * Identify variable renewable energy (VRE) generators (`vre(g)`) based on hourly variation data
2847  vre(g) = sum((gtechmap(g,tech),f)$pTechFuel(tech,f,'HourlyVariation'),1);
2848   
2849  * Identify renewable energy (RE) generators (`re(g)`) based on RE technology classification
2850  re(g)  = sum((gtechmap(g,tech),f)$pTechFuel(tech,f,'RETechnology'),1);
2851   
2852  * Identify concentrated solar power (CSP) technologies
2853  cs(g)  = gtechmap(g,"CSPPlant");
2854   
2855  * Identify PV with storage technologies
2856  so(g)  = gtechmap(g,"PVwSTO");
2857   
2858  * Identify solar thermal with PV (`STOPV`)
2859  stp(g) = gtechmap(g,"STOPV");
2860   
2861  * Identify storage technologies
2862  stg(g) = gtechmap(g,"Storage");
2863   
2864  * Define a general storage category (`st(g)`) as either `STOPV` or `STORAGE`
2865  st(g)  = gtechmap(g,"STOPV") or gtechmap(g,"Storage");
2866   
2867  * Define generators with capex trajectory data
2868  dc(g)  = sum(y, pCapexTrajectories(g,y));
2869   
2870  * Define generators without capex trajectory data
2871  ndc(g) = not dc(g);
2872   
2873  * Identify run-of-river hydro generators (`ror(g)`)
2874  ror(g) = gtechmap(g,"ROR");
2875   
2876  * Identify VRE generators excluding run-of-river hydro (`VRE_noROR(g)`)
2877  VRE_noROR(g) = vre(g) and not ror(g);
2878   
2879  * Define ramp-down rate for generators
2880  RampRate(g) = pGenData(g,"RampDnRate");
2881   
2882  * Map zones (`z`) to fuels (`f`) based on generator-fuel assignments (`gzmap` and `gfmap`)
2883  zfmap(z,f) = sum((gzmap(g,z),gfmap(g,f)), 1);
2884   
2885  * H2 model specific sets
2886  nh(hh)  = H2statusmap(hh,'candidate');
2887  eh(hh)  = not nh(hh);
2888  RampRateH2(hh)= pH2Data(hh,"RampDnRate");
2889  dcH2(hh)  = sum(y, pCapexTrajectoryH2(hh,y));
2890  ndcH2(hh) = not dcH2(hh);
2891  nRE(g) = not re(g);
2892  nVRE(g)=not VRE(g);
2893  REH2(g)= sum((gtechmap(g,tech),f)$pTechFuel(tech,f,'RETechnology'),1) - sum((gtechmap(g,tech),f)$pTechFuel(tech,f,'HourlyVariation'),1);
2894  nREH2(g)= not REH2(g);
2895   
2896  *-------------------------------------------------------------------
2897  * TOPOLOGY DEFINITION
2898  *-------------------------------------------------------------------
2899   
2900  * Defining sTopology based on existing, committed and candidate transmission lines
2901  sTopology(z,z2) = sum((q,y),pTransferLimit(z,z2,q,y)) + sum(pTransmissionHeader,pNewTransmission(z,z2,pTransmissionHeader)) + sum(pTransmissionHeader,pNewTransmission(z2,z,pTransmissionHeader));
2902   
2903  * If not running in interconnected mode, set network to 0
2904  sTopology(z,z2)$(not fEnableInternalExchange) = no;
2905   
2906  * if ignore transfer limit, set limits to high value
2907  pTransferLimit(sTopology,q,y)$fRemoveInternalTransferLimit = inf;
2908   
2909  * Default life for transmission lines
2910  pNewTransmission(sTopology,"Life")$(pNewTransmission(sTopology,"Life")=0 and fAllowTransferExpansion) = 30;
2911   
2912  * Map transmission status from input data
2913  tstatusmap(sTopology(z,z2),tstatus) = (pNewTransmission(z,z2, 'status')=tstatIndex(tstatus)) + (pNewTransmission(z2,z, 'status')=tstatIndex(tstatus));
2914   
2915  * Identify candidate generators (`ng(g)`) based on their status in `gstatusmap`
2916  commtransmission(sTopology(z,z2))  = tstatusmap(z,z2,'committed');
2917   
2918  *-------------------------------------------------------------------
2919  * CAPACITY CREDIT
2920  *-------------------------------------------------------------------
2921   
2922  * Identify the system peak demand for each year based on the highest total demand across all zones, times, and demand segments
2923  pFindSysPeak(y)     = smax((t,d,q), sum(z, pDemandData(z,q,d,y,t)));
2924   
2925  * Identify hours that are close to the peak demand for capacity credit calculations
2926  pAllHours(q,d,y,t)  = 1$(abs(sum(z,pDemandData(z,q,d,y,t))/pFindSysPeak(y) - 1)<pSettings("sPeakLoadProximityThreshold"));
2927   
2928  * Default capacity credit for all generators is set to 1
2929  pCapacityCredit(g,y)= 1;
2930   
2931  * Protect against unintended changes while modifying `pVREgenProfile` with `pVREProfile` data
2932  pVREgenProfile(VRE,q,d,t)$(not(pVREgenProfile(VRE,q,d,t))) = sum((z,tech)$(gzmap(VRE,z) and gtechmap(VRE,tech)),pVREProfile(z,tech,q,d,t));
2933   
2934  * Set capacity credit for VRE based on predefined values or calculated generation-weighted availability
2935  pCapacityCredit(VRE,y) =  Sum((z,q,d,t)$gzmap(VRE,z),Sum(f$gfmap(VRE,f),pVREgenProfile(VRE,q,d,t)) * pAllHours(q,d,y,t)) * (Sum((z,f,q,d,t)$(gfmap(VRE,f) and gzmap(VRE,z) ),pVREgenProfile(VRE,q,d,t))/sum((q,d,t),1));
2936   
2937  * Compute capacity credit for run-of-river hydro as an availability-weighted average
2938  pCapacityCredit(ROR,y) =  sum(q,pAvailability(ROR,y,q)*sum((d,t),pHours(q,d,t)))/sum((q,d,t),pHours(q,d,t));
2939   
2940  * Compute CSP and PV with storage generation profiles
2941  pCSPProfile(cs,q,d,t)    = sum((z,tech)$(gtechmap(cs,tech) and gzmap(cs,z)), pVREProfile(z,tech,q,d,t));
2942  pStoPVProfile(so,q,d,t)  =  sum((z,tech)$(gtechmap(so,tech) and gzmap(so,z)), pVREProfile(z,tech,q,d,t));
2943   
2944  * H2 model parameters
2945  pCapexTrajectoriesH2(hh,y) =1;
2946  pCapexTrajectoriesH2(dch2,y)$fEnableCapexTrajectoryH2 = pCapexTrajectoryH2(dcH2,y);
2947   
2948  *-------------------------------------------------------------------
2949  * Cost of capital
2950  *-------------------------------------------------------------------
2951   
2952  * Set the weight of the start year to 1.0
2953  pWeightYear(sStartYear) = 1.0;
2954  * Compute weight for each year as the difference from the previous year's cumulative weight
2955  pWeightYear(y)$(not sStartYear(y)) = y.val - sum(sameas(y2+1,y), y2.val) ;
2956   
2957  * Compute the present value discounting factor considering mid-period adjustments
2958  pRR(y) = 1.0;
2959  pRR(y)$(ord(y)>1) = 1/((1+pDR)**(sum(y2$(ord(y2)<ord(y)),pWeightYear(y2))-1 + sum(sameas(y2,y), pWeightYear(y2)/2))) ;
2960   
2961  *-------------------------------------------------------------------
2962  * Parameter Processing
2963  *-------------------------------------------------------------------
2964  pLossFactorInternal(z2,z,y)$(pLossFactorInternal(z,z2,y) and not pLossFactorInternal(z2,z,y)) = pLossFactorInternal(z,z2,y);
2965   
2966  pEnergyEfficiencyFactor(z,y)$(not fEnableEnergyEfficiency) = 1;
2967  pEnergyEfficiencyFactor(z,y)$(pEnergyEfficiencyFactor(z,y)=0) = 1;
2968   
2969  pVOMCost(gfmap(g,f),y) = pGenData(g,"VOM")
2970                         + pStorageData(g, "VOMMWh")
2971                         + pCSPData(g, "Storage", "VOMMWh")
2972                         + pCSPData(g, "Thermal Field", "VOMMWh");
2973   
2974  pFuelCost(g,f,y)$(gfmap(g,f)) = sum((gzmap(g,z),zcmap(z,c)),pFuelPrice(c,f,y)*pHeatRate(g,f));
2975  pVarCost(g,f,y)$(gfmap(g,f)) = pFuelCost(g,f,y) + pVOMCost(g,f,y);
2976  pVarCostH2(hh,y) = pH2Data(hh,"VOM");
2977   
2978  * pCRF refers to the Capital Recovery Factor, which is used to calculate the annualized cost of capital for a project.
2979  pCRF(g)$pGenData(g,'Life') = pWACC / (1 - (1 / ( (1 + pWACC)**pGenData(g,'Life'))));
2980  pCRFH2(hh)$pH2Data(hh,'Life') = pWACC / (1 - (1 / ( (1 + pWACC)**pH2Data(hh,'Life'))));
2981  pCRFsst(st)$pGenData(st,'Life') = pWACC / (1 - (1 / ( (1 + pWACC)**pGenData(st,'Life'))));
2982  pCRFcst(cs)$pGenData(cs,'Life') = pWACC / (1 - (1 / ( (1 + pWACC)**pGenData(cs,'Life'))));
2983  pCRFcth(cs)$pGenData(cs,'Life') = pWACC / (1 - (1 / ( (1 + pWACC)**pGenData(cs,'Life'))));
2984   
2985  * Defines which connected zones belong to different countries.
2986  sMapConnectedZonesDiffCountries(sTopology(z,z2)) = sum(c$(zcmap(z,c) and zcmap(z2,c)), 1) = 0;
2987   
2988  *** Simple bounds
2989   
2990  * Set upper limit for generation capacity based on predefined data
2991  vCap.up(g,y) = pGenData(g,"Capacity");
2992   
2993  * Fix the build decision variable to zero for existing generation projects (started before or at the model start year)
2994  vBuild.fx(eg,y)$(pGenData(eg,"StYr") <= sStartYear.val) = 0;
2995   
2996  * Set the upper limit for new generation builds per year, accounting for the annual build limit and year weighting
2997  * Exclude committed generators - they use Capacity directly, not BuildLimitperYear
2998  vBuild.up(ng,y)$(not gstatusmap(ng,'committed')) = pGenData(ng,"BuildLimitperYear")*pWeightYear(y);
2999   
3000  * Force committed generators (status=2) to be built at their start year.
3001  * Unlike candidates, committed generators are not optional - they must be built.
3002  * They remain in ng(g) so their CAPEX is included in total cost (unlike existing generators).
3003  * Note: BuildLimitperYear is ignored for committed generators - full capacity is built at StYr.
3004  vBuild.lo(ng,y)$(gstatusmap(ng,'committed') and (pGenData(ng,"StYr") = y.val)) = pGenData(ng,"Capacity");
3005  vBuild.up(ng,y)$(gstatusmap(ng,'committed') and (pGenData(ng,"StYr") = y.val)) = pGenData(ng,"Capacity");
3006   
3007  * Define the upper limit for additional transmission capacity, subject to high transfer allowance
3008  vNewTransmissionLine.up(sTopology(z,z2),y)$fAllowTransferExpansion = max(pNewTransmission(z,z2,"MaximumNumOfLines"),pNewTransmission(z2,z,"MaximumNumOfLines"));
3009   
3010  sAdditionalTransfer(sTopology(z,z2),y) = yes;
3011  sAdditionalTransfer(sTopology(z,z2),y) $((y.val < pNewTransmission(z,z2,"EarliestEntry")) or (y.val < pNewTransmission(z2,z,"EarliestEntry"))) = no;
3012   
3013  * Fix
3014  vNewTransmissionLine.fx(commtransmission(z,z2),y)$((max(pNewTransmission(z,z2,"EarliestEntry"),pNewTransmission(z2,z,"EarliestEntry")) <= y.val) and fAllowTransferExpansion) = max(pNewTransmission(z,z2,"MaximumNumOfLines"),pNewTransmission(z2,z,"MaximumNumOfLines"));
3015  vNewTransmissionLine.fx(commtransmission(z,z2),y)$(not sAdditionalTransfer(z,z2,y) and fAllowTransferExpansion) = 0;
3016   
3017  * Compute bounds
3018  vBuildTransmissionLine.lo(sTopology(z,z2),y) = max(0,vNewTransmissionLine.lo(z,z2,y) - vNewTransmissionLine.up(z,z2,y-1));
3019  vBuildTransmissionLine.up(sTopology(z,z2),y) = max(0,vNewTransmissionLine.up(z,z2,y) - vNewTransmissionLine.lo(z,z2,y-1));
3020   
3021  * Fix the storage build variable to zero if the project started before the model start year and storage is included
3022  vBuildStor.fx(eg,y)$(pGenData(eg,"StYr") <= sStartYear.val and fEnableStorage) = 0;
3023   
3024  * Fix the thermal build variable to zero if the project started before the model start year and CSP (Concentrated Solar Power) is included
3025  vBuildTherm.fx(eg,y)$(pGenData(eg,"StYr") <= sStartYear.val and fEnableCSP) = 0;
3026   
3027  * Disable all capacity expansion decisions when flag is off
3028  if (fEnableCapacityExpansion = 0,
3029     vBuild.fx(g,y)            = 0;
3030     vBuiltCapVar.fx(g,y)      = 0;
3031     vBuildStor.fx(g,y)        = 0;
3032     vBuildTherm.fx(g,y)       = 0;
3033     vBuildTransmissionLine.fx(z,z2,y) = 0;
3034     vNewTransmissionLine.fx(z,z2,y)   = 0;
3035     vBuildH2.fx(hh,y)         = 0;
3036     vBuiltCapVarH2.fx(hh,y)   = 0;
3037  );
3038   
3039  *-------------------------------------------------------------------
3040  * Fixed conditions
3041  *-------------------------------------------------------------------
3042   
3043   
3044  ********************* Load a previously saved solution**********************************************************
3045   
3046  * Load a previously saved solution from the specified path (if LOADSOLPATH is defined)
3047  * This solution contains the .l (level) values of capacity-related variables from a previous run
3049   
3050  ********************* Equations for generation capacity**********************************************************
3051  * Fix capacity to zero for generation projects that have not yet started in a given year
3052  vCap.fx(g,y)$(pGenData(g,"StYr") > y.val) = 0;
3053   
3054  * Set the fixed capacity for existing generation projects at the start year, if they were commissioned before the model start year
3055  vCap.fx(eg,sStartYear)$(pGenData(eg,"StYr") < sStartYear.val) = pGenData(eg,"Capacity");
3056   
3057  * Set fixed capacity for generation projects in years where they are within their operational period
3058  vCap.fx(eg,y)$((pGenData(eg,"StYr") <= y.val) and (pGenData(eg,"StYr") >= sStartYear.val)) = pGenData(eg,"Capacity");
3059   
3060  * Retire capacity by setting it to zero in the year of retirement
3061  vCap.fx(eg,y)$(pGenData(eg,"RetrYr") and (pGenData(eg,"RetrYr") <= y.val)) = 0;
3062   
3063  * Set the initial thermal capacity for CSP plants at the model start year, if commissioned before that year
3064  vCapTherm.fx(eg,sStartYear)$(pGenData(eg,"StYr") < sStartYear.val) = pCSPData(eg,"Thermal Field","CapacityMWh");
3065   
3066  * Set the initial storage capacity at the model start year, considering both CSP and standalone storage units
3067  vCapStor.fx(eg,sStartYear)$(pGenData(eg,"StYr") < sStartYear.val) = pCSPData(eg,"Storage","CapacityMWh") + pStorageData(eg,"CapacityMWh");
3068   
3069  * Prevent decommissioning of storage hours from existing storage when economic retirement is disabled
3070  vCapStor.fx(eg,y)$((pSettings("fEnableEconomicRetirement") = 0) and (pGenData(eg,"StYr") <= y.val) and (pGenData(eg,"RetrYr") >= y.val)) = pStorageData(eg,"CapacityMWh");
3071   
3072  * Fix the retirement variable to zero, meaning no unit is retired by default unless specified otherwise
3073  vRetire.fx(ng,y) = 0;
3074   
3075  * Ensure plants with a lifetime of 99 years (considered effectively infinite) are not retired
3076  vRetire.fx(eg,y)$(pGenData(eg,"Life") = 99) = 0;
3077   
3078  * Ensure capacity remains unchanged when economic retirement is disabled and the plant is still within its operational lifetime
3079  vCap.fx(eg,y)$((pSettings("fEnableEconomicRetirement") = 0 and pGenData(eg,"StYr") < y.val) and (pGenData(eg,"RetrYr") >= y.val)) = pGenData(eg,"Capacity");
3080   
3081  * Prevent thermal capacity from appearing in years before the commissioning date
3082  vCapTherm.fx(ng,y)$(pGenData(ng,"StYr") > y.val) = 0;
3083   
3084  * Prevent storage capacity from appearing in years before the commissioning date
3085  vCapStor.fx(ng,y)$(pGenData(ng,"StYr") > y.val) = 0;
3086   
3087  * Ensure storage capacity is set to zero if storage is not included in the scenario
3088  vCapStor.fx(ng,y)$(not fEnableStorage) = 0;
3089   
3090   
3091  ********************* Equations for hydrogen production**********************************************************
3092  *Maximum capacity is equal to "Capacity"
3093  vCapH2.up(hh,y) = pH2Data(hh,"Capacity");
3094   
3095  *No new capacity can be built for existing generators
3096  vBuildH2.fx(eh,y)$(pH2Data(eh,"StYr") <= sStartYear.val) = 0;
3097   
3098  *The new capacity for new generators can not exceed the annual limit
3099  vBuildH2.up(nh,y) = pH2Data(nh,"BuildLimitperYear")*pWeightYear(y);
3100   
3101  *Electrolyzers can not operate at days with zero demand (applicable to dispatch model)
3102  vH2PwrIn.fx(hh,q,d,t,y)$(sum(z,pDemandData(z,q,d,y,t))  =0)   =0;
3103   
3104  *The maximum power drawn for H2 production can't be more than the Capacity of the electrolyzer
3105  vH2PwrIn.up(hh,q,d,t,y)  =pH2Data(hh,"Capacity");
3106   
3107   
3108  vCapH2.fx(hh,y)$(pH2Data(hh,"StYr") > y.val)=0;
3109  vCapH2.fx(eh,sStartYear)$(pH2Data(eh,"StYr") < sStartYear.val) = pH2Data(eh,"Capacity");
3110  vCapH2.fx(eh,y)$((pH2Data(eh,"StYr") <= y.val) and (pH2Data(eh,"StYr") >= sStartYear.val)) = pH2Data(eh,"Capacity");
3111  vCapH2.fx(eh,y)$(pH2Data(eh,"RetrYr") and (pH2Data(eh,"RetrYr") <= y.val)) = 0;
3112   
3113  vRetireH2.fx(nh,y) = 0;
3114  vRetireH2.fx(eh,y)$(pH2Data(eh,"Life") = 99) = 0;
3115   
3116  vCapH2.fx(eh,y)$((pSettings("fEnableEconomicRetirement") = 0 and pH2Data(eh,"StYr") < y.val) and (pH2Data(eh,"RetrYr") >= y.val)) = pH2Data(eh,"Capacity");
3117   
3118  sH2PwrIn(hh,q,d,t,y) = yes;
3119   
3120  vREPwr2H2.fx(nRE,f,q,d,t,y)=0;
3121  vREPwr2Grid.fx(nRE,f,q,d,t,y)=0;
3122   
3123  *******************************************************************************************************************
3124   
3125  sPwrOut(gfmap(g,f),q,d,t,y) = yes;
3126  sPwrOut(gfmap(st,f),q,d,t,y)$(not fEnableStorage) = yes;
3127   
3128  * If price based export is not allowed, set to 0
3129  sExportPrice(z,zext,q,d,t,y)$(fEnableExternalExchange) = yes;
3130  sExportPrice(z,zext,q,d,t,y)$(not fEnableExternalExchange) = no;
3131   
3132  * If price based import is not allowed, set to 0
3133  sImportPrice(z,zext,q,d,t,y)$(fEnableExternalExchange) = yes;
3134  sImportPrice(z,zext,q,d,t,y)$(not fEnableExternalExchange) = no;
3135   
3136  vYearlyImportExternal.up(z,zext,q,d,t,y)$fEnableExternalExchange = pExtTransferLimitIn(z,zext,q,y);
3137  vYearlyExportExternal.up(z,zext,q,d,t,y)$fEnableExternalExchange = pExtTransferLimitOut(z,zext,q,y);
3138   
3139  * Do not allow imports and exports for a zone without import/export prices
3140  sExportPrice(z,zext,q,d,t,y)$(pTradePrice(zext,q,d,y,t)= 0) = no;
3141  sImportPrice(z,zext,q,d,t,y)$(pTradePrice(zext,q,d,y,t)= 0) = no;
3142   
3143  * Define the flow of electricity between zones
3144  sFlow(z,z2,q,d,t,y)$(sTopology(z,z2)) = yes;
3145   
3146  * Define spinning reserve constraints based on the settings for zonal and system spinning reserves
3147  sSpinningReserve(g,q,d,t,y)$((fApplyCountrySpinReserveConstraint or fApplySystemSpinReserveConstraint) ) = yes;
3148   
3149  *To avoid bugs when there is no candidate transmission expansion line
3150  pNewTransmission(z,z2,"EarliestEntry")$(not fAllowTransferExpansion) = 2500;
3151   
3152  *-------------------------------------------------------------------------------------
3153  * Ensure that variables fixed (`.fx`) at specific values remain unchanged during the solve process
3154  PA.HoldFixed=1;
3155   
3156  * Declare a file object `fmipopt` and set its name dynamically based on the modeltype
3157  file fmipopt / cplex.opt /;
3158  * Check if the set `mipopt` contains any elements (i.e., if modeltype options exist)
3159  if (card(mipopt),
3160   put fmipopt;
3161  * Loop over each entry in `mipopt` and write its text content to the file
3162   loop(mipline, put mipopt.te(mipline) /);
3163   putclose;
3164  );
3165   
3166  * Enable the modeltype to read an external modeltype option file
3167  PA.optfile = 1;
3168   
3169   
3170  * ############## SOLVE ##############
3171  * SOLVEMODE == 2 solves as usual
3172  * SOLVEMODE == 1 solves as usual but generates a savepoint file at the end
3173  * SOLVEMODE == 0 uses a savepoint file to skip the solve (This speeds up development of post solve features)
3174   
3177   
3178   
3180  *  Solve model as usual
3181     Solve PA using RMIP minimizing vNPVcost;
3182  *  Abort if model was not solved successfully
3183     abort$(not (PA.modelstat=1 or PA.modelstat=8)) 'ABORT: no feasible solution found.', PA.modelstat;
3185   
3186  *  Export model data only when debugging is enabled
3188  * ####################################
3189   
3190  * Include the external report file specified by `%REPORT_FILE%`
3191   
3194   
INCLUDE    /Users/lucas/Documents/World Bank/Projects/EPM_APPLIED/EPM_main/epm/generate_report.gms
3196  **********************************************************************
3197  * ELECTRICITY PLANNING MODEL (EPM)
3198  * Developed at the World Bank
3199  **********************************************************************
3200  * Description:
3201  * This GAMS-based model is designed for electricity system planning,
3202  * incorporating capacity expansion, generation dispatch, and policy
3203  * constraints such as renewable energy targets, emissions reductions,
3204  * and market mechanisms.
3205  *
3206  * Author(s): ESMAP Modelling Team
3207  * Organization: World Bank
3208  * Version:
3209  * License: Creative Commons Zero v1.0 Universal
3210  *
3211  * Key Features:
3212  * - Optimization of electricity generation and capacity planning
3213  * - Inclusion of renewable energy integration and storage technologies
3214  * - Multi-period, multi-region modeling framework
3215  * - CO2 emissions constraints and policy instruments
3216  *
3217  * Notes:
3218  * - Ensure GAMS is installed before running this model.
3219  * - The model requires input data in .GDX or Excel format.
3220  *
3221  * Contact:
3222  * Claire Nicolas, cnicolas@worldbank.org
3223  **********************************************************************
3224   
3225   
3227  * Report
3228   
3229  set sumhdr /
3230    "Investment costs: $m",
3231    "Fixed O&M: $m",
3232    "Variable O&M: $m",
3233    "Startup costs: $m",
3234    "Fuel costs: $m",
3235    "Transmission costs: $m",
3236    "Spinning reserve costs: $m",
3237    "Unmet demand costs: $m",
3238    "Unmet country spinning reserve costs: $m",
3239    "Unmet country planning reserve costs: $m",
3240    "Unmet country CO2 backstop cost: $m",
3241    "Unmet system planning reserve costs: $m",
3242    "Unmet system spinning reserve costs: $m",
3243    "Unmet system CO2 backstop cost: $m",
3244    "Excess generation: $m",
3245    "VRE curtailment: $m",
3246    "Import costs with external zones: $m",
3247    "Export revenues with external zones: $m",
3248    "Import costs with internal zones: $m",
3249    "Export revenues with internal zones: $m",
3250    "Trade shared benefits: $m",
3251    "Carbon costs: $m",
3252    "NPV of system cost: $m"
3253  /;
3254   
3255  * Set of demand-related summary labels
3256  set dshdr /
3257    "Demand: GWh",
3258    "Electricity demand for H2 production: GWh",
3259    "Total Demand (Including P to H2): GWh",
3260    "Total production: GWh",
3261    "Unmet demand: GWh",
3262    "Surplus generation: GWh",
3263    "Imports exchange: GWh",
3264    "Exports exchange: GWh",
3265    "Net interchange: GWh",
3266    "Net interchange Ratio: GWh"
3267  /;
3268   
3269  * H2-specific
3270  set dsH2hdr /
3271    "Electricity demand for H2 production: GWh",
3272    "Total H2 Production: mmBTU",
3273    "External Demand of H2: mmBTU",
3274    "Unmet External Demand of H2: mmBTU",
3275    "H2 produced for power production: mmBTU"
3276  /;
3277   
3278  set zgmap(z,g); option zgmap<gzmap;
3279  set zH2map(z,hh); option zH2map<h2zmap;
3280  set isExternal / Internal, External /;
3281   
3282  set capexComponent /
3283    Generation,
3284    StorageEnergy,
3285    CSPThermalField,
3286    CSPStorage,
3287    Hydrogen,
3288    Transmission
3289  /;
3290   
3291  set capexComponentPlant(capexComponent) /
3292    Generation,
3293    StorageEnergy,
3294    CSPThermalField,
3295    CSPStorage
3296  /;
3297   
3298  set genCostCmp /
3299    "Investment costs: $m",
3300    "Fixed O&M: $m",
3301    "Variable Cost: $m"
3302  /;
3303   
3304  set fEnergyBalance /
3305    "UnmetDemand",
3306    "Surplus",
3307    "Imports",
3308    "Imports External",
3309    "Exports",
3310    "Exports External"
3311  /;
