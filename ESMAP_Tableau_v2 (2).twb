            <column caption='Filter out' datatype='boolean' name='[Calculation_1938799658916077568]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='NOT (&#13;&#10;    CONTAINS([Path], &quot;Dispatch&quot;)&#13;&#10;    OR CONTAINS([Path], &quot;pPrice.csv&quot;)&#13;&#10;    OR CONTAINS([Path], &quot;pCostsPlant.csv&quot;)&#13;&#10;    OR CONTAINS([Path], &quot;pGeneratorTechFuel.csv&quot;)&#13;&#10;    OR CONTAINS([Path], &quot;input_scenarios.csv&quot;)&#13;&#10;    OR CONTAINS([Path], &quot;solver_metrics.csv&quot;)&#13;&#10;    OR CONTAINS([Path], &quot;summary.csv&quot;)&#13;&#10;    OR CONTAINS([Path], &quot;summary_generators.csv&quot;)&#13;&#10;    OR CONTAINS([Path], &quot;pCapacityPlant.csv&quot;)&#13;&#10;    OR CONTAINS([Path], &quot;pCapexInvestmentComponent.csv&quot;)&#13;&#10;    OR CONTAINS([Path], &quot;pDemandEnergyZone.csv&quot;)&#13;&#10;    OR CONTAINS([Path], &quot;pDemandPeakZone.csv&quot;)&#13;&#10;    OR CONTAINS([Path], &quot;pEmissionsIntensityZone.csv&quot;)&#13;&#10;    OR CONTAINS([Path], &quot;pEnergyPlant.csv&quot;)&#13;&#10;    OR CONTAINS([Path], &quot;pFuelCosts.csv&quot;)&#13;&#10;    OR CONTAINS([Path], &quot;pInterconUtilization.csv&quot;)&#13;&#10;    OR CONTAINS([Path], &quot;pNewCapacityPlant.csv&quot;)&#13;&#10;    OR CONTAINS([Path], &quot;pPlantAnnualLCOE.csv&quot;)&#13;&#10;    OR CONTAINS([Path], &quot;pUtilizationPlant.csv&quot;)&#13;&#10;    OR CONTAINS([Path], &quot;pNewTransmissionCapacity.csv&quot;)&#13;&#10;    OR CONTAINS([Path], &quot;pCostsCountryPerMWh.csv&quot;)&#13;&#10;    OR CONTAINS([Path], &quot;pCostsSystemPerMWh.csv&quot;)&#13;&#10;    OR CONTAINS([Path], &quot;pEnergyTechFuelComplete.csv&quot;)&#13;&#10;    OR CONTAINS([Path], &quot;pSettings.csv&quot;)&#13;&#10;    OR CONTAINS([Path], &quot;pYearlyCostsCountryPerMWh.csv&quot;)&#13;&#10;    OR CONTAINS([Path], &quot;pCongestionShare.csv&quot;)&#13;&#10;    OR CONTAINS([Path], &quot;pCostsZonePerMWh.csv&quot;)&#13;&#10;    OR CONTAINS([Path], &quot;pCostsPerMWh.csv&quot;)&#13;&#10;    OR CONTAINS([Path], &quot;pCostsPerMWh.csv&quot;)&#13;&#10;    OR CONTAINS([Path], &quot;pInterchange.csv&quot;)&#13;&#10;    OR CONTAINS([Path], &quot;pZoneCountry.csv&quot;)&#13;&#10;    OR CONTAINS([Path], &quot;pUtilizationTechFuel.csv&quot;)&#13;&#10;    OR CONTAINS([Path], &quot;Merged&quot;)&#13;&#10;    OR CONTAINS([Path], &quot;Cumulated&quot;)&#13;&#10;    OR CONTAINS([Path], &quot;pReserveSpinningTechFuel.csv&quot;)&#13;&#10;    OR CONTAINS([Path], &quot;DiscountedWeighted&quot;)&#13;&#10;&#13;&#10;)' />
            </column>
            <column caption='Attribute' datatype='string' name='[Calculation_1938799658917277697]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [Calculation_1938799658917425155]&#13;&#10;WHEN &apos;pTransmissionCapacity&apos; THEN &apos;Annual Transmission Capacity: MW&apos;&#13;&#10;WHEN &apos;pCapacityTechFuel&apos; THEN &apos;Capacity: MW&apos;&#13;&#10;WHEN &apos;pEmissionsZone&apos; THEN &apos;Emissions: MtCO2&apos;&#13;&#10;WHEN &apos;pEnergyTechFuel&apos; THEN &apos;Energy: GWh&apos;&#13;&#10;WHEN &apos;pCosts&apos; THEN [uni]&#13;&#10;WHEN &apos;pNewCapacityTechFuel&apos; THEN &apos;New Capacity: MW&apos;&#13;&#10;WHEN &apos;pEnergyBalance&apos; THEN [uni]&#13;&#10;WHEN &apos;pCostsSystem&apos; THEN [uni]&#13;&#10;WHEN &apos;pReserveSpinningPlantZone&apos; THEN &apos;Spinning Reserve: GWh&apos;&#13;&#10;END' />
