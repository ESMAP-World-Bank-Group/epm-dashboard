                <alias key='&quot;NewCapacityTechFuelCumulated&quot;' value='New Capacity Cumulative (MW)' />
                <alias key='&quot;ReserveSpinningTechFuel&quot;' value='Reserve (GWh)' />
                <alias key='&quot;Costs&quot;' value='Costs (m USD)' />
                <alias key='&quot;DiscountedWeightedCostsCumulated&quot;' value='Discounted Costs Cumulated (m USD)' />
                <alias key='&quot;CostsPerMWh&quot;' value='Generation Costs (USD/MWh)' />
              </aliases>
            </column>
            <column caption='Aggregation level' datatype='string' name='[Parameter 4]' param-domain-type='list' role='measure' type='nominal' value='&quot;Zone&quot;'>
              <calculation class='tableau' formula='&quot;Zone&quot;' />
