    <worksheet name='Zones_sheet'>
      <table>
        <view>
          <datasources>
            <datasource caption='pTechFuelMerged' name='federated.1658zy81lz2h3u1gu0hna1hkm2gh' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Reference scenario' datatype='string' name='[Parameter 1]' param-domain-type='list' role='measure' type='nominal' value='&quot;baseline&quot;'>
              <calculation class='tableau' formula='&quot;baseline&quot;' />
            </column>
            <column caption='View' datatype='string' name='[Parameter 2]' param-domain-type='list' role='measure' type='nominal' value='&quot;Difference&quot;'>
              <calculation class='tableau' formula='&quot;Difference&quot;' />
            </column>
            <column alias='Capacity (MW)' caption='Indicator' datatype='string' name='[Parameter 3]' param-domain-type='list' role='measure' type='nominal' value='&quot;CapacityTechFuel&quot;'>
              <calculation class='tableau' formula='&quot;CapacityTechFuel&quot;' />
              <aliases>
                <alias key='&quot;CapacityTechFuel&quot;' value='Capacity (MW)' />
                <alias key='&quot;CapexInvestmentComponent&quot;' value='CAPEX (m USD)' />
                <alias key='&quot;CapexInvestmentComponentCumulated&quot;' value='CAPEX Cumulative (m USD)' />
                <alias key='&quot;EnergyTechFuelComplete&quot;' value='Energy Generation (GWh)' />
                <alias key='&quot;NewCapacityTechFuel&quot;' value='New Capacity (MW)' />
                <alias key='&quot;NewCapacityTechFuelCumulated&quot;' value='New Capacity Cumulative (MW)' />
                <alias key='&quot;ReserveSpinningTechFuel&quot;' value='Reserve (GWh)' />
                <alias key='&quot;Costs&quot;' value='Costs (m USD)' />
                <alias key='&quot;DiscountedWeightedCostsCumulated&quot;' value='Discounted Costs Cumulated (m USD)' />
                <alias key='&quot;CostsPerMWh&quot;' value='Generation Costs (USD/MWh)' />
              </aliases>
            </column>
            <column caption='Aggregation level' datatype='string' name='[Parameter 4]' param-domain-type='list' role='measure' type='nominal' value='&quot;Zone&quot;'>
              <calculation class='tableau' formula='&quot;Zone&quot;' />
            </column>
            <column caption='Display Total' datatype='string' name='[Parameter 5]' param-domain-type='list' role='measure' type='nominal' value='&quot;No&quot;'>
              <calculation class='tableau' formula='&quot;No&quot;' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.1658zy81lz2h3u1gu0hna1hkm2gh'>
            <column caption='Indicator Attribute' datatype='boolean' name='[Calculation_1601592635822628865]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[Parameters].[Parameter 3]=[Calculation_3206000004388323328]' />
            </column>
            <column caption='Aggregation Unit' datatype='string' name='[Calculation_1601592635824541699]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='case [Parameters].[Parameter 4]&#13;&#10;WHEN &apos;Country&apos; THEN [c]&#13;&#10;WHEN &apos;Zone&apos; THEN [z]&#13;&#10;END' />
            </column>
            <column caption='Total Value Compare' datatype='real' name='[Calculation_1601592635830226948]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Parameters].[Parameter 2]&#13;&#10;WHEN &apos;Absolute&apos; THEN WINDOW_SUM([Calculation_804455501756768259])&#13;&#10;WHEN &apos;Difference&apos; THEN WINDOW_SUM([Calculation_804455501756768259])&#13;&#10;WHEN &apos;Percentage&apos; THEN 1&#13;&#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Total Value Displayed' datatype='string' name='[Calculation_1601592635831001093]' role='measure' type='nominal'>
              <calculation class='tableau' formula='case [Parameters].[Parameter 2]&#13;&#10;WHEN &apos;Percentage&apos; THEN &apos;&apos;&#13;&#10;ELSE &#13;&#10;CASE [Parameters].[Parameter 5]&#13;&#10;WHEN &apos;Yes&apos; THEN&#13;&#10;    CASE [Parameters].[Parameter 3]&#13;&#10;        WHEN &apos;CapexInvestmentComponentCumulated&apos; THEN &apos;M$ &apos; + STR(ROUND([Calculation_1601592635830226948]/10^6, 0))&#13;&#10;        WHEN &apos;CapexInvestmentComponent&apos; THEN &apos;M$ &apos; + STR(ROUND([Calculation_1601592635830226948]/10^6, 0))&#13;&#10;        ELSE STR(ROUND([Calculation_1601592635830226948], 0))&#13;&#10;    END&#13;&#10;ELSE &apos;&apos;&#13;&#10;END&#13;&#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Attribute Full' datatype='string' name='[Calculation_3206000004388323328]' role='dimension' type='nominal'>
