            </column>
            <column caption='Res' datatype='string' name='[Calculation_1938799658917724165]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [Calculation_1938799658917425155]&#13;&#10;WHEN &apos;pTransmissionCapacity&apos; THEN [z2]&#13;&#10;WHEN &apos;pCapacityTechFuel&apos; THEN [techfuel]&#13;&#10;WHEN &apos;pEnergyTechFuel&apos; THEN [techfuel]&#13;&#10;WHEN &apos;pNewCapacityTechFuel&apos; THEN [techfuel]&#13;&#10;END' />
