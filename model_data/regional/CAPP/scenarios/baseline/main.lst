1544   
1545  * ------------------------------
1546  * Unit-commitment transition equations
1547  * ------------------------------
1548     eCommitmentConsistency 'Keeps each hour’s on/off change consistent with the recorded startup/shutdown activity'
1549     eCommitmentInitialization 'Applies the same accounting for the first chronological slot using the initial status'
1550     eCommitmentSingleTransition 'Prevents multiple start/shutdown actions within a single chronological slot'
1551     eStartupCostConstraint(g,q,d,t,y) 'Aggregate startup cost per representative timeslice'
1552     eMinUpInitial(g,y) 'Initial minimum up-time accounting'
1553     eMinUpRolling(g,AT2,y) 'Rolling minimum up-time enforcement for startups'
1554     eMinDownInitial(g,y) 'Initial minimum down-time accounting'
1555     eMinDownRolling(g,AT2,y) 'Rolling minimum down-time enforcement for shutdowns'
1556  ;
1557   
1558   
1559  *-------------------------------------------------------------------
1560  * OBJECTIVE FUNCTION
1561  *-------------------------------------------------------------------
1562  * Adding system-level cost of reserves and CO2 backstop to the total cost
1563  eNPVCost..
1564     vNPVCost =e= sum(y, pRR(y)*pWeightYear(y)*(sum(c,
1565                                   vYearlyTotalCost(c,y)) +
1566                                   vYearlyUnmetPlanningReserveCostSystem(y) +
1567                                   vYearlyUnmetSpinningReserveCostSystem(y) +
1568                                   vYearlyCO2BackstopCostSystem(y))
1569                                   );
1570   
1571  *-------------------------------------------------------------------
1572  * 1. COST
1573  *-------------------------------------------------------------------
1574  * ------------------------------
1575  * System-level Cost accounting
1576  * ------------------------------
1577   
1578  eYearlyUnmetPlanningReserveCostSystem(y)..
1579     vYearlyUnmetPlanningReserveCostSystem(y) =e= vUnmetPlanningReserveSystem(y)*pPlanningReserveVoLL;
1580   
1581  eYearlyUnmetSpinningReserveCostSystem(y)..
1582     vYearlyUnmetSpinningReserveCostSystem(y) =e= sum((q,d,t), vUnmetSpinningReserveSystem(q,d,t,y)*pHours(q,d,t)*pSpinningReserveVoLL);
1583   
1584  eYearlyCO2BackstopCostsSystem(y)..
1585     vYearlyCO2BackstopCostSystem(y) =e= vYearlySysCO2backstop(y)*pCostOfCO2backstop;
1586   
1587  * Note capex is full capex in $m per MW. Also note VarCost includes fuel cost and VOM -
1588  * essentially the short run marginal cost for the generator
1589   
1590  * Adding country-level cost of reserves and CO2 backstop to the total cost
1591  eYearlyTotalCost(c,y)..
1592     vYearlyTotalCost(c,y) =e= vYearlyUnmetReserveCostCountry(c,y)+ vYearlyCO2BackstopCostCountry(c,y)
1593                             + sum(zcmap(z,c), vAnnCapex(z, y)
1594                                             + vYearlyFOMCost(z, y)
1595                                             + vYearlyVariableCost(z,y)
1596                                             + vYearlySpinningReserveCost(z,y)
1597                                             + vYearlyUSECost(z,y)
1598                                             + vYearlyCarbonCost(z,y)
1599                                             + vYearlyExternalTradeCost(z,y)
1600                                             + vAnnualizedTransmissionCapex(z,y)
1601                                             + vYearlyCurtailmentCost(z,y)
1602                                             + vYearlySurplus(z,y));
1603   
1604  * ------------------------------
1605  * Country-level Cost accounting
1606  * ------------------------------
1607   
1608  * Yearly unmet reserve cost at the country level
1609  eYearlyUnmetReserveCostCountry(c,y)..
1610     vYearlyUnmetReserveCostCountry(c,y) =e= vYearlyUnmetPlanningReserveCostCountry(c,y) + vYearlyUnmetSpinningReserveCostCountry(c,y);
1611   
1612  * Yearly unmet spinning reserve cost at the country level
1613  eYearlyUnmetSpinningReserveCostCountry(c,y)..
1614     vYearlyUnmetSpinningReserveCostCountry(c,y) =e= sum((q,d,t), vUnmetSpinningReserveCountry(c,q,d,t,y)*pHours(q,d,t)*pSpinningReserveVoLL);
1615   
1616  * Yearly unmet planning reserve cost at the country level
1617  eYearlyUnmetPlanningReserveCostCountry(c,y)..
1618     vYearlyUnmetPlanningReserveCostCountry(c,y) =e= vUnmetPlanningReserveCountry(c,y)*pPlanningReserveVoLL;
1619   
1620  * Yearly CO2 backstop cost at the country level
1621  eYearlyCO2BackstopCostCountry(c,y)..
1622     vYearlyCO2BackstopCostCountry(c,y) =e= vYearlyCO2backstop(c,y)*pCostOfCO2backstop;
1623   
1624  * ------------------------------
1625  * Zonal CAPEX accounting
1626  * Aggregates generator-level annualized CAPEX to the zone level.
1627  * ------------------------------
1628  * Annualized CAPEX for all zones in year y
1629  eTotalAnnualizedCapex(z, y)..
1630     vAnnCapex(z,y) =e= sum(gzmap(g,z), vAnnGenCapex(g,y));
1631   
1632  * Annualized CAPEX for all generators in year y
1633  * Separate treatment keeps time-varying CAPEX trajectories (dc) distinct
1634  * from flat-cost assets (ndc) when annualizing capital costs.
1635  * Assets tagged in set dc(g) follow time-varying CAPEX trajectories (stored
1636  * in vAnnCapexGenTraj), while flat-cost assets (ndc(g)) use
1637  * conventional CRF-based annualization. We keep both paths to preserve the
1638  * different depreciation logic without double-counting.
1639  eTotalAnnualizedGenCapex(g,y)..
1640     vAnnGenCapex(g,y) =e=
1641         vAnnCapexGenTraj(g,y)$(dc(g) and ng(g))
1642       + pCRF(g)*vCap(g,y)*pGenData(g,"Capex")*1e6$(ndc(g) and ng(g))
1643       + pCRFsst(g)*vCapStor(g,y)*pStorageData(g,"CapexMWh")*1e3$(ndc(g) and ng(g) and not cs(g))
1644       + pCRFcst(g)*vCapStor(g,y)*pCSPData(g,"Storage","CapexMWh")*1e3$(ndc(g) and ng(g) and not st(g))
1645       + pCRFcth(g)*vCapTherm(g,y)*pCSPData(g,"Thermal Field","CapexMWh")*1e6$(ndc(g) and ng(g));
1646   
1647  * Annualized CAPEX accumulation (years after the start year) for generators with capex trajectory
1648  eAnnualizedCapexUpdate(dc,y)$(not sStartYear(y))..
1649     vAnnCapexGenTraj(dc,y) =e= vAnnCapexGenTraj(dc,y-1)
1650                       + vBuild(dc,y)*pGenData(dc,"Capex")*pCapexTrajectories(dc,y)*pCRF(dc)*1e6
1651                       + vBuildStor(dc,y)*pStorageData(dc,"CapexMWh")*pCapexTrajectories(dc,y)*pCRFsst(dc)*1e3
1652                       + vBuildStor(dc,y)*pCSPData(dc,"Storage","CapexMWh")*pCapexTrajectories(dc,y)*pCRFcst(dc)*1e3
1653                       + vBuildTherm(dc,y)*pCSPData(dc,"Thermal Field","CapexMWh")*pCapexTrajectories(dc,y)*pCRFcth(dc)*1e6;
1654   
1655  * Initial annualized CAPEX in the start year for generators with capex trajectory
1656  eAnnualizedCapexInit(dc,sStartYear(y))..
1657     vAnnCapexGenTraj(dc,y) =e=
1658         vBuild(dc,y)     *pGenData(dc,"Capex")        *pCapexTrajectories(dc,y)*pCRF(dc)   *1e6
1659       + vBuildStor(dc,y) *pStorageData(dc,"CapexMWh")    *pCapexTrajectories(dc,y)*pCRFsst(dc)*1e3
1660       + vBuildStor(dc,y) *pCSPData(dc,"Storage","CapexMWh")*pCapexTrajectories(dc,y)*pCRFcst(dc)*1e3
1661       + vBuildTherm(dc,y)*pCSPData(dc,"Thermal Field","CapexMWh")*pCapexTrajectories(dc,y)*pCRFcth(dc)*1e6;
1662   
1663  * FOM costs including fixed O&M costs for generators, storage, and CSP thermal field
1664  eYearlyFOMCost(z,y)..
1665     vYearlyFOMCost(z,y) =e= sum(gzmap(g,z),  vCap(g,y)*pGenData(g,"FOMperMW"))
1666              + sum(gzmap(st,z), vCapStor(st,y)*pStorageData(st,"FixedOMMWh"))
1667              + sum(gzmap(cs,z), vCapStor(cs,y)*pCSPData(cs,"Storage","FixedOMMWh"))
1668              + sum(gzmap(cs,z), vCapTherm(cs,y)*pCSPData(cs,"Thermal field","FixedOMMWh"));
1669   
1670  * Variable costs equals fuel cost plus VOM cost
1671  eYearlyVariableCost(z,y)..
1672     vYearlyVariableCost(z,y) =e= vYearlyFuelCost(z,y) + vYearlyVOMCost(z,y) + vYearlyStartupCost(z,y);
1673   
1674  * Annualized startup cost pulled from dispatch slots (links to time-sliced variable).
1675  eYearlyStartupCost(z,y)$((fDispatchMode and fApplyStartupCost))..
1676     vYearlyStartupCost(z,y) =e= sum((gzmap(g,z),q,d,t)$MinGenPoint(g),
1677           vStartupCost(g,q,d,t,y)*pHours(q,d,t));
1678   
1679  * If startup costs are disabled, force the reporting variable to zero.
1680  eYearlyStartupCostOff(z,y)$(fDispatchMode=0 or fApplyStartupCost=0)..
1681     vYearlyStartupCost(z,y) =e= 0;
1682  *  Startup cost flows through the same time-slice weighting as the rest of the variable cost stack.
1683   
1684  * Fuel costs
1685  eYearlyFuelCost(z,y)..
1686     vYearlyFuelCost(z,y) =e= sum((gzmap(g,z),f,q,d,t), pFuelCost(g,f,y)*vPwrOut(g,f,q,d,t,y)*pHours(q,d,t));
1687   
1688  * VOM
1689  eYearlyVOMCost(z,y)..
1690     vYearlyVOMCost(z,y) =e= sum((gzmap(g,z),f,q,d,t), pVOMCost(g,f,y)*vPwrOut(g,f,q,d,t,y)*pHours(q,d,t));
1691   
1692  * Note: ReserveCost is in $/MWh -- this is the DIRECT cost of holding reserve like wear and tear that a generator bids in a market
1693  eYearlySpinningReserveCost(z,y)..
1694     vYearlySpinningReserveCost(z,y) =e= sum((gzmap(g,z),q,d,t), vSpinningReserve(g,q,d,t,y)*pGenData(g,"ReserveCost")*pHours(q,d,t));
1695   
1696  * Unserved energy cost (USE)
1697  eYearlyUSECost(z,y)..
1698     vYearlyUSECost(z,y) =e= sum((q,d,t), vUSE(z,q,d,t,y)*pVoLL*pHours(q,d,t));
1699   
1700  * Surplus cost
1701  eYearlySurplusCost(z,y)..
1702     vYearlySurplus(z,y) =e= sum((q,d,t), vSurplus(z,q,d,t,y)*pSurplusPenalty*pHours(q,d,t));
1703   
1704  * Curtailment cost
1705  eYearlyCurtailmentCost(z,y)..
1706     vYearlyCurtailmentCost(z,y) =e= sum((gzmap(g,z),q,d,t), vCurtailedVRE(z,g,q,d,t,y)*pCostOfCurtailment*pHours(q,d,t));
1707   
1708  * Yearly trade cost
1709  eYearlyExternalTradeCost(z,y)..
1710     vYearlyExternalTradeCost(z,y) =e= vYearlyImportExternalCost(z,y) - vYearlyExportExternalCost(z,y);
1711   
1712  * Yearly import and export costs from external zones
1713  eYearlyImportExternalCost(z,y)..
1714     vYearlyImportExternalCost(z,y) =e= sum((zext,q,d,t), vYearlyImportExternal(z,zext,q,d,t,y)*pTradePrice(zext,q,d,y,t)*pHours(q,d,t));
1715   
1716  * Yearly export cost to external zones
1717  eYearlyExportExternalCost(z,y)..
1718     vYearlyExportExternalCost(z,y) =e= sum((zext,q,d,t), vYearlyExportExternal(z,zext,q,d,t,y)*pTradePrice(zext,q,d,y,t)*pHours(q,d,t));
1719   
1720  * Yearly CO2 emissions cost for each zone
1721  eYearlyCarbonCost(z,y)..
1722     vYearlyCarbonCost(z,y) =e= fEnableCarbonPrice*pCarbonPrice(y)
1723                              * Sum((gzmap(g,z),gfmap(g,f),q,d,t), vPwrOut(g,f,q,d,t,y)*pHeatRate(g,f)*pFuelCarbonContent(f)*pHours(q,d,t));
1724   
1725   
1726  * Ensures that when accessing parameters like CostPerLine or Life for a connection between zones i and j,
1727  * the model always uses the maximum of both directions, regardless of ordering.
1728  $macro symmax(s,i,j,h) max(s(i,j,h),s(j,i,h))
1729   
1730  * Computes annualized investment cost of new transmission lines connected to zone z
1731  * using the annuity formula and averaging (divided by 2) to avoid double-counting symmetric lines
1732  eAnnualizedTransmissionCapex(z,y)$(fAllowTransferExpansion and sum(sTopology(z,z2),1))..
1733     vAnnualizedTransmissionCapex(z,y) =e=
1734         sum(sTopology(z,z2),
1735             vNewTransmissionLine(z,z2,y)
1736           * max(pNewTransmission(z,z2,"CostPerLine"),pNewTransmission(z2,z,"CostPerLine"))
1737           * 1e6)
1738       / 2
1739       * (pWACC / (1 - (1 / ((1 + pWACC) ** sum(sTopology(z,z2), max(pNewTransmission(z,z2,"Life"),pNewTransmission(z2,z,"Life")))))));
1740   
1741  * ------------------------------
1742  * Demand and supply balance
1743  * Ensures zonal demand matches supply components.
1744  * ------------------------------
1745  eDemSupply(z,q,d,t,y)$FD(q,d,t)..
1746     pDemandData(z,q,d,y,t) * pEnergyEfficiencyFactor(z,y) =e= vSupply(z,q,d,t,y);
1747   
1748  eDefineSupply(z,q,d,t,y)$FD(q,d,t)..
1749     vSupply(z,q,d,t,y) =e=
1750       sum((gzmap(g,z),gfmap(g,f)), vPwrOut(g,f,q,d,t,y))
1751     - sum(sTopology(z,z2), vFlow(z,z2,q,d,t,y))
1752     + sum(sTopology(z,z2), vFlow(z2,z,q,d,t,y) * (1 - pLossFactorInternal(z,z2,y)))
1753     - sum(gzmap(st,z), vStorInj(st,q,d,t,y))$(fEnableStorage)
1754     + sum(zext, vYearlyImportExternal(z,zext,q,d,t,y))
1755     - sum(zext, vYearlyExportExternal(z,zext,q,d,t,y))
1756     + vUSE(z,q,d,t,y)
1757     - vSurplus(z,q,d,t,y);
1758   
1759   
1760  * ------------------------------
1761  * Generator capacity equations
1762  * Tracks installed capacity for existing/new units.
1763  * ------------------------------
1764  * Initial capacity balance in the first model year
1765  eInitialCapacity(g,sStartYear(y))..
1766     vCap(g,y) =e= pGenData(g,"Capacity")$(eg(g) and (pGenData(g,"StYr") <= sStartYear.val))
1767                 + vBuild(g,y) - vRetire(g,y);
1768   
1769  * Year-on-year capacity tracking for existing generators
1770  eCapacityEvolutionExist(eg,y)$(not sStartYear(y))..
1771     vCap(eg,y) =e= vCap(eg,y-1) + vBuild(eg,y) - vRetire(eg,y);
1772   
1773  * Year-on-year capacity tracking for new generators (non-retirable)
1774  eCapacityEvolutionNew(ng,y)$(not sStartYear(y))..
1775     vCap(ng,y) =e= vCap(ng,y-1) + vBuild(ng,y);
1776   
1777  * Limit on initial build for new generators (starting after model year 1)
1778  eInitialBuildLimit(eg)$(pGenData(eg,"StYr") > sStartYear.val)..
1779     sum(y, vBuild(eg,y)) =l= pGenData(eg,"Capacity");
1780   
1781  eMinGenRE(c,y)$(pMinRE and y.val >= pMinsRenewableTargetYear)..
1782     sum((zcmap(z,c),gzmap(RE,z),gfmap(RE,f),q,d,t), vPwrOut(RE,f,q,d,t,y)*pHours(q,d,t)) =g=
1783     sum((zcmap(z,c),q,d,t), pDemandData(z,q,d,y,t)*pHours(q,d,t)*pEnergyEfficiencyFactor(z,y))*pMinRE;
1784   
1785  eBuiltCap(ng,y)$pGenData(ng,"DescreteCap")..
1786     vBuild(ng,y) =e= pGenData(ng,"UnitSize")*vBuiltCapVar(ng,y);
1787   
1788  eRetireCap(eg,y)$(pGenData(eg,"DescreteCap") and (y.val <= pGenData(eg,"RetrYr")))..
1789     vRetire(eg,y) =e= pGenData(eg,"UnitSize")*vRetireCapVar(eg,y);
1790   
1791  * ------------------------------
1792  * Production equations
1793  * Constrains generator dispatch, ramping, and minimum output.
1794  * ------------------------------
1795  * Enforces dispatch/reserve only when the generator is committed for the chronological slot.
1796  eJointResCap(g,q,d,t,y)$FD(q,d,t)..
1797     sum(gfmap(g,f), vPwrOut(g,f,q,d,t,y)) + vSpinningReserve(g,q,d,t,y)
1798        =l= vCap(g,y)*(1+pGenData(g,"Overloadfactor"));
1799   
1800  eMaxCF(g,q,y)..
1801     sum((gfmap(g,f),d,t), vPwrOut(g,f,q,d,t,y)*pHours(q,d,t)) =l= pAvailability(g,y,q)*vCap(g,y)*sum((d,t), pHours(q,d,t));
1802   
1803  * Note that we are effectively assuming grid-connected RE generation to be dispatchable. Generally speaking, most RE will be
1804  * dispatched anyway because they have zero cost (i.e., not a different outcome from net load approach, but this allows for
1805  * RE generation to be rejected as well
1806  eVREProfile(gfmap(VRE,f),z,q,d,t,y)$(gzmap(VRE,z) and FD(q,d,t))..
1807     vPwrOut(VRE,f,q,d,t,y) + vCurtailedVRE(z,VRE,q,d,t,y) =e= pVREgenProfile(VRE,q,d,t)*pAvailability(VRE,y,q)*vCap(VRE,y);
1808   
1809  eFuel(zfmap(z,f),y)..
1810     vFuel(z,f,y) =e= sum((gzmap(g,z),gfmap(g,f),q,d,t), vPwrOut(g,f,q,d,t,y)*pHours(q,d,t)*pHeatRate(g,f));
1811   
1812  eFuelLimit(c,f,y)$(fApplyFuelConstraint and pMaxFuelLimit(c,f,y) > 0)..
1813     sum((zcmap(z,c),zfmap(z,f)), vFuel(z,f,y)) =l= pMaxFuelLimit(c,f,y)*1e6;
1814   
1815  * Applies the minimum output requirement per capacity share.
1816  eMinGen(g,q,d,t,y)$((fApplyMinGenShareAllHours and pGenData(g,"MinGenShareAllHours") > 0) and FD(q,d,t))..
1817      sum(gfmap(g,f), vPwrOut(g,f,q,d,t,y)) =g= vCap(g,y)*pGenData(g,"MinGenShareAllHours");
1818   
1819  * ------------------------------
1820  * Unit-commitment transition equations
1821  * Ensures the recorded on/off state matches startups/shutdowns and forbids more than one transition per slot.
1822  * Since the state alone cannot capture how many switches occurred, we introduce startup/shutdown binaries alongside `isOn`.
1823  * ------------------------------
1824   
1825  * Dispatch-mode minimum generation only when the generator is recorded as online.
1826  eDispatchMinGenPoint(g,q,d,t,y)$((fDispatchMode and fApplyMinGenCommitment and MinGenPoint(g) and FD(q,d,t)))..
1827     sum(gfmap(g,f), vPwrOut(g,f,q,d,t,y))
1828        =g= pGenData(g,"MinGenCommitment")*pGenData(g,"Capacity")
1829            * sum(AT$mapTS(q,d,t,AT), isOn(g,q,d,t,AT,y));
1830   
1831  * Prevents exceeding capacity while the generator reports being online in dispatch slots.
1832  eDispatchMaxGenPoint(g,q,d,t,y)$((fDispatchMode and fApplyMinGenCommitment and MinGenPoint(g) and FD(q,d,t)))..
1833     sum(gfmap(g,f), vPwrOut(g,f,q,d,t,y))
1834        =l= pGenData(g,"Capacity")*sum(AT$mapTS(q,d,t,AT), isOn(g,q,d,t,AT,y));
1835   
1836  * Keeps each hour’s on/off change consistent with the recorded startup/shutdown activity.
1837  eCommitmentConsistency(g,AT,y)$(ord(AT) > 1 and fDispatchMode and fApplyMinGenCommitment and MinGenPoint(g))..
1838     sum((q,d,t)$mapTS(q,d,t,AT), isStartup(g,q,d,t,AT,y) - isShutdown(g,q,d,t,AT,y))
1839        =e= sum((q,d,t)$mapTS(q,d,t,AT), isOn(g,q,d,t,AT,y))
1840           - sum((q,d,t)$mapTS(q,d,t,AT-1), isOn(g,q,d,t,AT-1,y));
1841   
1842  * Applies the same accounting for the first chronological slot using the initial status.
1843  eCommitmentInitialization(g,AT,y)$(ord(AT) = 1 and fDispatchMode and fApplyMinGenCommitment and MinGenPoint(g))..
1844     sum((q,d,t)$mapTS(q,d,t,AT), isStartup(g,q,d,t,AT,y) - isShutdown(g,q,d,t,AT,y))
1845        =e= sum((q,d,t)$mapTS(q,d,t,AT), isOn(g,q,d,t,AT,y)) - pInitialOnStart(g);
1846   
1847  * Prevents multiple start/shutdown actions within a single chronological slot.
1848  eCommitmentSingleTransition(g,AT,y)$(fDispatchMode and fApplyMinGenCommitment and MinGenPoint(g))..
1849     sum((q,d,t)$mapTS(q,d,t,AT), isStartup(g,q,d,t,AT,y) + isShutdown(g,q,d,t,AT,y)) =l= 1;
1850   
1851  * ------------------------------
1852  * Minimum up/down-time constraints
1853  * ------------------------------
1854  * Initial minimum up-time: if HoursOn > 0, force the remaining required online hours.
1855  eMinUpInitial(g,y)$(fDispatchMode and fApplyMUDT and fApplyMinGenCommitment and MinGenPoint(g) and pGenData(g,"HoursOn")
1856        and pGenData(g,"HoursOff") = 0 and pGenData(g,"minUT") > 0.999)..
1857     sum(AT$(ord(AT) < (pGenData(g,"minUT") - pGenData(g,"HoursOn") + 1)),
1858         sum((q,d,t)$mapTS(q,d,t,AT), 1 - isOn(g,q,d,t,AT,y))) =e= 0;
1859   
1860  * Rolling minimum up-time: every startup must be followed by minUT consecutive on hours.
1861  eMinUpRolling(g,AT2,y)$(fDispatchMode and fApplyMUDT and fApplyMinGenCommitment and MinGenPoint(g) and pGenData(g,"minUT") > 0.999
1862        and ord(AT2) > (pGenData(g,"minUT") - pGenData(g,"HoursOn") + 1)$pGenData(g,"HoursOn")
1863        and ord(AT2) < (card(AT2) - pGenData(g,"minUT") + 1))..
1864     sum(AT$((ord(AT) >= ord(AT2)) and (ord(AT) < ord(AT2) + pGenData(g,"minUT"))),
1865         sum((q,d,t)$mapTS(q,d,t,AT), isOn(g,q,d,t,AT,y)))
1866        =g= pGenData(g,"minUT") * sum((q,d,t)$mapTS(q,d,t,AT2), isStartup(g,q,d,t,AT2,y));
1867   
1868  * Initial minimum down-time: if HoursOff > 0, force the remaining offline hours.
1869  eMinDownInitial(g,y)$(fDispatchMode and fApplyMUDT and fApplyMinGenCommitment and MinGenPoint(g) and pGenData(g,"HoursOn") = 0
1870        and pGenData(g,"HoursOff") and pGenData(g,"minDT") > 0.999)..
1871     sum(AT$(ord(AT) < (pGenData(g,"minDT") - pGenData(g,"HoursOff") + 1)),
1872         sum((q,d,t)$mapTS(q,d,t,AT), isOn(g,q,d,t,AT,y))) =e= 0;
1873   
1874  * Rolling minimum down-time: every shutdown must be followed by minDT consecutive off hours.
1875  eMinDownRolling(g,AT2,y)$(fDispatchMode and fApplyMUDT and fApplyMinGenCommitment and MinGenPoint(g) and pGenData(g,"minDT") > 0.999
1876        and ord(AT2) > (pGenData(g,"minDT") - pGenData(g,"HoursOff") + 1)$pGenData(g,"HoursOff")
1877        and ord(AT2) < (card(AT2) - pGenData(g,"minDT") + 1))..
1878     sum(AT$((ord(AT) >= ord(AT2)) and (ord(AT) < ord(AT2) + pGenData(g,"minDT"))),
1879         sum((q,d,t)$mapTS(q,d,t,AT), 1 - isOn(g,q,d,t,AT,y)))
1880        =g= pGenData(g,"minDT") * sum((q,d,t)$mapTS(q,d,t,AT2), isShutdown(g,q,d,t,AT2,y));
1881   
1882  * ------------------------------
1883  * Startup-cost translation
1884  * ------------------------------
1885  * Aggregate startup events per representative bucket by summing every chronological `AT` slot that belongs to (q,d,t).
1886  * The resulting cost is tied to the time slice so the variable-cost stack can weight it just like fuel and VOM.
1887  eStartupCostConstraint(g,q,d,t,y)$((fDispatchMode and fApplyMinGenCommitment and MinGenPoint(g) and fApplyStartupCost and FD(q,d,t)))..
1888     vStartupCost(g,q,d,t,y) =e= sum(AT$mapTS(q,d,t,AT), isStartup(g,q,d,t,AT,y)) * pGenData(g,"StUpCost");
1889   
1890  * ------------------------------
1891  * Dispatch-level ramping continuity
1892  * ------------------------------
1893   
1894  eRampDnLimit(g,q,d,t,y)$((Ramprate(g) and not sFirstHour(t) and fApplyRampConstraint and fDispatchMode=0) and FD(q,d,t))..
1895     sum(gfmap(g,f), vPwrOut(g,f,q,d,t-1,y)) - sum(gfmap(g,f), vPwrOut(g,f,q,d,t,y)) =l= vCap(g,y)*pGenData(g,"RampDnRate");
1896   
1897  eRampUpLimit(g,q,d,t,y)$((Ramprate(g) and not sFirstHour(t) and fApplyRampConstraint and fDispatchMode=0) and FD(q,d,t))..
1898     sum(gfmap(g,f), vPwrOut(g,f,q,d,t,y)) - sum(gfmap(g,f), vPwrOut(g,f,q,d,t-1,y)) =l= vCap(g,y)*pGenData(g,"RampUpRate");
1899   
1900  * Tie the chronological slot totals to the underlying hourly dispatch so that ramp limits can aggregate across AT.
1901  eRampContinuity(g,q,d,t,AT,y)$((Ramprate(g) and fApplyRampConstraint and fDispatchMode) and mapTS(q,d,t,AT))..
1902     sum(gfmap(g,f), vPwrOut(g,f,q,d,t,y)) =e= vPwrOutDispatch(g,q,d,t,AT,y);
1903   
1904  * Ensure ramp-up across consecutive AT slots respects the ramp rate plus any additional headroom from startups when min-gen constraints are active.
1905  eDispatchRampUpLimit(g,AT,y)$((not sFirstHourAT(AT) and Ramprate(g) and fApplyRampConstraint and fDispatchMode))..
1906     sum((q,d,t)$mapTS(q,d,t,AT), vPwrOutDispatch(g,q,d,t,AT,y))
1907     - sum((q,d,t)$mapTS(q,d,t,AT-1), vPwrOutDispatch(g,q,d,t,AT-1,y))
1908            =l= sum((q,d,t)$mapTS(q,d,t,AT), isStartup(g,q,d,t,AT,y))*pGenData(g,"Capacity")$(fApplyMinGenCommitment and MinGenPoint(g))
1909            + vCap(g,y)*pGenData(g,"RampUpRate");
1910   
1911  * Ensure ramp-down across slots respects ramp-down rates while allowing shutdowns to absorb faster decreases.
1912  eDispatchRampDownLimit(g,AT,y)$((not sFirstHourAT(AT) and Ramprate(g) and fApplyRampConstraint and fDispatchMode))..
1913     sum((q,d,t)$mapTS(q,d,t,AT-1), vPwrOutDispatch(g,q,d,t,AT-1,y))
1914     - sum((q,d,t)$mapTS(q,d,t,AT), vPwrOutDispatch(g,q,d,t,AT,y))
1915            =l= sum((q,d,t)$mapTS(q,d,t,AT), isShutdown(g,q,d,t,AT,y))*pGenData(g,"Capacity")$(fApplyMinGenCommitment and MinGenPoint(g))
1916            + vCap(g,y)*pGenData(g,"RampDnRate");
1917   
1918  * ------------------------------
1919  * Reserve equations
1920  * Enforces spinning and planning reserve requirements.
1921  * ------------------------------
1922  * Spinning reserve limit as a share of capacity
1923  eSpinningReserveLim(g,q,d,t,y)$((fApplyCountrySpinReserveConstraint or fApplySystemSpinReserveConstraint) and FD(q,d,t))..
1924     vSpinningReserve(g,q,d,t,y) =l= vCap(g,y)*pGenData(g,"ResLimShare");
1925   
1926  * Spinning reserve limit for VRE as a share of capacity adjusted for production profile
1927  eSpinningReserveLimVRE(gfmap(VRE,f),q,d,t,y)$((fApplyCountrySpinReserveConstraint or fApplySystemSpinReserveConstraint) and FD(q,d,t))..
1928      vSpinningReserve(VRE,q,d,t,y) =l= vCap(VRE,y)*pGenData(VRE,"ResLimShare")* pVREgenProfile(VRE,q,d,t);
1929   
1930  * This constraint increases solving time x3
1931  * Reserve constraints include interconnections as reserves too
1932  eSpinningReserveReqCountry(c,q,d,t,y)$((fApplyCountrySpinReserveConstraint) and FD(q,d,t))..
1933     sum((zcmap(z,c),gzmap(g,z)),vSpinningReserve(g,q,d,t,y))
1934   + vUnmetSpinningReserveCountry(c,q,d,t,y)
1935  * + sIntercoReserveContributionPct * sum((zcmap(z,c),sMapConnectedZonesDiffCountries(z2,z)), pTransferLimit(z2,z,q,y)
1936  *                                        + vNewTransmissionLine(z2,z,y)*symmax(pNewTransmission,z,z2,"CapacityPerLine")*fAllowTransferExpansion
1937  *                                        - vFlow(z2,z,q,d,t,y))
1938     =g= pSpinningReserveReqCountry(c,y) + sum((zcmap(z,c),gzmap(VRE_noROR,z),gfmap(VRE_noROR,f)), vPwrOut(VRE_noROR,f,q,d,t,y))*psVREForecastErrorPct;
1939   
1940  * System spinning reserve requirement
1941  eSpinningReserveReqSystem(q,d,t,y)$((fApplySystemSpinReserveConstraint) and FD(q,d,t))..
1942     sum(g, vSpinningReserve(g,q,d,t,y)) + vUnmetSpinningReserveSystem(q,d,t,y) =g= pSpinningReserveReqSystem(y) + sum(gfmap(VRE_noROR,f), vPwrOut(VRE_noROR,f,q,d,t,y))*psVREForecastErrorPct;
1943   
1944  * Planning reserve requirement at the country level
1945  ePlanningReserveReqCountry(c,y)$(fApplyPlanningReserveConstraint and pPlanningReserveMargin(c))..
1946     sum((zcmap(z,c),gzmap(g,z)), vCap(g,y)*pCapacityCredit(g,y))
1947   + vUnmetPlanningReserveCountry(c,y)
1948   + (sum((zcmap(z,c),sMapConnectedZonesDiffCountries(z2,z)), sum(q,pTransferLimit(z2,z,q,y))/card(q) + vNewTransmissionLine(z2,z,y)*max(pNewTransmission(z,z2,"CapacityPerLine"),pNewTransmission(z2,z,"CapacityPerLine"))*fAllowTransferExpansion))$fCountIntercoForReserves
1949     =g= (1+pPlanningReserveMargin(c))*smax((q,d,t), sum(zcmap(z,c), pDemandData(z,q,d,y,t)*pEnergyEfficiencyFactor(z,y)));
1950   
1951  * Planning reserve requirement at the system level
1952  ePlanningReserveReqSystem(y)$(fApplyPlanningReserveConstraint and sReserveMarginPct)..
1953     sum(g, vCap(g,y)*pCapacityCredit(g,y)) + vUnmetPlanningReserveSystem(y)
1954     =g= (1+sReserveMarginPct)*smax((q,d,t), sum(z, pDemandData(z,q,d,y,t)*pEnergyEfficiencyFactor(z,y)));
1955   
1956   
1957  * ------------------------------
1958  * Transfer equations
1959  * Limits internal flows and applies trade caps.
1960  * ------------------------------
1961  * Limits flow between zones to existing + expandable transmission capacity
1962  eTransferCapacityLimit(sTopology(z,z2),q,d,t,y)$FD(q,d,t)..
1963     vFlow(z,z2,q,d,t,y) =l= pTransferLimit(z,z2,q,y) + vNewTransmissionLine(z,z2,y)*max(pNewTransmission(z,z2,"CapacityPerLine"),pNewTransmission(z2,z,"CapacityPerLine"))*fAllowTransferExpansion;
1964   
1965  * Enforces minimum import flow into a zone when specified
1966  eMinImportRequirement(sTopology(z,z2),q,d,t,y)$(pMinImport(z2,z,y) and FD(q,d,t))..
1967     vFlow(z2,z,q,d,t,y) =g= pMinImport(z2,z,y);
1968   
1969  * Cumulative build-out of new transfer capacity over time
1970  eCumulativeTransferExpansion(sTopology(z,z2),y)$fAllowTransferExpansion..
1971     vNewTransmissionLine(z,z2,y) =e=  vNewTransmissionLine(z,z2,y-1) + vBuildTransmissionLine(z,z2,y);
1972   
1973  * Ensures symmetry in bidirectional transmission investment
1974  eSymmetricTransferBuild(sTopology(z,z2),y)$fAllowTransferExpansion..
1975     vBuildTransmissionLine(z,z2,y)  =e=  vBuildTransmissionLine(z2,z,y);
1976   
1977  * External trade
1978   
1979  * Caps total import energy based on annual demand and max external trade share
1980  eMaxAnnualImportShareEnergy(c,y)$fEnableExternalExchange..
1981     sum((zcmap(z,c),zext,q,d,t), vYearlyImportExternal(z,zext,q,d,t,y)*pHours(q,d,t)) =l=
1982     sum((zcmap(z,c),q,d,t), pDemandData(z,q,d,y,t)*pHours(q,d,t)*pEnergyEfficiencyFactor(z,y))*pMaxAnnualExternalTradeShare(y,c);
1983   
1984  * Caps total export energy based on annual demand and max external trade share
1985  eMaxAnnualExportShareEnergy(c,y)$fEnableExternalExchange..
1986     sum((zcmap(z,c),zext,q,d,t), vYearlyExportExternal(z,zext,q,d,t,y)*pHours(q,d,t)) =l=
1987     sum((zcmap(z,c),q,d,t), pDemandData(z,q,d,y,t)*pHours(q,d,t)*pEnergyEfficiencyFactor(z,y))*pMaxAnnualExternalTradeShare(y,c);
1988   
1989  * Limits hourly import energy as a share of hourly demand
1990  eMaxHourlyImportShareEnergy(c,q,d,t,y)$((sMaxHourlyImportExternalShare<1 and fEnableExternalExchange) and FD(q,d,t))..
1991     sum((zcmap(z,c), zext), vYearlyImportExternal(z,zext,q,d,t,y))  =l= sum(zcmap(z,c), pDemandData(z,q,d,y,t)*sMaxHourlyImportExternalShare * pEnergyEfficiencyFactor(z,y));
1992   
1993  * Limits hourly export energy as a share of hourly demand
1994  eMaxHourlyExportShareEnergy(c,q,d,t,y)$((sMaxHourlyExportExternalShare<1 and fEnableExternalExchange) and FD(q,d,t))..
1995     sum((zcmap(z,c), zext),vYearlyExportExternal(z,zext,q,d,t,y)) =l= sum(zcmap(z,c), pDemandData(z,q,d,y,t)*sMaxHourlyExportExternalShare * pEnergyEfficiencyFactor(z,y));
1996   
1997  * Caps import volume from an external zone to internal zone
1998  eExternalImportLimit(z,zext,q,d,t,y)$((fEnableExternalExchange) and FD(q,d,t))..
1999     vYearlyImportExternal(z,zext,q,d,t,y)=l= pExtTransferLimitIn(z,zext,q,y);
2000   
2001  * Caps export volume from internal zone to an external zone
2002  eExternalExportLimit(z,zext,q,d,t,y)$((fEnableExternalExchange) and FD(q,d,t))..
2003     vYearlyExportExternal(z,zext,q,d,t,y)=l= pExtTransferLimitOut(z,zext,q,y);
2004   
2005  * ------------------------------
2006  * Storage operations
2007  * Controls storage SOC, charging, and reserve support.
2008  * ------------------------------
2009  * Limits state of charge (SOC) by capacity
2010  eSOCUpperBound(st,q,d,t,y)$(fEnableStorage and FD(q,d,t))..
2011     vStorage(st,q,d,t,y) =l= vCapStor(st,y);
2012   
2013  * Prevents storage being used to meet reserves only
2014  eStorageCapMinConstraint(st,q,d,t,y)$(fEnableStorage and FD(q,d,t))..
2015     vCapStor(st,y) =g= vCap(st,y);
2016   
2017  * Charging power ≤ power capacity
2018  eChargeCapacityLimit(st,q,d,t,y)$(fEnableStorage and FD(q,d,t))..
2019     vStorInj(st,q,d,t,y) =l= vCap(st,y);
2020   
2021  * Charge cap from PV-following storage logic
2022  eChargeLimitWithPVProfile(stp,q,d,t,y)$(fEnableStorage and FD(q,d,t))..
2023     vStorInj(stp,q,d,t,y) =l= sum(gsmap(so,stp), vCap(so,y)*pStoPVProfile(so,q,d,t));
2024   
2025  * Max rate of charge decrease (ramp-down)
2026  eChargeRampDownLimit(st,q,d,t,y)$((not sFirstHour(t) and fEnableStorage and fApplyRampConstraint) and FD(q,d,t))..
2027     vStorInj(st,q,d,t-1,y) - vStorInj(st,q,d,t,y) =l= pGenData(st,'RampDnRate')*vCap(st,y);
2028   
2029  * Max rate of charge increase (ramp-up)
2030  eChargeRampUpLimit(st,q,d,t,y)$((not sFirstHour(t) and fEnableStorage and fApplyRampConstraint) and FD(q,d,t))..
2031     vStorInj(st,q,d,t,y) - vStorInj(st,q,d,t-1,y) =l= pGenData(st,'RampUpRate')*vCap(st,y);
2032   
2033  * Defines net charge as output - input
2034  eNetChargeBalance(st,q,d,t,y)$(fEnableStorage and FD(q,d,t))..
2035     vStorNet(st,q,d,t,y) =e= sum(gfmap(st,f), vPwrOut(st,f,q,d,t,y)) - vStorInj(st,q,d,t,y);
2036   
2037  * Anchors the first hour of the representative-day cycle to the configured capacity share (dispatch mode only).
2038  eStorageSOCInitDispatch(st,g,q,d,t,y)$((fDispatchMode and sFirstHour(t) and sFirstDay(d) and fEnableStorage) and FD(q,d,t))..
2039     vStorage(st,q,d,t,y) =e= vCapStor(st,y)*pStorageInitShare;
2040   
2041  * Forces the last hour of the cycle to return to the same capacity share, ensuring the wrap-around matches the initial value (dispatch mode only).
2042  eStorageSOCFinalDispatch(st,q,d,t,y)$((fDispatchMode and sLastHour(t) and sLastDay(d) and fEnableStorage) and FD(q,d,t))..
2043     vStorage(st,q,d,t,y) =e= vCapStor(st,y)*pStorageInitShare;
2044   
2045  * Representative-day mode: enforce SOC recursion on the first hour without cross-day anchoring.
2046  eStateOfChargeInitRep(st,q,d,t,y)$((not fDispatchMode) and fEnableStorage and sFirstHour(t) and FD(q,d,t))..
2047     vStorage(st,q,d,t,y) =e= pStorageData(st,"Efficiency")*vStorInj(st,q,d,t,y) - sum(gfmap(st,f), vPwrOut(st,f,q,d,t,y));
2048   
2049  * eStorageHourTransition rolls storage state forward using the previous chronological hour (t-1), assuming storage is enabled.
2050  eStorageHourTransition(st,q,d,t,y)$((not sFirstHour(t) and fEnableStorage) and FD(q,d,t))..
2051     vStorage(st,q,d,t,y) =e= vStorage(st,q,d,t-1,y)
2052        + pStorageData(st,"Efficiency")*vStorInj(st,q,d,t,y)
2053        - sum(gfmap(st,f), vPwrOut(st,f,q,d,t,y));
2054   
2055  * Dispatch mode: wrap the first hour of each day to the previous chronological hour (AT-1); no wrap in representative-day mode.
2056  eStorageDayWrap(st,q,d,t,AT,y)$((fDispatchMode and fEnableStorage and sFirstHour(t) and mapTS(q,d,t,AT) and ord(AT) > 1) and FD(q,d,t))..
2057     vStorage(st,q,d,t,y) =e= sum((q2,d2,t2)$mapTS(q2,d2,t2,AT-1), vStorage(st,q2,d2,t2,y))
2058        + pStorageData(st,"Efficiency")*vStorInj(st,q,d,t,y)
2059        - sum(gfmap(st,f), vPwrOut(st,f,q,d,t,y));
2060   
2061  * Ensures SOC level can cover spinning reserve
2062  eSOCSupportsReserve(st,q,d,t,y)$((fEnableStorage) and FD(q,d,t))..
2063     vSpinningReserve(st,q,d,t,y) =l= vStorage(st,q,d,t,y);
2064   
2065  * In dispatch mode, the day-wrap constraint ties each day’s first hour to AT-1, preventing artificial SOC jumps.
2066  * In representative-day mode the wrap is skipped, avoiding cross-day links that do not exist in that chronology.
2067   
2068  * Ensures energy conservation over the full representative day: total input × efficiency = total output
2069  * eDailyStorageEnergyBalance(st,q,d,y)$(fEnableStorage)..
2070  *   pStorageData(st,"efficiency") * sum(t, vStorInj(st,q,d,t,y)) =e= sum((gfmap(st,f),t), vPwrOut(st,f,q,d,t,y));
2071   
2072  * ------------------------------
2073  * CSP-specific equations
2074  * Constrains CSP thermal and storage operations.
2075  * ------------------------------
2076   
2077  * Limits CSP storage level to installed storage capacity.
2078  eCSPStorageCapacityLimit(cs,q,d,t,y)$(fEnableCSP and FD(q,d,t))..
2079     vStorage(cs,q,d,t,y) =l= vCapStor(cs,y);
2080   
2081  * Limits CSP storage injection to thermal energy output * efficiency. Prevents unrealistic injection behavior.
2082  eCSPStorageInjectionLimit(cs,q,d,t,y)$(fEnableCSP and FD(q,d,t))..
2083     vStorInj(cs,q,d,t,y) =l= vThermalOut(cs,q,d,t,y)*pCSPData(cs,"Thermal Field","Efficiency");
2084   
2085  * Prevents CSP storage injection exceeding installed capacity.
2086  eCSPStorageInjectionCap(cs,q,d,t,y)$(fEnableCSP and FD(q,d,t))..
2087     vStorInj(cs,q,d,t,y) =l= vCapStor(cs,y);
2088   
2089  *Limits thermal energy output to installed thermal field capacity * hourly solar profile.
2090  eCSPThermalOutputLimit(cs,q,d,t,y)$(fEnableCSP and FD(q,d,t))..
2091     vThermalOut(cs,q,d,t,y) =l= vCapTherm(cs,y)*pCSPProfile(cs,q,d,t);
2092   
2093  * Balances CSP thermal output, storage in/out, and generator dispatch.
2094  eCSPPowerBalance(cs,q,d,t,y)$(fEnableCSP and FD(q,d,t))..
2095     vThermalOut(cs,q,d,t,y)*pCSPData(cs,"Thermal Field","Efficiency")
2096   - vStorInj(cs,q,d,t,y) + vStorOut(cs,q,d,t,y)*pCSPData(cs,"Storage","Efficiency")
2097     =e= sum(gfmap(cs,f), vPwrOut(cs,f,q,d,t,y));
2098   
2099  * Tracks CSP storage state of charge across time (except for first hour).
2100  eCSPStorageEnergyBalance(cs,q,d,t,y)$((not sFirstHour(t) and fEnableCSP) and FD(q,d,t))..
2101     vStorage(cs,q,d,t,y) =e= vStorage(cs,q,d,t-1,y) + vStorInj(cs,q,d,t,y) - vStorOut(cs,q,d,t,y);
2102   
2103  * Initializes CSP storage balance for the first hour of the day.
2104  eCSPStorageInitialBalance(cs,q,d,sFirstHour(t),y)$((fEnableCSP) and FD(q,d,t))..
2105     vStorage(cs,q,d,t,y) =e= vStorInj(cs,q,d,t,y) - vStorOut(cs,q,d,t,y);
2106   
2107  * ------------------------------
2108  * Storage capacity evolution
2109  * Tracks storage energy capacity builds/retirements.
2110  * ------------------------------
2111   
2112  * TODO: Why is it defined for all generators (g) rather than just storage (st)?
2113  * Limits total installed storage capacity to predefined technical data from pStorageData and CSP-related capacity from pCSPData. Only applies if storage is included (fEnableStorage).
2114  eCapacityStorLimit(g,y)$fEnableStorage..
2115     vCapStor(g,y) =l= pStorageData(g,"CapacityMWh") + pCSPData(g,"Storage","CapacityMWh");
2116   
2117  * Sets initial year’s storage capacity equal to existing capacity (if online) plus new builds minus retirements.
2118  eCapStorBalance(g, sStartYear(y))..
2119      vCapStor(g,y) =e= pStorageData(g,"CapacityMWh")$(eg(g) and (pGenData(g,"StYr") <= sStartYear.val)) + vBuildStor(g,y) - vRetireStor(g,y);
2120   
2121  * Tracks annual storage capacity changes for existing generators (EGs): previous year’s capacity + builds − retirements.
2122  eCapStorAnnualUpdateEG(eg,y)$(not sStartYear(y) and fEnableStorage)..
2123     vCapStor(eg,y) =e= vCapStor(eg,y-1) + vBuildStor(eg,y) - vRetireStor(eg,y);
2124   
2125  * Tracks annual storage capacity for new generators (NGs): previous year’s capacity + builds. Assumes no retirement.
2126  eCapStorAnnualUpdateNG(ng,y)$(not sStartYear(y) and fEnableStorage)..
2127     vCapStor(ng,y) =e= vCapStor(ng,y-1) + vBuildStor(ng,y);
2128   
2129  * Sets initial capacity for new generators at start year equal to build amount. Applies only in the first year.
2130  eCapStorInitialNG(ng,sStartYear(y))$fEnableStorage..
2131     vCapStor(ng,y) =e= vBuildStor(ng,y);
2132   
2133  eBuildStorNew(eg)$((pGenData(eg,"StYr") > sStartYear.val) and fEnableStorage)..
2134     sum(y, vBuildStor(eg,y)) =l= pStorageData(eg,"CapacityMWh");
2135   
2136  * ------------------------------
2137  * CSP thermal capacity limits
2138  * Tracks CSP thermal field builds and limits.
2139  * ------------------------------
2140  eCapacityThermLimit(g,y)$fEnableCSP..
2141     vCapTherm(g,y) =l= pCSPData(g,"Thermal Field","CapacityMWh");
2142   
2143  eCapThermBalance1(eg,y)$(not sStartYear(y) and fEnableCSP)..
2144     vCapTherm(eg,y) =e= vCapTherm(eg,y-1) + vBuildTherm(eg,y) - vRetireTherm(eg,y);
2145   
2146  eCapThermBalance2(ng,y)$(not sStartYear(y) and fEnableCSP)..
2147     vCapTherm(ng,y) =e= vCapTherm(ng,y-1) + vBuildTherm(ng,y);
2148   
2149  eCapThermBalance3(ng,sStartYear(y))$fEnableCSP..
2150     vCapTherm(ng,y) =e= vBuildTherm(ng,y);
2151   
2152  eBuildThermNew(eg)$((pGenData(eg,"StYr") > sStartYear.val) and fEnableCSP)..
2153     sum(y, vBuildTherm(eg,y)) =l= pCSPData(eg,"Thermal Field","CapacityMWh");
2154   
2155  * ------------------------------
2156  * Capital budget constraint
2157  * Enforces the global investment ceiling.
2158  * ------------------------------
2159   
2160  eCapitalConstraint$fApplyCapitalConstraint..
2161     sum(y, pRR(y)*pWeightYear(y)*sum(ng, pCRF(ng)*vCap(ng,y)*pGenData(ng,"Capex"))) =l= ssMaxCapitalInvestmentInvestment*1e3;
2162   
2163  * ------------------------------
2164  * Emissions related equations
2165  * Computes CO₂ emissions and applies caps/backstops.
2166  * ------------------------------
2167   
2168  eZonalEmissions(z,y)..
2169     vZonalEmissions(z,y) =e=
2170     sum((gzmap(g,z),gfmap(g,f),q,d,t), vPwrOut(g,f,q,d,t,y)*pHeatRate(g,f)*pFuelCarbonContent(f)*pHours(q,d,t));
2171   
2172  eEmissionsCountry(c,y)$fApplyCountryCo2Constraint..
2173     sum(zcmap(z,c), vZonalEmissions(z,y))-vYearlyCO2backstop(c,y)=l= pEmissionsCountry(c,y);
2174   
2175  eTotalEmissions(y)..
2176      sum(z, vZonalEmissions(z,y))=e= vTotalEmissions(y);
2177   
2178  eTotalEmissionsConstraint(y)$fApplySystemCo2Constraint..
2179      vTotalEmissions(y)-vYearlySysCO2backstop(y) =l= pEmissionsTotal(y);
