1036  **********************************************************************
1037  * ELECTRICITY PLANNING MODEL (EPM)
1038  * Developed at the World Bank
1039  **********************************************************************
1040  * Description:
1041  * This GAMS-based model is designed for electricity system planning,
1042  * incorporating capacity expansion, generation dispatch, and policy
1043  * constraints such as renewable energy targets, emissions reductions,
1044  * and market mechanisms.
1045  *
1046  * Author(s): ESMAP Modelling Team
1047  * Organization: World Bank
1048  * Version:
1049  * License: Creative Commons Zero v1.0 Universal
1050  *
1051  * Key Features:
1052  * - Optimization of electricity generation and capacity planning
1053  * - Inclusion of renewable energy integration and storage technologies
1054  * - Multi-period, multi-region modeling framework
1055  * - CO2 emissions constraints and policy instruments
1056  *
1057  * Notes:
1058  * - Ensure GAMS is installed before running this model.
1059  * - The model requires input data in .GDX or Excel format.
1060  *
1061  * Contact:
1062  * Claire Nicolas, cnicolas@worldbank.org
1063  **********************************************************************
1064   
1067   
1068  *-------------------------------------------------------------------
1069  * DECLARATION OF SETS, PARAMETERS AND VARIABLES
1070  *-------------------------------------------------------------------
1071   
1072   
1073   
1074  alias (y,y2);
1075  alias (f,f2);
1076  alias (c,c2);
1077  alias (q,q2);
1078  alias (d,d2);
1079  alias (t,tprev,t2);
1080  alias (AT,AT2);
1081   
1082   
1083   
1084  * -------------------------------------------------------------
1085  * Generator classification sets
1086  * -------------------------------------------------------------
1087  Sets
1088     eg(g)                  'Existing generator fleet'
1089     ng(g)                  'New-build candidates'
1090     commtransmission(z,z2) 'Committed transmission corridors'
1091     cs(g)                  'Concentrated solar power units'
1092     so(g)                  'PV plants paired with storage'
1093     stp(g)                 'Dedicated storage blocks for PV plants'
1094     st(g)                  'All storage technologies (incl. standalone)'
1095     dc(g)                  'Candidates with CAPEX trajectory data'
1096     ndc(g)                 'Candidates without CAPEX trajectory data'
1097     vre(g)                 'Variable renewable technologies'
1098     re(g)                  'Renewable technologies (broader than VRE)'
1099     RampRate(g)            'Generators subject to ramp constraints (filters out inflexible units)'
1100     VRE_noROR(g)           'VRE assets excluding run-of-river (used for spinning reserve sizing)'
1101  ;
1102   
1103   
1104  * -------------------------------------------------------------
1105  * Mapping sets (generator-to-fuel/zone, network structure)
1106  * -------------------------------------------------------------
1107  Sets
1108     gfmap(g,f)             'Generator-to-fuel association'
1109     gzmap(g,z)             'Generator-to-zone association'
1110     zfmap(z,f)             'Fuel availability by zone'
1111     gsmap(g2,g)            'Storage-to-generator linkage'
1112     sTopology(z,z2)        'Internal network adjacency'
1113     sMapConnectedZonesDiffCountries(z,z2) 'Cross-country connections subset (topology filter)'
1114  ;
1115   
1116   
1117  * -------------------------------------------------------------
1118  * Status and modeltype-control sets
1119  * -------------------------------------------------------------
1120  Sets
1121     gstatus  'Generator status lookup'           / Existing, Candidate, Committed /
1122     tstatus  'Transmission project status'      / Candidate, Committed /
1123     mipline  'modeltype option line identifiers'
1124     mipopt(mipline<) 'MIP modeltype option key-value pairs' / system.empty /
1125  ;
1126   
1127   
1128  * -------------------------------------------------------------
1129  * Implicit domains (restrict variables to meaningful tuples)
1130  * -------------------------------------------------------------
1131  Sets
1132     sPwrOut(g,f,q,d,t,y)        'Active generator-fuel-time combinations'
1133     sExportPrice(z,zext,q,d,t,y) 'Valid export price records (external zones)'
1134     sImportPrice(z,zext,q,d,t,y) 'Valid import price records (external zones)'
1135     sAdditionalTransfer(z,z2,y)  'Transmission build decision domain'
1136     sFlow(z,z2,q,d,t,y)         'Feasible flow pairs'
1137     sSpinningReserve(g,q,d,t,y) 'Generators able to provide spinning reserve'
1138     FD(q,d,t)                  'Feasible q,d,t tuples for dispatch mode'
1139  ;
1140   
1141  Singleton sets
1142     sStartYear(y)
1143     sFirstHour(t)
1144     sLastHour(t)
1145     sFirstDay(d)
1146     sLastDay(d)
1147  ;
1148   
1149  Set
1150     sFirstHourAT(AT)          'First chronological hour in the AT sequence (used for ramp gating)'
1151  ;
1152   
1153  * Additional parameters for results and reporting
1154  * -------------------------------------------------------------
1155  * Global flags and shared parameters for reporting/constraints
1156  * -------------------------------------------------------------
1157  Parameter
1158     pAllHours(q,d,y,t)           'All operating hours (used for peak tracking)'
1159     pFindSysPeak(y)              'Yearly system peak indicator'
1160     pSeasonalReporting           'Enable seasonal report outputs'
1161     fEnableInternalExchange      'Allow internal zone trading'
1162     fRemoveInternalTransferLimit 'Override internal transfer limits'
1163     fAllowTransferExpansion      'Permit expansion of internal transmission (set elsewhere too; redundant flag)'
1164     pDR                          'Discount rate applied in objective'
1165     fEnableCapexTrajectoryH2     'Toggle CAPEX trajectory for hydrogen assets'
1166     fEnableEnergyEfficiency     'Enable demand-side efficiency adjustments'
1167     fApplySystemCo2Constraint   'Apply system-wide CO₂ constraint'
1168     pExtTransferLimitIn(z,zext,q,y)  'Exogenous import limit from external zones'
1169     pExtTransferLimitOut(z,zext,q,y) 'Exogenous export limit to external zones'
1170     psVREForecastErrorPct        'Forecast error percentage for VRE (used in reserves)'
1171  ;
1172   
1173  * Additional structure sets (technology/mapping)
1174  Set
1175     gprimf(g,f)            'Primary fuel used by each generator'
1176     gtechmap(g,tech)       'Generator-to-technology linkage'
1177     gstatusmap(g,gstatus)  'Generator status lookup (existing/candidate/committed)'
1178     tstatusmap(z,z2,tstatus) 'Transmission status lookup'
1179     Zd(z)                  'Demand-serving zones'
1180     Zt(z)                  'Zone type classification (often redundant with Zd)'
1181     stg(g)                 'Storage generators (grid-scale)'
1182     ror(g)                 'Run-of-river assets (subset of renewables)'
1183     MinGenPoint(g)         'Generators with minimum generation constraints (used for startup cost accumulation)'
1184  ;
1185   
1186   
1187  Parameters
1188     pCostOfCurtailment          'Penalty on curtailed VRE (check usage – may be redundant)'
1189     pCostOfCO2backstop          'CO₂ backstop cost ($/ton)'
1190     pWeightYear(y)              'Inter-year weighting factor'
1191   
1192  * Generator data
1193     pGenData(g,pGenDataInputHeader) 'Generator characteristics (capex, heat rate, etc.)'
1194     pAvailability(g,y,q)           'Seasonal availability factors'
1195     pCapexTrajectories(g,y)        'CAPEX trajectory multipliers'
1196     pInitialOnStart(g)             'Initial commitment state (1=on) for the first chronological slot (default or from data)'
1197   
1198  * External exchange data
1199     fEnableExternalExchange          'Permit external exchange'
1200     pMaxAnnualExternalTradeShare(y,c) 'Annual import/export share cap by country'
1201     pTradePrice(zext,q,d,y,t)      'Border price for external trades'
1202     sMaxHourlyImportExternalShare  'Hourly import cap (share of demand)'
1203     sMaxHourlyExportExternalShare  'Hourly export cap (share of demand)'
1204     pExtTransferLimit(z,zext,q,*,y) 'Full external transfer limit tensor'
1205     pExtTransferLimitIn(z,zext,q,y) 'Import limit (duplicate of earlier parameter)'
1206     pExtTransferLimitOut(z,zext,q,y)'Export limit (duplicate of earlier parameter)'
1207   
1208  * Demand inputs
1209     pDemandData(z,q,d,y,t)         'Demand time series (seasonal, daily, hourly)'
1210   
1211  * Renewable/storage inputs
1212     pCSPProfile(g,q,d,t)           'CSP solar profile (pu)'
1213     pStoPVProfile(g,q,d,t)         'PV-with-storage profile (pu)'
1214     pStorageData(g,pStorageDataHeader)  'Storage technical data'
1215   
1216  * Reserve and policy inputs
1217     pCapacityCredit(g,y)           'Capacity credit for planning reserves'
1218     psVREForecastErrorPct          'Reserve add-on for VRE (note: duplicate naming with parameter above)'
1219     pCarbonPrice(y)                'Carbon price trajectory'
1220     pFuelCarbonContent(f)          'Fuel carbon intensity (tCO₂/MMBtu)'
1221   
1222  * Economic parameters
1223     pRR(y)                         'Discount factor (accumulated)'
1224     pWACC                          'Weighted average cost of capital'
1225     pCRF(g)                        'Capital recovery factor (generator)'
1226     pCRFsst(g)                     'Capital recovery factor (storage)'
1227     pCRFcst(g)                     'Capital recovery factor (CSP storage)'
1228     pCRFcth(g)                     'Capital recovery factor (CSP thermal field)'
1229     pVoLL                          'Value of lost load'
1230     pPlanningReserveVoLL           'Penalty for planning reserve shortfall'
1231     pSpinningReserveVoLL           'Penalty for spinning reserve shortfall'
1232     ssMaxCapitalInvestmentInvestment 'Total capital limit (USD) – consider renaming for clarity'
1233     pVarCost(g,f,y)                'Variable cost (fuel + VOM)'
1234     pFuelCost(g,f,y)               'Fuel price'
1235     pVOMCost(g,f,y)                'Variable O&M component'
1236   
1237  * Control toggles
1238     fEnableCapacityExpansion
1239     fApplyRampConstraint           'Enable ramping constraints'
1240     fApplyFuelConstraint           'Enable fuel availability limits'
1241     fApplyCapitalConstraint        'Enable total capital constraint'
1242     fEnableCSP                     'Enable CSP features'
1243     fEnableStorage                 'Enable storage operations'
