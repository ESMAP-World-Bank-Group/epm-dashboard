3294  set dsH2hdr /
3295    "Electricity demand for H2 production: GWh",
3296    "Total H2 Production: mmBTU",
3297    "External Demand of H2: mmBTU",
3298    "Unmet External Demand of H2: mmBTU",
3299    "H2 produced for power production: mmBTU"
3300  /;
3301   
3302  set zgmap(z,g); option zgmap<gzmap;
3303  set zH2map(z,hh); option zH2map<h2zmap;
3304  set isExternal / Internal, External /;
3305   
3306  set capexComponent /
3307    Generation,
3308    StorageEnergy,
3309    CSPThermalField,
3310    CSPStorage,
3311    Hydrogen,
3312    Transmission
3313  /;
3314   
3315  set capexComponentPlant(capexComponent) /
3316    Generation,
3317    StorageEnergy,
3318    CSPThermalField,
3319    CSPStorage
3320  /;
3321   
3322  set genCostCmp /
3323    "Investment costs: $m",
3324    "Fixed O&M: $m",
3325    "Variable Cost: $m"
3326  /;
3327   
3328  set fEnergyBalance /
3329    "UnmetDemand",
3330    "Surplus",
3331    "Imports",
3332    "Imports External",
3333    "Exports",
3334    "Exports External"
3335  /;
