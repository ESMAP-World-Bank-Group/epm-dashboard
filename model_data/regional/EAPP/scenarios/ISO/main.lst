3523    pCostsCountryPerMWh(c,sumhdr,y)  'Country average cost by component [USD/MWh]'
3524    pCostsSystemPerMWh(sumhdr, y)    'System average cost [USD/MWh] by year'
3525   
3526  * ============================================================
3527  * 11. modeltype PARAMETERS
3528  * ============================================================
3529     pSolverParameters(*)                      'modeltype parameters'
3530  ;
3531   
3532  * Mapping
3533   
3534  pGeneratorTechFuel(g, tech, f) = sum(z, gmap(g, z, tech, f));
3535  pGeneratorTechFuel(g, tech, f)$pGeneratorTechFuel(g, tech, f) = 1;
3536   
3537  pZoneCountry(z, c) = zcmap(z, c);
3538  pZoneCountry(z, c)$pZoneCountry(z, c) = 1;
3539   
3540   
3541  * ============================================================
3542  * 1. CAPACITY
3543  * ============================================================
3544   
3545  * ---------------------------------------------------------
3546  * Plant and technology-level capacity and utilization
3547  * ---------------------------------------------------------
3548  * Records installed capacity, retirements, and utilization
3549  * factors for each plant and aggregated by technology:
3550  *   - pCapacityPlant: installed capacity by plant
3551  *   - pRetirementsPlant: retired capacity by plant
3552   
3553  * ---------------------------------------------------------
3554   
3555  pCapacityPlant(zgmap(z,g),y)                 = vCap.l(g,y);
3556   
3557  pNewCapacityPlant(zgmap(z,g),y)              = vBuild.l(g,y);
3558   
3559  pRetirementsPlant(zgmap(z,g),y)                  = vRetire.l(g,y);
3560   
3561   
3562  * ---------------------------------------------------------
3563  * Capacity, new builds, retirements, and utilization by fuel and technology
3564  * ---------------------------------------------------------
3565  * Tracks installed capacity, new capacity, and retirements
3566  * disaggregated by fuel type and technology.
3567  * Also computes utilization factors:
3568  *   - pCapacityTechFuel / pCapacityFuel: installed capacity
3569  *   - pNewCapacityFuel / pNewCapacityTech: new builds
3570  *   - pRetirementsFuel: retirements
3571   
3572  * ---------------------------------------------------------
3573   
3574  * Installed capacity by technology and fuel [MW]
3575  pCapacityTechFuel(z, tech, f, y) =
3576    sum((gzmap(g, z), gtechmap(g, tech), gprimf(g, f)), vCap.l(g, y));
3577   
3578  * Installed capacity by fuel [MW]
3579  pCapacityFuel(z, f, y) =
3580    sum((gzmap(g, z), gprimf(g, f)), vCap.l(g, y));
3581   
3582  * New capacity by fuel [MW]
3583  pNewCapacityFuel(z, f, y) =
3584    sum((gzmap(g, z), gprimf(g, f)), vBuild.l(g, y));
3585   
3586  * New capacity by technology [MW]
3587  pNewCapacityTech(z, tech, y) =
3588    sum((gzmap(g, z), gtechmap(g, tech), gprimf(g, f)), vBuild.l(g, y));
3589   
3590  * New capacity by technology and fuel [MW]
3591  pNewCapacityTechFuel(z, tech, f, y) =
3592    sum((gzmap(g, z), gtechmap(g, tech), gprimf(g, f)), vBuild.l(g, y));
3593   
3594  * Retirements by fuel [MW]
3595  pRetirementsFuel(z, f, y) =
3596    sum((gzmap(g, z), gprimf(g, f)), vRetire.l(g, y));
3597   
3598  * ---------------------------------------------------------
3599  * Transmission capacity expansion and annual limits
3600  * ---------------------------------------------------------
3601  * pNewTransmissionCapacity:
3602  *   - Incremental transmission capacity built in year y
3603  *   - Based on yearly build decisions and per-line capacity
3604  *
3605  * pTransmissionCapacity:
3606  *   - Total available transfer capacity in a year
3607  *   - Equals existing maximum transfer limit plus any new additions
3608  * ---------------------------------------------------------
3609   
3610  pNewTransmissionCapacity(sTopology(z,z2),y) =
3611    vBuildTransmissionLine.l(z,z2,y)
3612    * max(pNewTransmission(z,z2,"CapacityPerLine"),pNewTransmission(z2,z,"CapacityPerLine"))
3613    * fAllowTransferExpansion;
3614   
3615  pAdditionalTransmissionCapacity(sTopology(z,z2),y) = vNewTransmissionLine.l(z,z2,y)*max(pNewTransmission(z,z2,"CapacityPerLine"),pNewTransmission(z2,z,"CapacityPerLine"))*fAllowTransferExpansion;
3616  pTransmissionCapacity(sTopology(z,z2),y) = pAdditionalTransmissionCapacity(z,z2,y) + smax(q, pTransferLimit(z,z2,q,y)) ;
3617   
3618  * ---------------------------------------------------------
3619  * Country-level capacity, new builds, retirements, and utilization
3620  * ---------------------------------------------------------
3621  * Aggregates zonal results to the country level:
3622  *   - pCapacityPlantCountry: installed capacity by plant
3623  *   - pCapacityTechFuelCountry / pCapacityFuelCountry: installed capacity by tech-fuel or fuel
3624  *   - pNewCapacityFuelCountry / pNewCapacityTechCountry: new builds by fuel or tech
3625  *   - pRetirementsFuelCountry / pRetirementsCountry: retirements by fuel and total
3626  *   - pUtilizationFuelCountry / pUtilizationTechFuelCountry:
3627  *       utilization factors (energy ÷ capacity × hours) by fuel or tech-fuel
3628  * ---------------------------------------------------------
3629   
3630  pCapacityTechFuelCountry(c, tech, f, y) =
3631    sum(zcmap(z, c), pCapacityTechFuel(z, tech, f, y));
3632   
3633  pCapacityFuelCountry(c, f, y) =
3634    sum(zcmap(z, c), pCapacityFuel(z, f, y));
3635   
3636  pNewCapacityFuelCountry(c, f, y) =
3637    sum(zcmap(z, c), pNewCapacityFuel(z, f, y));
3638   
3639  pNewCapacityTechCountry(c, tech, y) =
3640    sum(zcmap(z, c), pNewCapacityTech(z, tech, y));
3641   
3642  pNewCapacityTechFuelCountry(c, tech, f, y) =
3643    sum(zcmap(z, c), pNewCapacityTechFuel(z, tech, f, y));
3644   
3645  pRetirementsFuelCountry(c, f, y) =
3646    sum(zcmap(z, c), pRetirementsFuel(z, f, y));
3647   
3648  pRetirementsCountry(c, y) =
3649    sum((zcmap(z, c), f), pRetirementsFuel(z, f, y));
3650   
3651  * ---------------------------------------------------------
3652  * Capacity summary at zone and country level [MW]
3653  * ---------------------------------------------------------
3654  * Provides aggregated indicators of system capacity:
3655  *   - Available capacity
3656  *   - Peak demand (with and without power-to-hydrogen load)
3657  *   - New capacity builds
3658  *   - Retired capacity
3659  *   - Committed total transmission capacity
3660  * Reported at both zonal and country aggregation levels.
3661  * ---------------------------------------------------------
3662   
3663  pCapacitySummary(z,"Available capacity: MW",y) = sum(gzmap(g,z), vCap.l(g,y));
3664  pCapacitySummary(z,"Peak demand: MW"       ,y) = smax((q,d,t), pDemandData(z,q,d,y,t)*pEnergyEfficiencyFactor(z,y));
3665  pCapacitySummary(z,"Peak demand including P to H2: MW"       ,y) = smax((h2zmap(hh,z),q,d,t), pDemandData(z,q,d,y,t)*pEnergyEfficiencyFactor(z,y) + vH2PwrIn.l(hh,q,d,t,y))$fEnableH2Production+1e-6;
3666  pCapacitySummary(z,"New capacity: MW"      ,y) = sum(gzmap(g,z), vBuild.l(g,y));
3667  pCapacitySummary(z,"Retired capacity: MW"  ,y) = sum(gzmap(g,z), vRetire.l(g,y));
3668  pCapacitySummary(z,"Committed Total TX capacity: MW"  ,y) = sum((z2,q), pTransferLimit(z,z2,q,y)/card(q));
3669   
3670  pCapacitySummaryCountry(c,"Available capacity: MW",y) = sum(zcmap(z,c), pCapacitySummary(z,"Available capacity: MW",y));
3671  pCapacitySummaryCountry(c,"Peak demand: MW"       ,y) = smax((q,d,t), sum(zcmap(z,c), pDemandData(z,q,d,y,t)*pEnergyEfficiencyFactor(z,y)));
3672  pCapacitySummaryCountry(c,"New capacity: MW"      ,y) = sum(zcmap(z,c), pCapacitySummary(z,"New capacity: MW",y));
3673  pCapacitySummaryCountry(c,"Retired capacity: MW"  ,y) = sum(zcmap(z,c), pCapacitySummary(z,"Retired capacity: MW",y));
3674  pCapacitySummaryCountry(c,"Committed Total TX capacity: MW",y) = sum(zcmap(z,c), pCapacitySummary(z,"Committed Total TX capacity: MW",y));
3675   
3676  * H2 model additions
3677  pCapacityPlantH2(zh2map(z,hh),y) = vCapH2.l(hh,y)$fEnableH2Production+1e-6;
3678   
3679  * ============================================================
3680  * 2. COSTS
3681  * ============================================================
3682   
3683  * Reporting costs by plant
3684  * Plant-level cost reporting (prettier formatting)
3685  pCostsPlant(z, g, "Investment costs: $m", y)$gzmap(g, z) =
3686    vAnnGenCapex.l(g, y) / 1e6;
3687   
3688  pCostsPlant(z, g, "Fixed O&M: $m", y)$gzmap(g, z) =
3689    (
3690      vCap.l(g, y)      * pGenData(g, "FOMperMW")
3691      + vCapStor.l(g, y)  * pStorageData(g, "FixedOMMWh")
3692      + vCapStor.l(g, y)  * pCSPData(g, "Storage", "FixedOMMWh")
3693      + vCapTherm.l(g, y) * pCSPData(g, "Thermal field", "FixedOMMWh")
3694    ) / 1e6;
3695   
3696  pCostsPlant(z, g, "Variable Cost: $m", y)$gzmap(g, z) =
3697    sum((gfmap(g, f), q, d, t),
3698      pVarCost(g, f, y) * vPwrOut.l(g, f, q, d, t, y) * pHours(q, d, t)
3699    ) / 1e6;
3700   
3701  pCostsPlant(z, g, "Spinning Reserve Cost: $m", y)$gzmap(g, z) =
3702    sum((q, d, t),
3703      vSpinningReserve.l(g, q, d, t, y) * pGenData(g, "ReserveCost") * pHours(q, d, t)
3704    ) / 1e6;
3705   
3706  * ---------------------------------------------------------
3707  * Plant-level CAPEX investment breakdown [USD]
3708  * ---------------------------------------------------------
3709  * Stores the non-Investment costs flows for each plant and
3710  * component so that we can add dedicated transmission and
3711  * hydrogen entries later on.
3712  * ---------------------------------------------------------
3713   
3714  * Generation CAPEX - with capex trajectories (dc)
3715  pCapexInvestmentPlant(zgmap(z,g), "Generation", y)$((not st(g)) and dc(g)) =
3716    1e6 * vBuild.l(g, y) * pGenData(g, "Capex") * pCapexTrajectories(g, y);
3717   
3718  * Generation CAPEX - without capex trajectories (ndc) - use trajectory = 1
3719  pCapexInvestmentPlant(zgmap(z,g), "Generation", y)$((not st(g)) and ndc(g)) =
3720    1e6 * vBuild.l(g, y) * pGenData(g, "Capex");
3721   
3722  * Storage CAPEX - with capex trajectories (dc)
3723  pCapexInvestmentPlant(zgmap(z,g), "StorageEnergy", y)$((st(g)) and (not cs(g)) and dc(g)) =
3724    1e3 * vBuildStor.l(g, y) * pStorageData(g, "CapexMWh") * pCapexTrajectories(g, y) +
3725    1e6 * vBuild.l(g, y) * pGenData(g, "Capex") * pCapexTrajectories(g, y);
3726   
3727  * Storage CAPEX - without capex trajectories (ndc) - use trajectory = 1
3728  pCapexInvestmentPlant(zgmap(z,g), "StorageEnergy", y)$((st(g)) and (not cs(g)) and ndc(g)) =
3729    1e3 * vBuildStor.l(g, y) * pStorageData(g, "CapexMWh") +
3730    1e6 * vBuild.l(g, y) * pGenData(g, "Capex");
3731   
3732  * CSP Thermal Field CAPEX - with capex trajectories (dc)
3733  pCapexInvestmentPlant(zgmap(z,g), "CSPThermalField", y)$(cs(g) and dc(g)) =
3734    1e3 * vBuildTherm.l(g, y) * pCSPData(g, "Thermal Field", "CapexMWh") * 1e3 * pCapexTrajectories(g, y);
3735   
3736  * CSP Thermal Field CAPEX - without capex trajectories (ndc) - use trajectory = 1
3737  pCapexInvestmentPlant(zgmap(z,g), "CSPThermalField", y)$(cs(g) and ndc(g)) =
3738    1e3 * vBuildTherm.l(g, y) * pCSPData(g, "Thermal Field", "CapexMWh") * 1e3;
3739   
3740  * CSP Storage CAPEX - with capex trajectories (dc)
3741  pCapexInvestmentPlant(zgmap(z,g), "CSPStorage", y)$(cs(g) and dc(g)) =
3742    1e3 * vBuildStor.l(g, y) * pCSPData(g, "Storage", "CapexMWh") * pCapexTrajectories(g, y);
3743   
3744  * CSP Storage CAPEX - without capex trajectories (ndc) - use trajectory = 1
3745  pCapexInvestmentPlant(zgmap(z,g), "CSPStorage", y)$(cs(g) and ndc(g)) =
3746    1e3 * vBuildStor.l(g, y) * pCSPData(g, "Storage", "CapexMWh");
3747   
3748  * Derive zonal totals per component (generation-related ones come from plants)
3749  pCapexInvestmentComponent(z, capexComponentPlant, y) =
3750    sum(zgmap(z, g), pCapexInvestmentPlant(z, g, capexComponentPlant, y));
3751   
3752  * Hydrogen CAPEX is tracked separately
3753  pCapexInvestmentComponent(z, "Hydrogen", y)$fEnableH2Production =
3754    1e6 * sum(zH2map(z, hh),
3755      vBuildH2.l(hh, y) * pH2Data(hh, "Capex") * pCapexTrajectoriesH2(hh, y)
3756    );
3757   
3758  * Transmission CAPEX additions
3759  pCapexInvestmentComponent(z, "Transmission", y)$(fAllowTransferExpansion and sum(sTopology(z, z2), 1)) =
3760    0.5 * sum(sTopology(z, z2),
3761      vBuildTransmissionLine.l(z, z2, y)
3762      * max(pNewTransmission(z,z2,"CostPerLine"),pNewTransmission(z2,z,"CostPerLine"))
3763      * 1e6
3764    );
3765   
3766  pCapexInvestmentTransmission(sTopology(z, z2), y)$fAllowTransferExpansion =
3767    0.5 * vBuildTransmissionLine.l(z, z2, y)
3768    * max(pNewTransmission(z,z2,"CostPerLine"),pNewTransmission(z2,z,"CostPerLine"))
3769    * 1e6;
3770   
3771  * ---------------------------------------------------------
3772  * Zone-level CAPEX investment flows [$]
3773  * ---------------------------------------------------------
3774  * Captures the annual capital expenditures for new builds
3775  * in zone z and year y, before annualization.
3776  *
3777  * Components:
3778  *   - Generation builds (MW × $/MW × cost trajectory)
3779  *   - Storage builds (MWh × $/MWh × cost trajectory)
3780  *   - CSP thermal field and storage builds (MWh × $/MWh × trajectory)
3781  *   - Hydrogen builds (MW × $/MW × cost trajectory), optional
3782  *   - Small epsilon added to avoid divide-by-zero issues
3783  * ---------------------------------------------------------
3784   
3785  pCapexInvestment(z, y) =
3786    sum(capexComponent, pCapexInvestmentComponent(z, capexComponent, y))
3787    + 1e-6;
3788   
3789   
3790  * ---------------------------------------------------------
3791  * Price calculation [$/MWh]
3792  * ---------------------------------------------------------
3793  * Market clearing price derived from the dual variable of the
3794  * demand-supply balance constraint, scaled by operating hours,
3795  * discount rate (pRR), and year weight.
3796  * --------------------------------------------------------
3797   
3798  pHourlyPrice(z,q,d,t,y)$(pHours(q,d,t)) = -eDemSupply.m(z,q,d,t,y)/pHours(q,d,t)/pRR(y)/pWeightYear(y);
3799   
3800  * ---------------------------------------------------------
3801  * Import and export costs with internal zones [$]
3802  * ---------------------------------------------------------
3803  * Import costs:
3804  *   - Value of inflows from neighboring zones
3805  *   - Calculated as local price × imported flow × hours
3806  *
3807  * Export revenues:
3808  *   - Value of outflows to neighboring zones
3809  *   - Negative sign ensures revenues reduce total cost
3810  * ---------------------------------------------------------
3811   
3812  pImportCostsInternal(z,y) = sum((sTopology(Zd,z),q,d,t), pHourlyPrice(z,q,d,t,y)*vFlow.l(Zd,z,q,d,t,y)*pHours(q,d,t));
3813   
3814  pExportRevenuesInternal(z,y) = - sum((sTopology(z,Zd),q,d,t), pHourlyPrice(z,q,d,t,y)*vFlow.l(z,Zd,q,d,t,y)*pHours(q,d,t));
3815   
3816  * ---------------------------------------------------------
3817  * Congestion rents between zones [$]
3818  * ---------------------------------------------------------
3819  * Difference in marginal prices × traded flow × hours
3820  * Negative sign ensures consistency with rent allocation
3821  * ---------------------------------------------------------
3822   
3823  pCongestionRevenues(z,Zd,y) = - sum((q,d,t), (pHourlyPrice(zD,q,d,t,y) - pHourlyPrice(z,q,d,t,y))*vFlow.l(z,Zd,q,d,t,y)*pHours(q,d,t));
3824   
3825  * ---------------------------------------------------------
3826  * Trade shared benefits [$]
3827  * ---------------------------------------------------------
3828  * Congestion rents are split equally (50/50) between
3829  * importing and exporting zones as the allocation rule
3830  * ---------------------------------------------------------
3831   
3832  pTradeSharedBenefits(z,y) = 0.5*sum(sTopology(Zd,z), pCongestionRevenues(Zd,z,y)) + 0.5*sum(sTopology(z,Zd), pCongestionRevenues(z,Zd,y));
3833   
3834  * ---------------------------------------------------------
3835  * Net trade costs with internal zones [$]
3836  * ---------------------------------------------------------
3837  * Equivalent formulation where:
3838  *   Trade cost = Import cost + Export revenues + Shared rents
3839  * This matches pricing trades at the average marginal price
3840  * between connected zones
3841  * ---------------------------------------------------------
3842   
3843  * pTradeCostsInternal(z,y) = pExportRevenuesInternal(z,y) + pImportCostsInternal(z,y) + pTradeSharedBenefits(z,y);
3844   
3845  * ---------------------------------------------------------
3846  * Demand allocation [GWh → TWh]
3847  * ---------------------------------------------------------
3848  * Zone-level demand:
3849  *   - Sum of hourly demand × operating hours
3850  *   - Adjusted by efficiency factor
3851  *   - Converted from GWh to TWh
3852  *
3853  * Country-level demand:
3854  *   - Aggregation of zonal demand by mapping zones to countries
3855  * ---------------------------------------------------------
3856  Parameter
3857    pDemandEnergyZone(z,y)         'Total energy demand [GWh] by zone and year'
3858    pDemandEnergyCountry(c,y)      'Total energy demand [GWh] by country and year'
3859    pDemandEnergySystem(y)         'Total system energy demand [GWh] by year'
3860    pDemandPeakZone(z,y)           'Peak demand [MW] by zone and year'
3861    pDemandPeakCountry(c,y)        'Peak demand [MW] by country and year'
3862    pDemandPeakSystem(y)           'Peak demand [MW] by year'
3863  ;
3864   
3865  pDemandEnergyZone(z,y) = sum((q,d,t), pDemandData(z,q,d,y,t) * pHours(q,d,t) * pEnergyEfficiencyFactor(z,y)) / 1e3;
3866  pDemandEnergyCountry(c,y) = sum(zcmap(z,c), pDemandEnergyZone(z,y));
3867  pDemandEnergySystem(y) = sum(z, pDemandEnergyZone(z,y));
3868   
3869  pDemandPeakZone(z,y) = smax((q,d,t), pDemandData(z,q,d,y,t) * pEnergyEfficiencyFactor(z,y));
3870  pDemandPeakCountry(c,y) = smax((q,d,t), sum(zcmap(z,c), pDemandData(z,q,d,y,t) * pEnergyEfficiencyFactor(z,y)));
3871  pDemandPeakSystem(y) = smax((q,d,t), sum(z, pDemandData(z,q,d,y,t) * pEnergyEfficiencyFactor(z,y)));
3872   
3873  * ---------------------------------------------------------
3874  * Zone-level cost components [$m]
3875  * ---------------------------------------------------------
3876  * Each entry in pCosts stores one annual cost component
3877  * at the zonal level in million $.
3878  *
3879  * Categories included:
3880  *   - Investment costs
3881  *   - Fixed O&M
3882  *   - Variable O&M
3883  *   - Fuel costs
3884  *   - Transmission costs
3885  *   - Spinning reserve costs
3886  *   - Unmet demand, reserve, and CO2 backstop costs
3887  *       (allocated proportionally to zonal demand at country/system level)
3888  *   - Excess generation
3889  *   - VRE curtailment
3890  *   - Import/export costs (external and internal zones)
3891  *   - Trade shared benefits
3892  *   - Carbon costs (system-wide total)
3893  * ---------------------------------------------------------
3894   
3895  * Investment-related costs
3896  pCosts(z, "Investment costs: $m", y) =
3897    vAnnCapex.l(z, y) / 1e6;
3898   
3899  pCosts(z, "Transmission costs: $m", y) =
3900    vAnnualizedTransmissionCapex.l(z, y) / 1e6;
3901   
3902  * Operation-related costs
3903  pCosts(z, "Fixed O&M: $m", y) =
3904    vYearlyFOMCost.l(z, y) / 1e6;
3905   
3906  pCosts(z, "Variable O&M: $m", y) =
3907    vYearlyVOMCost.l(z, y) / 1e6;
3908   
3909  pCosts(z, "Startup costs: $m", y) =
3910    vYearlyStartupCost.l(z, y) / 1e6;
3911   
3912  pCosts(z, "Fuel costs: $m", y) =
3913    vYearlyFuelCost.l(z, y) / 1e6;
3914   
3915  * System balancing costs
3916  pCosts(z, "Unmet demand costs: $m", y) =
3917    vYearlyUSECost.l(z, y) / 1e6;
3918   
3919  pCosts(z, "Excess generation: $m", y) =
3920    vYearlySurplus.l(z, y) / 1e6;
3921   
3922  pCosts(z, "VRE curtailment: $m", y) =
3923    vYearlyCurtailmentCost.l(z, y) / 1e6;
3924   
3925  * Reserve-related costs
3926  pCosts(z, "Spinning reserve costs: $m", y) =
3927    vYearlySpinningReserveCost.l(z, y) / 1e6;
3928   
3929  pCosts(z, "Unmet country spinning reserve costs: $m", y) =
3930    sum(c$(zcmap(z, c) and pDemandEnergyCountry(c, y) > 0),
3931      vYearlyUnmetSpinningReserveCostCountry.l(c, y) * (pDemandEnergyZone(z, y) / pDemandEnergyCountry(c, y))
3932    ) / 1e6;
3933   
3934  pCosts(z, "Unmet country planning reserve costs: $m", y) =
3935    sum(c$(zcmap(z, c) and pDemandEnergyCountry(c, y) > 0),
3936      vYearlyUnmetPlanningReserveCostCountry.l(c, y) * (pDemandEnergyZone(z, y) / pDemandEnergyCountry(c, y))
3937    ) / 1e6;
3938   
3939  pCosts(z, "Unmet system planning reserve costs: $m", y) =
3940    vYearlyUnmetPlanningReserveCostSystem.l(y) * (pDemandEnergyZone(z, y) / pDemandEnergySystem(y)) / 1e6;
3941   
3942  pCosts(z, "Unmet system spinning reserve costs: $m", y) =
3943    vYearlyUnmetSpinningReserveCostSystem.l(y) * (pDemandEnergyZone(z, y) / pDemandEnergySystem(y)) / 1e6;
3944   
3945  * Carbon-related costs
3946  pCosts(z, "Carbon costs: $m", y) =
3947    vYearlyCarbonCost.l(z, y) / 1e6;
3948   
3949  pCosts(z, "Unmet country CO2 backstop cost: $m", y) =
3950    sum(c$(zcmap(z, c) and pDemandEnergyCountry(c, y) > 0),
3951      vYearlyCO2BackstopCostCountry.l(c, y) * (pDemandEnergyZone(z, y) / pDemandEnergyCountry(c, y))
3952    ) / 1e6;
3953   
3954  pCosts(z, "Unmet system CO2 backstop cost: $m", y) =
3955    vYearlyCO2BackstopCostSystem.l(y) * (pDemandEnergyZone(z, y) / pDemandEnergySystem(y)) / 1e6;
3956   
3957  * Trade-related costs
3958  pCosts(z, "Import costs with internal zones: $m", y) =
3959    pImportCostsInternal(z, y) / 1e6;
3960   
3961  pCosts(z, "Export revenues with internal zones: $m", y) =
3962    pExportRevenuesInternal(z, y) / 1e6;
3963   
3964  pCosts(z, "Trade shared benefits: $m", y) =
3965    pTradeSharedBenefits(z, y) / 1e6;
3966   
3967  pCosts(z, "Import costs with external zones: $m", y) =
3968    vYearlyImportExternalCost.l(z, y) / 1e6;
3969   
3970  pCosts(z, "Export revenues with external zones: $m", y) =
3971    vYearlyExportExternalCost.l(z, y) / 1e6;
3972   
3973  * Discounted weighted yearly costs by zone
3974  pDiscountedWeightedCosts(z, sumhdr, y) =
3975      pCosts(z, sumhdr, y) * pRR(y) * pWeightYear(y);
3976   
3977  * Cost
3978  pNetPresentCost(z, sumhdr) =
3979      sum(y, pDiscountedWeightedCosts(z, sumhdr, y));
3980   
3981  * ---------------------------------------------------------
3982   
3983  * Cost by country and year
3984  pCostsCountry(c,sumhdr,y) = sum(z$(zcmap(z,c)), pCosts(z,sumhdr,y));
3985   
3986  * ---------------------------------------------------------
3987  * System-level cost summary
3988  * ---------------------------------------------------------
3989  * Aggregates all zone-level costs into a single system-wide
3990  * metric across the entire time horizon.
3991  *
3992  * - pNetPresentCostSystem(sumhdr):
3993  *     Weighted sum of all zone-level costs
3994  *     Units: million $ (after scaling)
3995  *
3996  * - "NPV of system cost: $m":
3997  *     The model's computed Net Present Value of system costs
3998  *     Directly taken from optimization variable vNPVCost
3999  * ---------------------------------------------------------
4000   
4001  pCostsSystem(sumhdr, y) = sum(z, pCosts(z, sumhdr, y));
4002   
4003  * pNetPresentCostSystem(sumhdr) = sum((y,z), pCosts(z,sumhdr,y) * pRR(y) * pWeightYear(y));
4004  pNetPresentCostSystem(sumhdr) = sum(z, pNetPresentCost(z,sumhdr));
4005   
4006  pNetPresentCostSystem("NPV of system cost: $m") = vNPVCost.l/1e6;
4007   
4008  * ---------------------------------------------------------
4009   
4010  * Annual average cost benchmarks ($/MWh) without discounting:
4011  * divide yearly costs by the matching energy basis.
4012  pCostsPerMWh(z,sumhdr,y) =
4013      pCosts(z,sumhdr,y)*1e6 / (pDemandEnergyZone(z,y) * 1e3);
4014   
4015  pCostsCountryPerMWh(c,sumhdr,y) =
4016      1e6 * pCostsCountry(c,sumhdr,y) / (pDemandEnergyCountry(c,y) * 1e3);
4017   
4018  pCostsSystemPerMWh(sumhdr,y) =
4019      1e6 * pCostsSystem(sumhdr, y) / (pDemandEnergySystem(y) * 1e3);
4020   
4021  * Discount zonal demand over the horizon; convert GWh -> MWh via 1e3
4022  * and apply both the discount rate (pRR) and scenario weight (pWeightYear).
4023  pDiscountedDemandZoneMWh(z) =
4024      sum(y, pDemandEnergyZone(z,y) * 1e3 * pRR(y) * pWeightYear(y));
4025   
4026  pDiscountedDemandCountryMWh(c) =
4027      sum(zcmap(z,c), pDiscountedDemandZoneMWh(z));
4028   
4029  pDiscountedDemandSystemMWh =
4030      sum(z, pDiscountedDemandZoneMWh(z));
4031   
4032  * Divide the discounted cost ledger by discounted demand to express
4033  * each zonal cost component as an average $/MWh metric.
4034  pNetPresentCostPerMWh(z,sumhdr)$pDiscountedDemandZoneMWh(z) =
4035      pNetPresentCost(z,sumhdr) * 1e6 / pDiscountedDemandZoneMWh(z);
4036   
4037  * Country totals reuse the zonal discounted costs and demands,
4038  * aggregating before taking the ratio so shared demand weights apply.
4039  pNetPresentCostCountryPerMWh(c,sumhdr)$pDiscountedDemandCountryMWh(c) =
4040      1e6 * sum(zcmap(z,c), pNetPresentCost(z,sumhdr)) / pDiscountedDemandCountryMWh(c);
4041   
4042  * System-wide average cost: sum of discounted zonal costs divided by
4043  * the discounted system demand (sum of zonal denominators).
4044  pNetPresentCostSystemPerMWh(sumhdr)$pDiscountedDemandSystemMWh =
4045      (pNetPresentCostSystem(sumhdr) * 1e6) / pDiscountedDemandSystemMWh;
4046   
4047  * ---------------------------------------------------------
4048  * Fuel costs and consumption [$m, PJ] by zone and country
4049  * ---------------------------------------------------------
4050  * Calculates annual fuel expenditures and consumption
4051  * based on generation output, heat rates, and fuel prices.
4052  * Results are stored at both zonal and country aggregation levels.
4053  * ---------------------------------------------------------
4054   
4055  pFuelCosts(z,f,y) = sum((gzmap(g,z),gfmap(g,f),zcmap(z,c),q,d,t), vPwrOut.l(g,f,q,d,t,y)*pHours(q,d,t)*pFuelPrice(c,f,y)*pHeatRate(g,f))/1e6;
4056  pFuelConsumption(z,f,y) = vFuel.l(z,f,y)/1e6;
4057   
4058  pFuelCostsCountry(c,f,y) = sum(zcmap(z,c), pFuelCosts(z,f,y));
4059  pFuelConsumptionCountry(c,f,y) = sum(zcmap(z,c), pFuelConsumption(z,f,y));
4060   
4061  * ============================================================
4062  * 3. ENERGY BALANCE
4063  * ============================================================
4064   
4065  * ---------------------------------------------------------
4066  * Energy generation by plant, technology-fuel, and country
4067  * ---------------------------------------------------------
4068  * Calculates annual electricity generation (TWh) from model
4069  * outputs at different aggregation levels:
4070  *   - pEnergyPlant: plant-level generation
4071  *   - pEnergyTechFuel / pEnergyTechFuelCountry: by technology and fuel, zonal and country
4072  *   - pEnergyTechFuelComplete: tech-fuel generation plus balance components
4073  *   - pEnergyFuel / pEnergyFuelCountry: by fuel, zonal and country
4074  * ---------------------------------------------------------
4075   
4076  pEnergyPlant(zgmap(z,g),y) = sum((gfmap(g,f),q,d,t), vPwrOut.l(g,f,q,d,t,y)*pHours(q,d,t))/1e3;
4077  pEnergyFuel(z,f,y) = sum((gzmap(g,z),gfmap(g,f),q,d,t), vPwrOut.l(g,f,q,d,t,y)*pHours(q,d,t))/1e3;
4078  pEnergyFuelCountry(c,f,y) = sum(zcmap(z,c), pEnergyFuel(z,f,y));
4079   
4080  * Energy balance including demand slack, surplus, and exchanges
4081  pEnergyFuelComplete(z,f,y) = pEnergyFuel(z,f,y);
4082  pEnergyFuelComplete(z,"UnmetDemand",y) = sum((q,d,t), vUSE.l(z,q,d,t,y)*pHours(q,d,t))/1e3;
4083  pEnergyFuelComplete(z,"Surplus",y) = sum((q,d,t), vSurplus.l(z,q,d,t,y)*pHours(q,d,t))/1e3;
4084  pEnergyFuelComplete(z,"Imports",y) = sum((sTopology(Zd,z),q,d,t), vFlow.l(Zd,z,q,d,t,y)*pHours(q,d,t))/1e3;
4085  pEnergyFuelComplete(z,"Imports External",y) = sum((zext,q,d,t), vYearlyImportExternal.l(z,zext,q,d,t,y)*pHours(q,d,t))/1e3;
4086  pEnergyFuelComplete(z,"Exports",y) = -sum((sTopology(z,Zd),q,d,t), vFlow.l(z,Zd,q,d,t,y)*pHours(q,d,t))/1e3;
4087  pEnergyFuelComplete(z,"Exports External",y) = -sum((zext,q,d,t), vYearlyExportExternal.l(z,zext,q,d,t,y)*pHours(q,d,t))/1e3;
4088   
4089  pEnergyTechFuel(z,tech,f,y) = sum((gzmap(g,z),gtechmap(g,tech),gfmap(g,f),q,d,t), vPwrOut.l(g,f,q,d,t,y)*pHours(q,d,t))/1e3;
4090  pEnergyTechFuelCountry(c,tech,f,y) = sum(zcmap(z,c), pEnergyTechFuel(z,tech,f,y));
4091  * Copy slack components under synthetic technology "EnergyBalance"
4092  pEnergyTechFuelComplete(z,tech,f,y) = pEnergyTechFuel(z,tech,f,y);
4093  pEnergyTechFuelComplete(z,"EnergyBalance",fEnergyBalance,y) = pEnergyFuelComplete(z,fEnergyBalance,y);
4094   
4095   
4096  * ---------------------------------------------------------
4097  * Utilization factors by plant, technology, fuel, and country
4098  * ---------------------------------------------------------
4099  * Computes average utilization (capacity factor) as the ratio
4100  * of generated energy to available capacity and hours:
4101  *   - pUtilizationPlant / pUtilizationTech: plant-level
4102  *     and tech-level capacity factors
4103  *   - pUtilizationFuel / pUtilizationTechFuel: by fuel and tech-fuel at zone level
4104  *   - pUtilizationFuelCountry / pUtilizationTechFuelCountry:
4105  *     by fuel and tech-fuel at country level
4106  * ---------------------------------------------------------
4107   
4108   
4109  * Plant-level utilization (capacity factor, annual average)
4110  pUtilizationPlant(zgmap(z,g),y)$vCap.l(g,y) =
4111    sum((gfmap(g,f), q, d, t), vPwrOut.l(g,f,q,d,t,y) * pHours(q,d,t))
4112    / vCap.l(g,y) / 8760;
4113   
4114  * Technology-level utilization (capacity factor, annual average)
4115  pUtilizationTech(z, tech, y)$sum((zgmap(z,g), gfmap(g,f), gtechmap(g,tech))$vCap.l(g,y), vCap.l(g,y)) =
4116    sum((zgmap(z,g), gfmap(g,f), gtechmap(g,tech), q, d, t)$vCap.l(g,y),
4117      vPwrOut.l(g,f,q,d,t,y) * pHours(q,d,t))
4118    / sum((zgmap(z,g), gfmap(g,f), gtechmap(g,tech))$vCap.l(g,y), vCap.l(g,y))
4119    / 8760;
4120   
4121  * Fuel-level utilization (capacity factor, annual average)
4122  pUtilizationFuel(z, f, y)$(pCapacityFuel(z, f, y)) =
4123    pEnergyFuel(z, f, y)
4124    / (pCapacityFuel(z, f, y) * sum((q, d, t), pHours(q, d, t)))
4125    * 1000;
4126   
4127  * Technology-fuel-level utilization (capacity factor, annual average)
4128  pUtilizationTechFuel(z, tech, f, y)$(pCapacityTechFuel(z, tech, f, y)) =
4129    pEnergyTechFuel(z, tech, f, y)
4130    / (pCapacityTechFuel(z, tech, f, y) * sum((q, d, t), pHours(q, d, t)))
4131    * 1000;
4132   
4133  * Country-level fuel utilization (capacity factor, annual average)
4134  pUtilizationFuelCountry(c, f, y)$(pCapacityFuelCountry(c, f, y)) =
4135    pEnergyFuelCountry(c, f, y)
4136    / (pCapacityFuelCountry(c, f, y) * sum((q, d, t), pHours(q, d, t)))
4137    * 1000;
4138   
4139  * Country-level technology-fuel utilization (capacity factor, annual average)
4140  pUtilizationTechFuelCountry(c, tech, f, y)$(pCapacityTechFuelCountry(c, tech, f, y)) =
4141    pEnergyTechFuelCountry(c, tech, f, y)
4142    / (pCapacityTechFuelCountry(c, tech, f, y) * sum((q, d, t), pHours(q, d, t)))
4143    * 1000;
4144   
4145   
4146  * ---------------------------------------------------------
4147  * Energy balance [GWh] by zone and country
4148  * ---------------------------------------------------------
4149  * Accounts for demand (electricity and H2), production,
4150  * unmet demand, surplus generation, imports/exports,
4151  * and net interchange, with aggregation to country level.
4152  * ---------------------------------------------------------
4153   
4154  pEnergyBalance(z, "Demand: GWh", y) =
4155    sum((q, d, t), pDemandData(z, q, d, y, t) * pHours(q, d, t) * pEnergyEfficiencyFactor(z, y)) / 1e3;
4156   
4157  pEnergyBalance(z, "Demand H2: GWh", y) =
4158    (sum((h2zmap(hh, z), q, d, t), vH2PwrIn.l(hh, q, d, t, y) * pHours(q, d, t)) / 1e3) $ (fEnableH2Production + 1e-6);
4159   
4160  pEnergyBalance(z, "Total Demand: GWh", y) =
4161    pEnergyBalance(z, "Demand: GWh", y) + pEnergyBalance(z, "Demand H2: GWh", y);
4162   
4163  pEnergyBalance(z, "Total production: GWh", y) =
4164    sum(gzmap(g, z), pEnergyPlant(z, g, y));
4165   
4166  pEnergyBalance(z, "Unmet demand: GWh", y) =
4167    sum((q, d, t), vUSE.l(z, q, d, t, y) * pHours(q, d, t)) / 1e3;
4168   
4169  pEnergyBalance(z, "Surplus generation: GWh", y) =
4170    sum((q, d, t), vSurplus.l(z, q, d, t, y) * pHours(q, d, t)) / 1e3;
4171   
4172  pEnergyBalance(z, "Imports exchange: GWh", y) =
4173    (sum((sTopology(z, z2), q, d, t), vFlow.l(z2, z, q, d, t, y) * pHours(q, d, t))
4174     + sum((zext, q, d, t), vYearlyImportExternal.l(z, zext, q, d, t, y) * pHours(q, d, t))) / 1e3;
4175   
4176  pEnergyBalance(z, "Exports exchange: GWh", y) =
4177    (sum((sTopology(z, z2), q, d, t), vFlow.l(z, z2, q, d, t, y) * pHours(q, d, t))
4178     + sum((zext, q, d, t), vYearlyExportExternal.l(z, zext, q, d, t, y) * pHours(q, d, t))) / 1e3;
4179   
4180  pEnergyBalance(z, "Net interchange: GWh", y) =
4181    pEnergyBalance(z, "Imports exchange: GWh", y) - pEnergyBalance(z, "Exports exchange: GWh", y);
4182   
4183  pEnergyBalance(z, "Net interchange Ratio: GWh", y) $ pEnergyBalance(z, "Demand: GWh", y) =
4184    pEnergyBalance(z, "Net interchange: GWh", y) / pEnergyBalance(z, "Demand: GWh", y);
4185   
4186  pEnergyBalanceCountry(c,dshdr,y) = sum(z$(zcmap(z,c)), pEnergyBalance(z,dshdr,y));
4187   
4188   
4189  *--- H2 Demand-Supply Balance
4190  pEnergyBalanceH2(z,"Demand H2: GWh",y)   =(sum( (h2zmap(hh,z), q,d,t), vH2PwrIn.l(hh,q,d,t,y)*pHours(q,d,t))/1000)$fEnableH2Production+1e-6;
4191  pEnergyBalanceH2(z,"Production H2: mmBTU",           y)        =sum( (h2zmap(hh,z), q,d,t), vH2PwrIn.l(hh,q,d,t,y)*pHours(q,d,t)*pH2Data(hh,"HeatRate"))$fEnableH2Production+1e-6;
4192  pEnergyBalanceH2(z,"External Demand H2: mmBTU",         y)        =sum(q,pExternalH2(z,q,y)       )$fEnableH2Production+1e-6;
4193  pEnergyBalanceH2(z,"Unmet External Demand H2: mmBTU",   y)        =sum(q,vUnmetExternalH2.l(z,q,y))$fEnableH2Production+1e-6;
4194  pEnergyBalanceH2(z,"H2 Power: mmBTU",       y)        =sum(q,vFuelH2Quarter.l(z,q,y)  )$fEnableH2Production+1e-6;
4195   
4196  pEnergyBalanceCountryH2(c,dsH2hdr,y) = sum(z$(zcmap(z,c)), pEnergyBalanceH2(z,dsH2hdr,y));
4197   
4198  * ============================================================
4199  * 4. ENERGY DISPATCH
4200  * ============================================================
4201   
4202  * ---------------------------------------------------------
4203  * Hourly dispatch reporting: plant, fuel, and zone level
4204  * ---------------------------------------------------------
4205  * - pDispatchPlant: plant-level hourly generation and reserve [MW]
4206  * - pDispatchFuel: fuel-level hourly generation [MW]
4207  * - pDispatch: zone-level hourly imports, exports, unmet demand, storage charge, and demand [MW]
4208  * ---------------------------------------------------------
4209   
4210  pDispatchPlant(z, y, q, d, g, t, "Generation")$zgmap(z, g) = sum(gfmap(g, f), vPwrOut.l(g, f, q, d, t, y));
4211  pDispatchPlant(z, y, q, d, g, t, "Reserve")$zgmap(z, g) = vSpinningReserve.l(g, q, d, t, y);
4212   
4213  pDispatchFuel(z, y, q, d, f, t) = sum((gzmap(g, z), gfmap(g, f)), vPwrOut.l(g, f, q, d, t, y));
4214  pDispatchTechFuel(z, y, q, d, tech, f, t) =
4215    sum((gzmap(g, z), gtechmap(g, tech), gfmap(g, f)), vPwrOut.l(g, f, q, d, t, y));
4216   
4217  pDispatch(z, y, q, d, "Imports", t) = sum(sTopology(z, z2), vFlow.l(z2, z, q, d, t, y)) + sum(zext, vYearlyImportExternal.l(z, zext, q, d, t, y));
4218  pDispatch(z, y, q, d, "Exports", t) = -sum(sTopology(z, z2), vFlow.l(z, z2, q, d, t, y)) - sum(zext, vYearlyExportExternal.l(z, zext, q, d, t, y));
4219  pDispatch(z, y, q, d, "Unmet demand", t) = vUSE.l(z, q, d, t, y);
4220  pDispatch(z, y, q, d, "Storage Charge", t) = -sum(zgmap(z, st), vStorInj.l(st, q, d, t, y));
4221  pDispatch(z, y, q, d, "Demand", t) = pDemandData(z, q, d, y, t) * pEnergyEfficiencyFactor(z, y);
4222   
4223  * ============================================================
4224  * 5. RESERVES
4225  * ============================================================
4226   
4227  * ---------------------------------------------------------
4228  * Spinning reserve and reserve margin reporting
4229  * ---------------------------------------------------------
4230  * - pReserveSpinningPlantZone: annual spinning reserve provided by plant and zone [GWh]
4231  * - pReserveSpinningFuelZone: annual spinning reserve provided by fuel and zone [GWh]
4232  * - pReserveSpinningPlantCountry: annual spinning reserve provided by plant and country [GWh]
4233  * - pReserveMargin / pReserveMarginCountry: peak demand, total firm capacity, and reserve margin by zone/country
4234  * ---------------------------------------------------------
4235   
4236  pReserveSpinningPlantZone(zgmap(z,g),y) = sum((q,d,t), vSpinningReserve.l(g,q,d,t,y)*pHours(q,d,t))/1e3 ;
4237  pReserveSpinningFuelZone(z,f,y) = sum((gzmap(g,z),gfmap(g,f),q,d,t), vSpinningReserve.l(g,q,d,t,y)*pHours(q,d,t))/1e3 ;
4238  pReserveSpinningTechFuelZone(z,tech,f,y) =
4239    sum((gzmap(g,z),gtechmap(g,tech),gfmap(g,f),q,d,t), vSpinningReserve.l(g,q,d,t,y)*pHours(q,d,t))/1e3 ;
4240  pReserveSpinningPlantCountry(c,g,y)=  sum((zcmap(z,c),zgmap(z,g)), pReserveSpinningPlantZone(z,g,y));
4241  pReserveSpinningTechFuelCountry(c,tech,f,y) =
4242    sum(zcmap(z,c), pReserveSpinningTechFuelZone(z,tech,f,y));
4243   
4244  pReserveMargin(z,"Peak demand: MW",y) = smax((q,d,t), pDemandData(z,q,d,y,t)*pEnergyEfficiencyFactor(z,y));
4245  pReserveMargin(z,"TotalFirmCapacity",y) = sum(zgmap(z,g), pCapacityCredit(g,y)* vCap.l(g,y));
4246  pReserveMargin(z,"ReserveMargin",y)$(pReserveMargin(z,"TotalFirmCapacity",y)) = pReserveMargin(z,"TotalFirmCapacity",y)/pReserveMargin(z,"Peak demand: MW",y)  ;
4247   
4248  pReserveMarginCountry(c,"Peak demand: MW",y) =   pCapacitySummaryCountry(c,"Peak demand: MW"       ,y);
4249  pReserveMarginCountry(c,"TotalFirmCapacity",y) = sum(zcmap(z,c), pReserveMargin(z,"TotalFirmCapacity",y));
4250  pReserveMarginCountry(c,"ReserveMargin",y)$(pReserveMarginCountry(c,"TotalFirmCapacity",y)) = pReserveMarginCountry(c,"TotalFirmCapacity",y)/ pReserveMarginCountry(c,"Peak demand: MW",y)  ;
4251   
4252  * ============================================================
4253  * 6. INTERCONNECTIONS
4254  * ============================================================
4255   
4256  * ---------------------------------------------------------
4257  * Internal zones: interchange, utilization, losses, congestion
4258  * ---------------------------------------------------------
4259  * - pInterchange / pInterchangeCountry: net interchange flow [GWh]
4260  * - pInterconUtilization: utilization of transfer capacity [%]
4261  * - pLossesTransmission / pLossesTransmissionCountry: transmission losses [GWh]
4262  * - isCongested / pCongestionShare: binary indicator and share of time congested
4263  * ---------------------------------------------------------
4264   
4265  * Annual interchange between internal zones [GWh]
4266  pInterchange(sTopology(z, z2), y) =
4267    sum((q, d, t), vFlow.l(z, z2, q, d, t, y) * pHours(q, d, t)) / 1e3;
4268   
4269   
4270  * Utilization of interconnection throughout modeling horizon [%]
4271  pInterconUtilization(sTopology(z, z2), y)$pInterchange(z, z2, y) =
4272    1e3 * pInterchange(z, z2, y)
4273    / sum((q, d, t),
4274      (pTransferLimit(z, z2, q, y)
4275       + vNewTransmissionLine.l(z, z2, y)
4276         * max(pNewTransmission(z, z2, "CapacityPerLine"),
4277           pNewTransmission(z2, z, "CapacityPerLine"))
4278         * fAllowTransferExpansion)
4279      * pHours(q, d, t)
4280      );
4281   
4282  * Transmission losses between internal zones in MWh per zone
4283  pLossesTransmission(z, y) =
4284    sum((sTopology(z, z2), q, d, t),
4285      vFlow.l(z2, z, q, d, t, y) * pLossFactorInternal(z, z2, y) * pHours(q, d, t)
4286    );
4287   
4288  * Country-level interchange and losses
4289  alias (zcmap, zcmap2);
4290   
4291  pInterchangeCountry(c, c2, y) =
4292    sum((zcmap(z, c), zcmap2(z2, c2), sMapConnectedZonesDiffCountries(z2, z)),
4293      pInterchange(z, z2, y)
4294    );
4295   
4296  pLossesTransmissionCountry(c, y) =
4297    sum(zcmap(z, c), pLossesTransmission(z, y));
4298   
4299  * Binary indicator for congestion per time step
4300  isCongested(z, z2, q, d, t, y)$(
4301    sTopology(z, z2)
4302    and abs(
4303      vFlow.l(z, z2, q, d, t, y)
4304      - (
4305        pTransferLimit(z, z2, q, y)
4306        + vNewTransmissionLine.l(z, z2, y)
4307          * max(pNewTransmission(z, z2, "CapacityPerLine"),
4308            pNewTransmission(z2, z, "CapacityPerLine"))
4309          * fAllowTransferExpansion
4310        )
4311      ) < 1e-5
4312  ) = 1;
4313   
4314  * Percentage of time (weighted by pHours) when the line is congested
4315  pCongestionShare(sTopology(z, z2), y) =
4316    sum((q, d, t), isCongested(z, z2, q, d, t, y) * pHours(q, d, t))
4317    / sum((q, d, t), pHours(q, d, t));
4318   
4319   
4320  * ---------------------------------------------------------
4321  * External zones: imports and exports
4322  * ---------------------------------------------------------
4323  * - pHourlyInterchangeExternal / pYearlyInterchangeExternal: hourly and annual imports/exports [GWh]
4324  * - pInterchangeExternalExports / pInterconUtilizationExternalExports: exports and line utilization [%]
4325  * - pInterchangeExternalImports / pInterconUtilizationExternalImports: imports and line utilization [%]
4326  * - pHourlyInterchangeExternalCountry / pYearlyInterchangeExternalCountry: aggregated country-level interchange [GWh]
4327  * ---------------------------------------------------------
4328   
4329  set thrd / Imports, Exports /;
4330  set isExternal / Internal, External /;
4331   
4332  * Hourly interchange with external zones [MW]
4333  pHourlyInterchangeExternal(z, y, q, d, "Imports", t) =
4334    sum(zext, vYearlyImportExternal.l(z, zext, q, d, t, y));
4335   
4336  pHourlyInterchangeExternal(z, y, q, d, "Exports", t) =
4337    sum(zext, vYearlyExportExternal.l(z, zext, q, d, t, y));
4338   
4339  * Annual interchange with external zones [GWh]
4340  pYearlyInterchangeExternal(z, thrd, y) =
4341    sum((q, d, t), pHourlyInterchangeExternal(z, y, q, d, thrd, t) * pHours(q, d, t)) / 1e3;
4342   
4343  * Annual exports and imports with external zones [GWh]
4344  pInterchangeExternalExports(z, zext, y) =
4345    sum((q, d, t), vYearlyExportExternal.l(z, zext, q, d, t, y) * pHours(q, d, t)) / 1e3;
4346   
4347  pInterchangeExternalImports(zext, z, y) =
4348    sum((q, d, t), vYearlyImportExternal.l(z, zext, q, d, t, y) * pHours(q, d, t)) / 1e3;
4349   
4350  * Utilization of external interconnections [%]
4351  pInterconUtilizationExternalExports(z, zext, y)$pInterchangeExternalExports(z, zext, y) =
4352    1e3 * pInterchangeExternalExports(z, zext, y)
4353    / sum((q, d, t), pExtTransferLimitOut(z, zext, q, y) * pHours(q, d, t));
4354   
4355  pInterconUtilizationExternalImports(zext, z, y)$pInterchangeExternalImports(zext, z, y) =
4356    1e3 * pInterchangeExternalImports(zext, z, y)
4357    / sum((q, d, t), pExtTransferLimitIn(z, zext, q, y) * pHours(q, d, t));
4358   
4359  * Country-level hourly and annual interchange with external zones
4360  pHourlyInterchangeExternalCountry(c, y, q, d, thrd, t) =
4361    sum(zcmap(z, c), pHourlyInterchangeExternal(z, y, q, d, thrd, t));
4362   
4363  pYearlyInterchangeExternalCountry(c, thrd, y) =
4364    sum(zcmap(z, c), pYearlyInterchangeExternal(z, thrd, y));
4365   
4366  * ---------------------------------------------------------
4367  * Net import by zone and source zone type
4368  * ---------------------------------------------------------
4369  * Calculates net import (imports - exports) for each zone from
4370  * every other zone, distinguishing between internal and external zones.
4371  * Positive values indicate net imports, negative values indicate net exports.
4372  * ---------------------------------------------------------
4373   
4374  * Net import from internal zones
4375  * pInterchange(z, z2, y) represents flow from z to z2
4376  * Net import from z2 to z = -pInterchange(z, z2, y) when sTopology(z, z2) exists
4377  * If only reverse direction exists, use pInterchange(z2, z, y) directly
4378  pNetImport(z, z2, y, "Internal")$sTopology(z, z2) = -pInterchange(z, z2, y) / 1e3;
4379  pNetImport(z, z2, y, "Internal")$(sTopology(z2, z) and not sTopology(z, z2)) = pInterchange(z2, z, y) / 1e3;
4380   
4381  * Net import from external zones
4382  * Net import from zext to z = imports from zext - exports to zext
4383  pNetImport(z, zext, y, "External") =
4384    pInterchangeExternalImports(zext, z, y) - pInterchangeExternalExports(z, zext, y) / 1e3;
4385   
4386  * ============================================================
4387  * 7. EMISSIONS
4388  * ============================================================
4389   
4390  * ---------------------------------------------------------
4391  * Emissions reporting: zone, country, and marginal costs
4392  * ---------------------------------------------------------
4393  * - pEmissionsZone: total CO2 emissions [Mt] by zone and year
4394  * - pEmissionsIntensityZone: CO2 intensity [tCO2/GWh] by zone and year
4395  * - pEmissionsCountrySummary: total and backstop CO2 emissions [Mt] by country and year
4396  * - pEmissionsIntensityCountry: CO2 intensity [tCO2/GWh] by country and year
4397  * - pEmissionMarginalCosts / pEmissionMarginalCostsCountry: marginal cost of emission constraints [USD/tCO2]
4398  * ---------------------------------------------------------
4399   
4400  pEmissionsZone(z,y)                                                     =  vZonalEmissions.l(z,y)/1e6 ;
4401  pEmissionsIntensityZone(z,y)$pEnergyBalance(z,"Total production: GWh",y) = 1e-3*pEmissionsZone(z,y)/pEnergyBalance(z,"Total production: GWh",y);
4402  pEmissionsCountrySummary(c,"Emissions: mm tCO2eq",y)                               = sum(zcmap(z,c), pEmissionsZone(z,y));
4403  pEmissionsCountrySummary(c,"CO2backstopEmissions: mm tCO2eq",y)                    = vYearlyCO2backstop.l(c,y)/1e6;
4404  pEmissionsIntensityCountry(c,y)$pEnergyBalanceCountry(c,"Total production: GWh",y) = 1e-3*sum(zcmap(z,c), vZonalEmissions.l(z,y))/pEnergyBalanceCountry(c,"Total production: GWh",y);
4405   
4406  pEmissionMarginalCosts(y) $(pWeightYear(y))                  = -eTotalEmissionsConstraint.M(y)/pRR(y)/pWeightYear(y);
4407  pEmissionMarginalCostsCountry(c,y) $(pWeightYear(y))         = -eEmissionsCountry.M(c,y)/pRR(y)/pWeightYear(y);
4408   
4409  * ============================================================
4410  * 8. PRICES
4411  * ============================================================
4412  * ---------------------------------------------------------
4413  * Average yearly electricity prices at zone and country level
4414  * ---------------------------------------------------------
4415  * Calculates demand-weighted consumer prices, export/import
4416  * prices weighted by actual flows (internal & external),
4417  * and hub prices. Aggregates results to country averages
4418  * using zonal weights and interconnection flows.
4419  * ---------------------------------------------------------
4420   
4421  * Average yearly price paid by consumers, weighted by demand
4422  pPrice(z,y)$pEnergyBalance(z,"Demand: GWh",y) = 1e-3*sum((q,d,t),pHourlyPrice(z,q,d,t,y)*pDemandData(z,q,d,y,t)*pHours(q,d,t)*pEnergyEfficiencyFactor(z,y))
4423                                                       /pEnergyBalance(z,"Demand: GWh",y) ;
4424   
4425  Parameter
4426    pFlowMWSum(z,z2,y)    "Sum of hourly MW flows over the year (used for weights)"
4427    pFlowMWh(z,z2,y)      "Annual energy flow between zones [MWh]"
4428  ;
4429   
4430  pFlowMWSum(z,z2,y) = sum(sFlow(z,z2,q,d,t,y),vFlow.l(z,z2,q,d,t,y));
4431  pFlowMWh(z,z2,y) = sum(sFlow(z,z2,q,d,t,y),vFlow.l(z,z2,q,d,t,y)*pHours(q,d,t));
4432   
4433  * Average price of exports and imports, weighted by actual flows on the lines
4434  pPriceExport(z,y) $(sum(Zd, pFlowMWh(z,Zd,y))  > 0) = (sum((sTopology(z,Zd),q,d,t),  pHourlyPrice(z,q,d,t,y) *vFlow.l(z,Zd,q,d,t,y)*pHours(q,d,t))
4435                                                             + sum((zext,q,d,t), vYearlyExportExternal.l(z,zext,q,d,t,y) * pTradePrice(zext,q,d,y,t) * pHours(q,d,t)))
4436                                                           /(sum(Zd, pFlowMWh(z,Zd,y))+ sum((zext,q,d,t), vYearlyExportExternal.l(z,zext,q,d,t,y)* pHours(q,d,t)));
4437   
4438  pPriceImport(z,y) $(sum(Zd, pFlowMWh(Zd,z,y))  > 0) = (sum((sTopology(Zd,z),q,d,t),  pHourlyPrice(Zd,q,d,t,y)*vFlow.l(Zd,z,q,d,t,y)*pHours(q,d,t))
4439                                                              + sum((zext,q,d,t), vYearlyImportExternal.l(z,zext,q,d,t,y) * pTradePrice(zext,q,d,y,t) * pHours(q,d,t)))
4440                                                           /(sum(Zd, pFlowMWh(Zd,z,y))+ sum((zext,q,d,t), vYearlyImportExternal.l(z,zext,q,d,t,y)  * pHours(q,d,t)));
4441   
4442  * Average price at the hub, weighted by actual flows on the lines (TODO: check not with pHours)
4443  pPriceHub(Zt,y)$(sum(Zd, pFlowMWSum(Zt,Zd,y))   > 0) = sum((sTopology(Zt,Zd),q,d,t), pHourlyPrice(Zt,q,d,t,y)*vFlow.l(Zt,Zd,q,d,t,y))
4444                                                           /sum(Zd, pFlowMWSum(Zt,Zd,y));
4445   
4446  * Average yearly price paid by consumers, weighted by demand
4447  pPriceCountry(c,y)$pEnergyBalanceCountry(c,"Demand: GWh",y) = sum(zcmap(z,c), pPrice(z,y)*pEnergyBalance(z,"Demand: GWh",y))/pEnergyBalanceCountry(c,"Demand: GWh",y);
4448   
4449  * ---------------------------------------------------------
4450  * Country-level interconnection energy flows [MWh]
4451  * ---------------------------------------------------------
4452  * Aggregated annual energy exchanged between a country and its
4453  * neighboring countries, used as weights to compute average
4454  * export and import prices:
4455  *   - pCountryExportFlowMWh: total export energy from country c
4456  *   - pCountryImportFlowMWh: total import energy into country c
4457  * ---------------------------------------------------------
4458   
4459  Parameter
4460      pCountryExportFlowMWh(c,y) "Annual exported energy [MWh] from country c"
4461      pCountryImportFlowMWh(c,y) "Annual imported energy [MWh] into country c";
4462   
4463  pCountryExportFlowMWh(c,y) = sum((zcmap(z,c), sMapConnectedZonesDiffCountries(z,Zd)), pFlowMWh(z,Zd,y));
4464   
4465  pPriceExportCountry(c,y)$(pCountryExportFlowMWh(c,y) > 0) =
4466      sum((zcmap(z,c), sMapConnectedZonesDiffCountries(z,Zd),q,d,t),
4467          pHourlyPrice(z,q,d,t,y)*vFlow.l(z,Zd,q,d,t,y)*pHours(q,d,t))
4468      / pCountryExportFlowMWh(c,y);
4469   
4470  pCountryImportFlowMWh(c,y) = sum((zcmap(z,c), sMapConnectedZonesDiffCountries(Zd,z)), pFlowMWh(Zd,z,y));
4471   
4472  pPriceImportCountry(c,y)$(pCountryImportFlowMWh(c,y) > 0) =
4473      sum((zcmap(z,c), sMapConnectedZonesDiffCountries(Zd,z),q,d,t),
4474          pHourlyPrice(Zd,q,d,t,y)*vFlow.l(Zd,z,q,d,t,y)*pHours(q,d,t))
4475      / pCountryImportFlowMWh(c,y);
4476   
4477   
4478   
4479  * ============================================================
4480  * 9. SPECIAL TECHNOLOGIES
4481  * ============================================================
4482  * ---------------------------------------------------------
4483  * CSP, PV+Storage, and Generic Storage balances and components
4484  * ---------------------------------------------------------
4485  * Tracks technology-specific balances and installed components:
4486  *   - pCSPBalance: thermal, storage input/output, and power output by CSP
4487  *   - pCSPComponents: thermal field, storage, power block, solar multiple, storage hours
4488  *   - pPVwSTOBalance: PV output, storage input/output, storage losses and levels for PV+storage systems
4489  *   - pPVwSTOComponents: PV capacity, storage MW/MWh, storage hours
4490  *   - pStorageBalance: input, output, losses, net change, and storage level for generic storage
4491  *   - pStorageComponents: installed MW, MWh, and storage hours
4492  * ---------------------------------------------------------
4493   
4494  pCSPBalance(y, g,q,d,"Thermal output",t) = vThermalOut.l(g,q,d,t,y);
4495  pCSPBalance(y,cs,q,d,"Storage Input" ,t) = vStorInj.l(cs,q,d,t,y);
4496  pCSPBalance(y,cs,q,d,"Storage Output",t) = vStorOut.l(cs,q,d,t,y);
4497  pCSPBalance(y,cs,q,d,"Power Output"  ,t) = sum(gfmap(cs,f), vPwrOut.l(cs,f,q,d,t,y));
4498   
4499  pCSPComponents(g, "Thermal Field: WM" ,y) = vCapTherm.l(g,y);
4500  pCSPComponents(cs,"Storage: MWh"      ,y) = vCapStor.l(cs,y);
4501  pCSPComponents(cs,"Power Block: MW"   ,y) = vCap.l(cs,y);
4502  pCSPComponents(g, "Solar Multiple"    ,y) = vCapTherm.l(g,y)/max(vCap.l(g,y),1);
4503  pCSPComponents(cs,"Storage Hours: hrs",y) = vCapStor.l(cs,y)/max(vCap.l(cs,y),1);
4504   
4505  pPVwSTOBalance(y,q,d,so, "PV output"     ,t) = sum(gfmap(so,f), vPwrOut.l(so,f,q,d,t,y));
4506  pPVwSTOBalance(y,q,d,stp,"Storage Input" ,t) = vStorInj.l(stp,q,d,t,y);
4507  pPVwSTOBalance(y,q,d,stp,"Storage output",t) = sum(gfmap(stp,f), vPwrOut.l(stp,f,q,d,t,y));
4508  pPVwSTOBalance(y,q,d,stp,"Storage Losses",t) = (1-pStorageData(stp,"Efficiency"))*vStorInj.l(stp,q,d,t,y);
4509  pPVwSTOBalance(y,q,d,stp,"Storage level" ,t) = vStorage.l(stp,q,d,t,y);
4510   
4511  pPVwSTOComponents(so, "PV Plants"           ,y) = vCap.l(so,y);
4512  pPVwSTOComponents(stp,"Storage Capacity MW" ,y) = vCap.l(stp,y);
4513  pPVwSTOComponents(stp,"Storage Capacity MWh",y) = vCapStor.l(stp,y);
4514  pPVwSTOComponents(stp,"Storage Hours"       ,y) = vCapStor.l(stp,y)/max(vCap.l(stp,y),1);
4515   
4516  pStorageBalance(y,stg,q,d,"Storage Input"     ,t) = vStorInj.l(stg,q,d,t,y);
4517  pStorageBalance(y,stg,q,d,"Storage Output"    ,t) = sum(gfmap(stg,f), vPwrOut.l(stg,f,q,d,t,y));
4518  pStorageBalance(y,stg,q,d,"Storage Losses"    ,t) = (1-pStorageData(stg,"Efficiency"))*vStorInj.l(stg,q,d,t,y);
4519  pStorageBalance(y,stg,q,d,"Net Storage Change",t) = vStorNet.l(stg,q,d,t,y);
4520  pStorageBalance(y,stg,q,d,"Storage Level"     ,t) = vStorage.l(stg,q,d,t,y);
4521   
4522  pStorageComponents(stg,"Storage Capacity: MW",y) = vCap.l(stg,y);
4523  pStorageComponents(stg,"Storage Capacity: MWh"  ,y) = vCapStor.l(stg,y);
4524  pStorageComponents(stg,"Storage Hours"         ,y) = vCapStor.l(stg,y)/max(vCap.l(stg,y),1);
4525   
4526  * ---------------------------------------------------------
4527  * Zonal solar energy, value, and cost indicators
4528  * ---------------------------------------------------------
4529  * Computes solar power output, annual energy, market value,
4530  * and levelized cost of solar at the zonal level:
4531  *   - pSolarPower: hourly solar generation
4532  *   - pSolarEnergyZone: total annual solar energy (MWh)
4533  *   - pSolarValueZone: average market value of solar ($/MWh)
4534  *   - pSolarCost: levelized cost of solar based on Investment costs ($/MWh)
4535  * ---------------------------------------------------------
4536   
4537  set PVtech(tech) / PV, PVwSTO /;
4538  Parameter pSolarEnergyZone(z,y);
4539   
4540  pSolarPower(z,q,d,t,y) = sum((gzmap(g,z),gtechmap(g,PVtech),gfmap(g,f)), vPwrOut.l(g,f,q,d,t,y));
4541  pSolarEnergyZone(z,y) = sum((q,d,t), pSolarPower(z,q,d,t,y)*pHours(q,d,t));
4542  pSolarValueZone(z,y)$(pSolarEnergyZone(z,y) > 0) = sum((q,d,t), pHourlyPrice(z,q,d,t,y)*pSolarPower(z,q,d,t,y))/pSolarEnergyZone(z,y);
4543  pSolarCost(z,y)$(pSolarEnergyZone(z,y) > 0) = (sum((gzmap(ng,z),gtechmap(ng,PVtech)), pCRF(ng)*vCap.l(ng,y)*pGenData(ng,"Capex")*pCapexTrajectories(ng,y))*1e6)/pSolarEnergyZone(z,y);
4544   
4545   
4546  * ============================================================
4547  * 10. METRICS
4548  * ============================================================
4549   
4550  * ---------------------------------------------------------
4551  * LCOE by plant [$/MWh]
4552  * ---------------------------------------------------------
4553   
4554  Parameter
4555    pPlantEnergyMWh(z,g,y) "Annual energy production by plant [MWh]"
4556  ;
4557   
4558  * Plant-level energy denominator
4559  pPlantEnergyMWh(z,g,y)$pEnergyPlant(z,g,y) = pEnergyPlant(z,g,y)*1e3;
4560   
4561  * LCOE for new capacity plants (without direct spinning reserve cost)
4562  pPlantAnnualLCOE(z,g,y)$((pPlantEnergyMWh(z,g,y)) and (pPlantEnergyMWh(z,g,y) >= 1e3)) =
4563      1e6 * (
4564          pCostsPlant(z, g, "Investment costs: $m", y)
4565        + pCostsPlant(z, g, "Fixed O&M: $m", y)
4566        + pCostsPlant(z, g, "Variable Cost: $m", y)
4567  *      + pCostsPlant(z, g, "Spinning Reserve Cost: $m", y)
4568      ) / pPlantEnergyMWh(z,g,y);
4569   
4570   
4571  * Zone-level generation cost intensity by component [$/MWh]
4572  pGenCostsPerMWh(z,genCostCmp,y)$sum(gzmap(g,z), pEnergyPlant(z,g,y)) =
4573      1e6 * sum(gzmap(g,z), pCostsPlant(z, g, genCostCmp, y))
4574      / (sum(gzmap(g,z), pEnergyPlant(z,g,y)) * 1e3);
4575   
4576   
4577  * ============================================================
4578  * 11. modeltype PARAMETERS
4579  * ============================================================
4580   
4581  pSolverParameters("modeltype Status")               = PA.modelstat + EPS;
4582  pSolverParameters("modeltype Time: ms")             = PA.etSolve + EPS;
4583  pSolverParameters("Absolute gap")                = PA.objVal-PA.objEst + EPS;
4584  pSolverParameters("Relative gap")$(PA.objVal >0) = pSolverParameters("Absolute gap")/PA.objVal + EPS;
4585   
4586  *--- END RESULTS
